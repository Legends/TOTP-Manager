<Window x:Class="TOTP.Updater.UpdateInstallerForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TOTP Manager Updater"
        Width="560"
        Height="290"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#1A2E4E" />
            <Setter Property="Foreground"
                    Value="#FFF4F7FF" />
            <Setter Property="BorderBrush"
                    Value="#335A91" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="14,6" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Margin="10"
            Padding="18"
            CornerRadius="14"
            Background="#FF10213F"
            BorderBrush="#FF7D7FF4"
            BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="78"
                    Margin="0,0,0,14"
                    CornerRadius="10"
                    Background="#162B4F"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1">
                <Grid Margin="14,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TOTP Manager Updates"
                                   Foreground="White"
                                   FontSize="17"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Applying the signed update package and relaunching the app."
                                   Margin="0,4,0,0"
                                   Foreground="#FFD7E6FF"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock x:Name="TitleTextBlock"
                       Grid.Row="1"
                       FontSize="21"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="Installing update" />

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="2"
                       Margin="0,12,0,0"
                       FontSize="14"
                       Foreground="#FFCBDAF3"
                       Text="Preparing updater..." />

            <TextBlock x:Name="DetailTextBlock"
                       Grid.Row="3"
                       Margin="0,8,0,0"
                       FontSize="12"
                       Foreground="#FF9CC3FF"
                       TextWrapping="Wrap" />

            <Border Grid.Row="4"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="#141F3559"
                    CornerRadius="10"
                    BorderBrush="#334F80"
                    BorderThickness="1">
                <StackPanel>
                    <ProgressBar x:Name="InstallProgressBar"
                                 Height="18"
                                 IsIndeterminate="True"
                                 Minimum="0"
                                 Maximum="100"
                                 Foreground="#FF7D7FF4"
                                 Background="#1A2E4E" />

                    <TextBlock x:Name="ProgressTextBlock"
                               Margin="0,10,0,0"
                               FontSize="11"
                               Foreground="#FFCBDAF3"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="5"
                        Margin="0,16,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CloseButton"
                        Width="100"
                        Height="30"
                        IsEnabled="False"
                        Content="Close"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CloseButton_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
