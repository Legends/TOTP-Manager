<syncfusion:ChromelessWindow x:Class="TOTP.Updater.UpdateInstallerWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             Title="TOTP Manager Updater"
                             Width="560"
                             Height="290"
                             ResizeMode="NoResize"
                             WindowStartupLocation="CenterScreen"
                             Topmost="True"
                             Background="Transparent"
                             AllowsTransparency="True"
                             WindowStyle="None"
                             TitleBarHeight="0"
                             ShowTitle="False"
                             ShowIcon="False"
                             ShowMinimizeButton="False"
                             ShowMaximizeButton="False"
                             ShowInTaskbar="True">
    <syncfusion:ChromelessWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#1A2E4E" />
            <Setter Property="Foreground"
                    Value="#FFF4F7FF" />
            <Setter Property="BorderBrush"
                    Value="#335A91" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="14,6" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>
    </syncfusion:ChromelessWindow.Resources>

    <Border Margin="10"
            Padding="18"
            CornerRadius="14"
            Background="#FF10213F"
            BorderBrush="#FF7D7FF4"
            BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="78"
                    Margin="0,0,0,14"
                    CornerRadius="10"
                    Background="#162B4F"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1">
                <Grid Margin="14,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TOTP Manager Updates"
                                   Foreground="White"
                                   FontSize="17"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Applying the signed update package and relaunching the app."
                                   Margin="0,4,0,0"
                                   Foreground="#FFD7E6FF"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock
                       Grid.Row="1"
                       FontSize="21"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="{Binding TitleText, Mode=OneWay}" />

            <TextBlock
                       Grid.Row="2"
                       Margin="0,12,0,0"
                       FontSize="14"
                       Foreground="#FFCBDAF3"
                       Text="{Binding StatusText, Mode=OneWay}" />

            <TextBlock
                       Grid.Row="3"
                       Margin="0,8,0,0"
                       FontSize="12"
                       Foreground="#FF9CC3FF"
                       TextWrapping="Wrap"
                       Text="{Binding DetailText, Mode=OneWay}" />

            <Border Grid.Row="4"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="#141F3559"
                    CornerRadius="10"
                    BorderBrush="#334F80"
                    BorderThickness="1">
                <StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Current step"
                                   FontSize="10"
                                   Foreground="#7FA7D8"
                                   TextWrapping="Wrap" />
                        <TextBlock
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#FF9CC3FF"
                                   TextWrapping="Wrap"
                                   Text="{Binding DetailText, Mode=OneWay}" />
                    </StackPanel>

                    <ProgressBar
                                 Height="18"
                                 Minimum="0"
                                 Maximum="100"
                                 Foreground="#FF7D7FF4"
                                 Background="#1A2E4E"
                                 IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}"
                                 Value="{Binding ProgressValue, Mode=OneWay}" />

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="Overall progress"
                                   FontSize="10"
                                   Foreground="#7FA7D8"
                                   TextWrapping="Wrap" />
                        <TextBlock
                                   Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="#FFCBDAF3"
                                   TextWrapping="Wrap"
                                   Text="{Binding ProgressText, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="5"
                        Margin="0,16,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button
                        Width="100"
                        Height="30"
                        Content="Close"
                        Command="{Binding CloseCommand}"
                        IsEnabled="{Binding IsCloseEnabled, Mode=OneWay}"
                        Visibility="{Binding IsCloseEnabled, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Border>
</syncfusion:ChromelessWindow>
