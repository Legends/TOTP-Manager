<syncfusion:ChromelessWindow x:Class="TOTP.Windows.KeyValueDialog"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:local="clr-namespace:TOTP.Windows"
                             xmlns:vm="clr-namespace:TOTP.ViewModels"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             mc:Ignorable="d"
                             Title="add new platform secret"
                             Height="270"
                             Width="300"
                             WindowStartupLocation="CenterOwner"
                             ResizeMode="NoResize"
                             TitleBarBackground="#7D7FF4"
                             TitleBarForeground="White"
                             ShowInTaskbar="False">

    <StackPanel Margin="24"
                FocusManager.FocusedElement="{Binding ElementName=KeyTextBox}">

        <TextBlock Text="platform"
                   Foreground="White"
                   FontWeight="Medium"
                   Margin="0,5" />

        <syncfusion:SfTextBoxExt x:Name="KeyTextBox"
                                 Watermark="i.e. github, microsoft, ..."
                                 Focusable="True"
                                 Margin="0,0,0,12"
                                 Text="{Binding Platform, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="shared secret"
                   FontWeight="Medium"
                   Foreground="White"
                   Margin="0,5" />

        <syncfusion:SfTextBoxExt Watermark="base32-encoded string"
                                 Margin="0,0,0,16"
                                 Text="{Binding Secret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="account (optional)"
                   FontWeight="Medium"
                   Foreground="White"
                   Margin="0,5" />

        <syncfusion:SfTextBoxExt Watermark="username or email"
                                 Margin="0,0,0,16"
                                 Text="{Binding Account, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="72"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Click="Ok_Click" />
            <Button Content="Cancel"
                    Width="72"
                    IsCancel="True" />
        </StackPanel>
    </StackPanel>
</syncfusion:ChromelessWindow>
