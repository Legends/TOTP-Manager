<syncfusion:ChromelessWindow x:Class="TOTP.MainWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                             xmlns:behaviors="clr-namespace:TOTP.Behaviors"
                             xmlns:converters="clr-namespace:TOTP.Converters"
                             xmlns:props="clr-namespace:TOTP.AttachedProperties"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                             xmlns:resx="clr-namespace:TOTP.Resources"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             mc:Ignorable="d"
                             Width="350"
                             SizeToContent="Height"
                             Icon="/Assets/Icons/app.ico"
                             Title="TOTP Manager"
                             TitleBarBackground="#7D7FF4"
                             TitleBarForeground="{DynamicResource Brush.Foreground}"
                             WindowStartupLocation="CenterScreen">

    <!--
https://help.syncfusion.com/wpf/themes/skin-manager#themes-list:  
        Windows11Light, 
        MaterialLightBlue,
        MaterialDarkBlue
-->
    <syncfusion:ChromelessWindow.Resources>
        <!--<BoolToVisibilityConverterCollapsed x:Key="BoolToVisibilityConverterCollapsed" />-->

        <BounceEase x:Key="BounceEase"
                    Bounces="1"
                    Bounciness="100"
                    EasingMode="EaseOut" />

    </syncfusion:ChromelessWindow.Resources>

    <StackPanel Orientation="Vertical"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">

        <syncfusion:ToolBarAdv HorizontalAlignment="Stretch"
                               Height="30"
                               MaxHeight="35"
                               Foreground="{DynamicResource Brush.Foreground}"
                               Background="Transparent"
                               OverflowMode="AsNeeded">

            <Button ToolTip="Add new"
                    Margin="5,0"
                    Command="{Binding AddNewTotpCommand}">
                <!--svg image property must be set to Resource !-->
                <svgc:SvgViewbox Source="/Assets/Icons/plus-24x24.svg"
                                 Height="15"
                                 Stretch="Uniform" />
            </Button>

            <Separator />

            <Button Command="{Binding ToggleSearchBoxCommand}"
                    Margin="5,0"
                    ToolTip="{xaml:Resx Key=ui_btnSearch}">
                <!--svg image property must be set to Resource !-->
                <svgc:SvgViewbox Source="/Assets/Icons/find-24x24.svg"
                                 Height="17"
                                 Stretch="Uniform" />
            </Button>

            <!-- Search Box -->
            <syncfusion:SfTextBoxExt Width="150"
                                     Height="30"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Stretch"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="{xaml:Resx Key=ui_label_Search_Dots}"
                                     props:FocusExtension.IsFocused="{Binding IsSearchFocused}"
                                     Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}"
                                     Padding="0"
                                     Margin="10,0,0,0" />
            <Button Content="×"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="20"
                    Height="20"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="-20,0,0,0"
                    Command="{Binding ClearSearchCommand}"
                    Visibility="{Binding IsSearchTextNotEmpty, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />
        </syncfusion:ToolBarAdv>


        <Grid Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Row 0: DataGrid -->
                <RowDefinition Height="Auto" />
                <!-- Row 1: QR Code -->
                <RowDefinition Height="Auto" />
                <!-- Row 2:TOTP Label -->
                <RowDefinition Height="Auto" />
                <!-- Row 2: Copied Label -->

            </Grid.RowDefinitions>

            <syncfusion:SfDataGrid x:Name="SecretsGrid"
                                   Grid.Row="0"
                                   AllowEditing="True"
                                   AllowDeleting="True"
                                   AutoGenerateColumns="False"
                                   CanMaintainScrollPosition="True"
                                   EditTrigger="OnDoubleTap"
                                   SelectedItem="{Binding SelectedSecret, Mode=TwoWay}"
                                   SelectionMode="Single"
                                   SelectionUnit="Row"
                                   NavigationMode="Cell"
                                   ItemsSource="{Binding FilteredSecrets}"
                                   LiveDataUpdateMode="AllowDataShaping"
                                   MaxHeight="200"
                                   MaxWidth="340"
                                   Margin="0,0,0,20"
                                   BorderThickness="0"
                                   RowSelectionBrush="#1D3366"
                                   SelectionForegroundBrush="#87CE3E"
                                   CurrentCellBorderBrush="Transparent"
                                   CurrentCellBorderThickness="0"
                                   HorizontalAlignment="Stretch"
                                   ColumnSizer="Star">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <i:InvokeCommandAction Command="{Binding SelectionChangedCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>

                <i:Interaction.Behaviors>
                    <behaviors:SfDataGridEditingBehavior BeginEditCommand="{Binding BeginEditCommand}"
                                                         EndEditCommand="{Binding EndEditCommand}"
                                                         DoubleClickCommand="{Binding DoubleClickCommand}" />

                    <behaviors:ToggleColumnVisibilityBehavior ShowActionsColumn="{Binding ShowActionsColumn}" />

                    <!--<behaviors:SingleOrDoubleTapBehavior SingleTapCommand="{Binding SingleTapCommand}"
                                                         DoubleTapCommand="{Binding DoubleTapCommand}"
                                                         TapDelay="300" />-->
                    <behaviors:SfDataGridContextMenuBehavior />
                </i:Interaction.Behaviors>

                <syncfusion:SfDataGrid.Resources>
                    <Style TargetType="syncfusion:GridHeaderCellControl">
                        <Setter Property="Background"
                                Value="#269797">
                            <!--<Setter.Value>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="0,1">
                                    <GradientStop Color="#FF1976D2"
                                                  Offset="0" />
                                    <GradientStop Color="#FF005577"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Setter.Value>-->
                        </Setter>
                        <Setter Property="Foreground"
                                Value="{DynamicResource Brush.Foreground}" />
                        <Setter Property="FontWeight"
                                Value="Bold" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Center" />
                    </Style>

                </syncfusion:SfDataGrid.Resources>

                <syncfusion:SfDataGrid.Columns>
                    <syncfusion:GridTextColumn HeaderText="{xaml:Resx Key=ui_Header_Platform}"
                                               MappingName="Platform" />

                    <syncfusion:GridTextColumn HeaderText="{xaml:Resx Key=ui_Header_Secret}"
                                               MappingName="Secret" />

                    <!--<syncfusion:GridTemplateColumn x:Name="ActionsColumn"
                                                   HeaderText="Actions">

                        <syncfusion:GridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBeingEdited}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                   
                 
                                    <Button  FontFamily="Segoe MDL2 Assets"
                                             Content="&#xE74D;"
                                             ToolTip="Delete"
                                             Command="{Binding DataContext.DeleteSecretCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                             CommandParameter="{Binding}"
                                             Focusable="False" />


                                </StackPanel>
                            </DataTemplate>
                        </syncfusion:GridTemplateColumn.CellTemplate>
                    </syncfusion:GridTemplateColumn>-->

                </syncfusion:SfDataGrid.Columns>

                <syncfusion:SfDataGrid.RecordContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{xaml:Resx Key=ui_btnDelete}"
                                  Padding="0,0,2,0"
                                  Foreground="{DynamicResource Brush.Foreground}"
                                  Command="{Binding DataGrid.DataContext.DeleteSecretCommand}"
                                  CommandParameter="{Binding Record}">
                            <MenuItem.Icon>
                                <svgc:SvgViewbox Width="11"
                                                 Height="11"
                                                 Source="/Assets/Icons/delete-24x24.svg" />
                            </MenuItem.Icon>

                        </MenuItem>
                        <!--<MenuItem Header="Delete"
                                  Command="{Binding DataGrid.DataContext.DeleteSecretCommand2}"
                                  CommandParameter="{Binding}"> Here you dont get the SecretItem but a GridInfoContext object                 
                            <MenuItem.Icon>
                                -->
