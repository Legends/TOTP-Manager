<syncfusion:ChromelessWindow x:Class="TOTP.MainWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                             xmlns:behaviors="clr-namespace:TOTP.Behaviors"
                             xmlns:converters="clr-namespace:TOTP.Converters"
                             xmlns:props="clr-namespace:TOTP.AttachedProperties"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                             xmlns:resx="clr-namespace:TOTP.Core.Resources"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             xmlns:models="clr-namespace:TOTP.Core.Models"
                             mc:Ignorable="d"
                             Width="350"
                             SizeToContent="Height"
                             Icon="/Assets/Icons/app.ico"
                             Title="TOTP Manager"
                             TitleBarBackground="#7D7FF4"
                             TitleBarForeground="{DynamicResource Brush.Foreground}"
                             WindowStartupLocation="CenterScreen">

    <!--
https://help.syncfusion.com/wpf/themes/skin-manager#themes-list:  
        Windows11Light, 
        MaterialLightBlue,
        MaterialDarkBlue
-->
    <syncfusion:ChromelessWindow.Resources>
        <!--<BoolToVisibilityConverterCollapsed x:Key="BoolToVisibilityConverterCollapsed" />-->

        <BounceEase x:Key="BounceEase"
                    Bounces="1"
                    Bounciness="100"
                    EasingMode="EaseOut" />
        <converters:SecretMaskConverter x:Key="SecretMaskConverter" />
    </syncfusion:ChromelessWindow.Resources>

    <StackPanel Orientation="Vertical"
                Margin="0,5,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">

        <Grid Height="30"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- left side -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Grid.Column="0">

                <!-- Add Button -->
                <Button ToolTip="{xaml:Resx Key=tooltip_AddNew}"
                        Margin="5,5,0,0"
                        Padding="5,5"
                        Command="{Binding AddNewSecretCommand}">
                    <svgc:SvgViewbox Source="/Assets/Icons/plus-24x24.svg"
                                     Height="15"
                                     Stretch="Uniform" />
                </Button>

                <!-- Search Button -->
                <Button Command="{Binding ToggleSearchBoxCommand}"
                        ToolTip="{xaml:Resx Key=ui_btnSearch}"
                        Margin="5,5,5,0"
                        Padding="5,5">
                    <svgc:SvgViewbox Source="/Assets/Icons/find-24x24.svg"
                                     Height="15"
                                     Stretch="Uniform" />
                </Button>

                <!-- Search field -->
                <syncfusion:SfTextBoxExt Width="150"
                                         Height="30"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Stretch"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Watermark="{xaml:Resx Key=ui_label_Search_Dots}"
                                         props:FocusExtension.IsFocused="{Binding IsSearchFocused}"
                                         Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}"
                                         Padding="0"
                                         Margin="10,0,0,0" />

                <!-- Clear-Suche-Button -->
                <Button Content="×"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Center"
                        Margin="-20,0,0,0"
                        Command="{Binding ClearSearchCommand}"
                        Visibility="{Binding IsSearchTextNotEmpty, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />

            </StackPanel>

            <!-- right side: language selection -->
            <syncfusion:ComboBoxAdv Grid.Column="1"
                                    ItemsSource="{Binding SupportedCultures}"
                                    SelectedItem="{Binding SelectedCulture, Mode=TwoWay}"
                                    Width="50"
                                    VerticalAlignment="Center"
                                    Margin="2"
                                    AllowMultiSelect="False">
                <syncfusion:ComboBoxAdv.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding IconPath}"
                                   Width="20"
                                   Height="25"
                                   Margin="0,0,5,0" />
                        </StackPanel>
                    </DataTemplate>
                </syncfusion:ComboBoxAdv.ItemTemplate>
            </syncfusion:ComboBoxAdv>
        </Grid>


        <Grid Margin="10,20,10,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Row 0: DataGrid -->
                <RowDefinition Height="Auto" />
                <!-- Row 1: QR Code -->
                <RowDefinition Height="Auto" />
                <!-- Row 2:TOTP Label -->
                <RowDefinition Height="Auto" />
                <!-- Row 2: Copied Label -->

            </Grid.RowDefinitions>

            <syncfusion:SfDataGrid x:Name="SecretsGrid"
                                   Grid.Row="0"
                                   AllowEditing="True"
                                   AllowDeleting="True"
                                   GridValidationMode="InView"
                                   AutoGenerateColumns="False"
                                   CanMaintainScrollPosition="True"
                                   EditTrigger="OnDoubleTap"
                                   SelectedItem="{Binding SelectedSecret, Mode=TwoWay}"
                                   SelectionMode="Single"
                                   SelectionUnit="Row"
                                   SelectionChanged="DataGrid_SelectionChanged"
                                   NavigationMode="Cell"
                                   ItemsSource="{Binding FilteredSecrets}"
                                   LiveDataUpdateMode="AllowDataShaping"
                                   MaxHeight="200"
                                   MaxWidth="340"
                                   Margin="0,0,0,20"
                                   BorderThickness="0"
                                   RowSelectionBrush="#1D3366"
                                   SelectionForegroundBrush="#87CE3E"
                                   CurrentCellBorderBrush="Transparent"
                                   CurrentCellBorderThickness="0"
                                   HorizontalAlignment="Stretch"
                                   ColumnSizer="Star">
                <!--<i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <i:InvokeCommandAction Command="{Binding SelectionChangedCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>-->
                <!--<i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <behaviors:AsyncInvokeCommandAction Command="{Binding SelectionChangedCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>-->


                <i:Interaction.Behaviors>
                    <behaviors:DataGridValidationBehavior />
                    <behaviors:SfDataGridEditingBehavior BeginEditCommand="{Binding BeginEditCommand}"
                                                         EndEditCommand="{Binding EndEditCommand}"
                                                         DoubleClickCommand="{Binding DoubleClickCommand}" />

                    <behaviors:ToggleColumnVisibilityBehavior ShowActionsColumn="{Binding ShowActionsColumn}" />

                    <behaviors:SfDataGridContextMenuBehavior />
                </i:Interaction.Behaviors>

                <syncfusion:SfDataGrid.Resources>
                    <Style TargetType="syncfusion:GridHeaderCellControl">
                        <Setter Property="Background"
                                Value="#269797">
                            <!--<Setter.Value>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="0,1">
                                    <GradientStop Color="#FF1976D2"
                                                  Offset="0" />
                                    <GradientStop Color="#FF005577"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Setter.Value>-->
                        </Setter>
                        <Setter Property="Foreground"
                                Value="{DynamicResource Brush.Foreground}" />
                        <Setter Property="FontWeight"
                                Value="Bold" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Center" />
                    </Style>

                </syncfusion:SfDataGrid.Resources>

                <syncfusion:SfDataGrid.Columns>
                    <syncfusion:GridTextColumn HeaderText="{xaml:Resx Key=ui_Header_Platform}"
                                               MappingName="Platform" />

                    <!--<syncfusion:GridTextColumn HeaderText="{xaml:Resx Key=ui_Header_Secret}"
                                               MappingName="Secret" />-->

                    <syncfusion:GridTemplateColumn MappingName="Secret"
                                                   HeaderText="{xaml:Resx Key=ui_Header_Secret}">

                        <!-- Display Mode -->
                        <syncfusion:GridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- Masked text display -->
                                <TextBlock TextAlignment="Left"
                                           VerticalAlignment="Center"
                                           Padding="5,2,5,0"
                                           Text="{Binding Secret, Converter={StaticResource SecretMaskConverter}}" />
                            </DataTemplate>
                        </syncfusion:GridTemplateColumn.CellTemplate>

                        <!-- Edit Mode -->
                        <syncfusion:GridTemplateColumn.EditTemplate>
                            <DataTemplate>
                                <PasswordBox props:PasswordBoxHelper.BindPassword="True"
                                             VerticalContentAlignment="Center"
                                             Padding="5,2,5,0"
                                             props:PasswordBoxHelper.BoundPassword="{Binding Secret, Mode=TwoWay,  UpdateSourceTrigger=PropertyChanged}" />

                            </DataTemplate>
                        </syncfusion:GridTemplateColumn.EditTemplate>

                    </syncfusion:GridTemplateColumn>
                </syncfusion:SfDataGrid.Columns>

                <syncfusion:SfDataGrid.RecordContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{Binding DataGrid.DataContext.DeleteLabel}"
                                  Padding="0,0,2,0"
                                  Foreground="{DynamicResource Brush.Foreground}"
                                  Command="{Binding DataGrid.DataContext.DeleteSecretCommand}"
                                  CommandParameter="{Binding Record}">
                            <MenuItem.Icon>
                                <svgc:SvgViewbox Width="11"
                                                 Height="11"
                                                 Source="/Assets/Icons/delete-24x24.svg" />
                            </MenuItem.Icon>

                        </MenuItem>
                    </ContextMenu>
                </syncfusion:SfDataGrid.RecordContextMenu>

            </syncfusion:SfDataGrid>

            <Label x:Name="lblCode"
                   Grid.Row="2"
                   Content="{Binding CurrentCodeLabel}"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Height="{Binding CodeLabelHeight}"
                   FontWeight="Bold"
                   Foreground="#97B0DF"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   Margin="0,0">
                <Label.RenderTransform>
                    <TranslateTransform />
                </Label.RenderTransform>
                <Label.Style>
                    <Style TargetType="Label">
                        <Setter Property="Opacity"
                                Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCodeLabelVisible}"
                                         Value="True">
                                <Setter Property="Opacity"
                                        Value="1" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                             From="0"
                                                             To="-10"
                                                             Duration="0:0:0.2"
                                                             AutoReverse="True"
                                                             EasingFunction="{StaticResource BounceEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Label.Style>
            </Label>

            <Image Grid.Row="1"
                   Margin="0,0,0,20"
                   Source="{Binding QrCodeImage}"
                   Width="130"
                   Height="130"
                   Visibility="{Binding IsQrVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />


            <TextBlock x:Name="lblCopiedToClipboard"
                       Grid.Row="3"
                       Margin="0,10"
                       Text="{xaml:Resx Key=ui_Code_Copied_Clipboard}"
                       TextAlignment="Center"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#FF22ED20"
                       TextWrapping="Wrap"
                       Visibility="{Binding IsCodeCopiedVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      Color="Aqua" />
                </TextBlock.Effect>
            </TextBlock>

        </Grid>
    </StackPanel>
</syncfusion:ChromelessWindow>