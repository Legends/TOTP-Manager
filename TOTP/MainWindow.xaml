                    </ContextMenu>
                </syncfusion:SfDataGrid.RecordContextMenu>

            </syncfusion:SfDataGrid>

            <Label x:Name="lblCode"
                   Grid.Row="2"
                   Content="{Binding CurrentCodeLabel}"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Height="{Binding CodeLabelHeight}"
                   FontWeight="Bold"
                   Foreground="#97B0DF"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   Margin="0,0">
                <Label.RenderTransform>
                    <TranslateTransform />
                </Label.RenderTransform>
                <Label.Style>
                    <Style TargetType="Label">
                        <Setter Property="Opacity"
                                Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCodeLabelVisible}"
                                         Value="True">
                                <Setter Property="Opacity"
                                        Value="1" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                             From="0"
                                                             To="-10"
                                                             Duration="0:0:0.2"
                                                             AutoReverse="True"
                                                             EasingFunction="{StaticResource BounceEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Label.Style>
            </Label>

            <Image Grid.Row="1"
                   Margin="0,0,0,20"
                   Source="{Binding QrCodeImage}"
                   Width="130"
                   Height="130"
                   Visibility="{Binding IsQrVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />


            <Label x:Name="lblCopiedToClipboard"
                   Grid.Row="3"
                   Margin="0,10"
                   Content="Code was copied to clipboard!"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Top"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#FF22ED20"
                   Visibility="{Binding IsCodeCopiedVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}">
                <Label.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      Color="Aqua" />
                </Label.Effect>
            </Label>
        </Grid>
    </StackPanel>
</syncfusion:ChromelessWindow>