<UserControl x:Class="TOTP.AutoUpdate.AutoUpdateProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:xaml="clr-namespace:TOTP.Xaml"
             mc:Ignorable="d">
    <Grid Width="332" Height="350">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Height="74"
                Margin="0,0,0,14"
                CornerRadius="10"
                ClipToBounds="True">
            <Grid>
                <Image Source="/Assets/backgrounds/background-main.png"
                       Stretch="UniformToFill"
                       Opacity="0.5" />
                <Rectangle Fill="{StaticResource Brush.SurfaceOverlay}" />
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,14,0">
                    <Image Source="/Assets/Icons/app.ico"
                           Width="24"
                           Height="24"
                           Stretch="Uniform" />
                    <TextBlock Text="{xaml:Resx Key=ui_Updater_Download_Title}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource TextStyle.SectionHeader}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding ProgressTitleText}"
                       Style="{StaticResource TextStyle.SectionHeader}" />

            <Border Grid.Column="1"
                    Padding="10,5"
                    CornerRadius="999"
                    Background="{StaticResource Brush.AccentChipBackground}"
                    BorderBrush="{StaticResource Brush.BorderAccent}"
                    BorderThickness="1">
                <TextBlock Text="{Binding ProgressStateText}"
                           Foreground="{StaticResource Brush.TextTertiary}"
                           FontSize="{StaticResource FontSize.Caption}"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="{StaticResource Brush.TextSecondary}"
                   FontSize="{StaticResource FontSize.Body}"
                   TextWrapping="Wrap"
                   Text="{Binding ProgressVersionText}" />

        <TextBlock Grid.Row="3"
                   Margin="0,8,0,0"
                   Foreground="{StaticResource Brush.TextInfo}"
                   FontSize="{StaticResource FontSize.Caption}"
                   TextWrapping="Wrap"
                   Text="{Binding ProgressDownloadInfoText}" />

        <ProgressBar Grid.Row="4"
                     Height="10"
                     Margin="0,16,0,0"
                     Minimum="0"
                     Maximum="100"
                     IsIndeterminate="{Binding ProgressIndeterminate}"
                     Value="{Binding ProgressValue, Mode=OneWay}"
                     Foreground="{StaticResource Brush.AccentPrimary}"
                     Background="{StaticResource Brush.SurfaceProgressTrack}"
                     BorderThickness="0" />

        <TextBlock Grid.Row="5"
                   Margin="0,10,0,0"
                   MaxWidth="296"
                   Foreground="{StaticResource Brush.TextTertiary}"
                   FontSize="{StaticResource FontSize.Body}"
                   TextWrapping="Wrap"
                   TextTrimming="None"
                   Text="{Binding ProgressDescriptionText}" />

        <StackPanel Grid.Row="6"
                    Margin="0,16,0,0">
            <TextBlock MaxWidth="296"
                       Foreground="{StaticResource Brush.TextDanger}"
                       FontSize="{StaticResource FontSize.Body}"
                       TextWrapping="Wrap"
                       TextTrimming="None"
                       Visibility="{Binding ProgressErrorVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Text="{Binding ProgressErrorText}" />

            <Button Width="120"
                    Height="30"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Right"
                    IsEnabled="{Binding ProgressActionEnabled}"
                    Command="{Binding ProgressActionCommand}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <ProgressBar Width="14"
                                 Height="14"
                                 Margin="0,0,8,0"
                                 IsIndeterminate="True"
                                 Minimum="0"
                                 Maximum="100"
                                 Visibility="{Binding ProgressActionBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding ProgressActionText}" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
