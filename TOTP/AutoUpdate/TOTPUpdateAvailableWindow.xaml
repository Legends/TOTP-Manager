<Window x:Class="TOTP.AutoUpdate.TOTPUpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#1A2E4E" />
            <Setter Property="Foreground"
                    Value="#FFF4F7FF" />
            <Setter Property="BorderBrush"
                    Value="#335A91" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="12,6" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>
        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background"
                    Value="#FF7D7FF4" />
            <Setter Property="BorderBrush"
                    Value="#FF9899FF" />
            <Setter Property="Foreground"
                    Value="White" />
        </Style>
        <Style x:Key="PackageListItemStyle"
               TargetType="ListBoxItem">
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="10"
                                Background="#0EFFFFFF"
                                CornerRadius="8"
                                BorderBrush="#00000000"
                                BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#1F7D7FF4" />
                                <Setter TargetName="ItemBorder"
                                        Property="BorderBrush"
                                        Value="#FF7D7FF4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#18FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Margin="10"
            Padding="18"
            CornerRadius="14"
            Background="#FF10213F"
            BorderBrush="#FF7D7FF4"
            BorderThickness="1.5">
        <Grid Width="396">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="84"
                    Margin="0,0,0,14"
                    CornerRadius="10"
                    ClipToBounds="True">
                <Grid>
                    <Image Source="/Assets/backgrounds/background-main.png"
                           Stretch="UniformToFill"
                           Opacity="0.48" />
                    <Rectangle Fill="#B010213F" />
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,14,0">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="12"
                                Background="#FF162B4F"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1">
                            <Image Source="/Assets/Icons/app.ico"
                                   Width="24"
                                   Height="24"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="TOTP Manager Updates"
                                       Foreground="White"
                                       FontSize="17"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Verified feed with release notes and installer details"
                                       Margin="0,4,0,0"
                                       Foreground="#FFD7E6FF"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="HeaderText"
                               Text="Update available"
                               Foreground="White"
                               FontSize="19"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SummaryText"
                               Margin="0,8,0,0"
                               Foreground="#FFCBDAF3"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Padding="10,5"
                        CornerRadius="999"
                        Background="#1B7D7FF4"
                        BorderBrush="#FF7D7FF4"
                        BorderThickness="1">
                    <TextBlock x:Name="StatusChipText"
                               Text="Ready"
                               Foreground="#FFF4F7FF"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,14,0,0"
                    Padding="10"
                    Background="#141F3559"
                    CornerRadius="10"
                    BorderBrush="#334F80"
                    BorderThickness="1">
                <syncfusion:TabControlExt Background="Transparent"
                                          BorderThickness="0"
                                          TabItemHoverBorderBrush="#FF7D7FF4"
                                          TabItemHoverBackground="Transparent"
                                          TabItemHoverForeground="#FFF4F7FF"
                                          CloseButtonType="Hide"
                                          TabStripPlacement="Top"
                                          Foreground="White">
                    <syncfusion:TabItemExt Header="Overview">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock x:Name="InstalledVersionText"
                                           Foreground="#FFCBDAF3"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="CurrentVersionText"
                                           Margin="0,6,0,0"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <TextBlock x:Name="ActionHintText"
                                           Margin="0,8,0,0"
                                           Foreground="#FFCBDAF3"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Padding="10"
                                    Background="#10000000"
                                    CornerRadius="8"
                                    BorderBrush="#224B79"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Package selection"
                                               Foreground="#FFF4F7FF"
                                               FontWeight="SemiBold"
                                               FontSize="12" />
                                    <ListBox x:Name="UpdatesList"
                                             Margin="0,8,0,0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             SelectionChanged="UpdatesList_OnSelectionChanged"
                                             ItemContainerStyle="{StaticResource PackageListItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold" />
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="8,3"
                                                                CornerRadius="999"
                                                                Background="#183C6AD1">
                                                            <TextBlock Text="{Binding ShortVersion}"
                                                                       Foreground="#FFD7E6FF"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                    </DockPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </syncfusion:TabItemExt>

                    <syncfusion:TabItemExt Header="Details">
                        <StackPanel Margin="8">
                            <TextBlock x:Name="PublishDateText"
                                       Foreground="#FFCBDAF3"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="PackageSizeText"
                                       Margin="0,8,0,0"
                                       Foreground="#FFCBDAF3"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="SourceText"
                                       Margin="0,8,0,0"
                                       Foreground="#FF9CC3FF"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </syncfusion:TabItemExt>

                    <syncfusion:TabItemExt x:Name="ReleaseNotesTab"
                                           Header="Notes">
                        <Grid Margin="8">
                            <WebBrowser x:Name="ReleaseNotesBrowser"
                                        Visibility="Visible" />
                            <ScrollViewer x:Name="ReleaseNotesFallbackPanel"
                                          VerticalScrollBarVisibility="Auto"
                                          Visibility="Collapsed">
                                <TextBlock x:Name="ReleaseNotesFallbackText"
                                           Foreground="#FFF4F7FF"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </syncfusion:TabItemExt>
                </syncfusion:TabControlExt>
            </Border>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button x:Name="SkipButton"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="84"
                        Height="30"
                        Margin="0,0,8,0"
                        Content="Skip"
                        Click="SkipButton_OnClick" />
                <Button x:Name="LaterButton"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="144"
                        Height="30"
                        Margin="0,0,8,0"
                        Content="Remind me later"
                        Click="LaterButton_OnClick" />
                <Button x:Name="InstallButton"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="126"
                        Height="30"
                        Content="Download update"
                        Click="InstallButton_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
