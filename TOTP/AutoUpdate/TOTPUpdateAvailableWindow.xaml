<local:AutoUpdateWindowBase x:Class="TOTP.AutoUpdate.TOTPUpdateAvailableWindow"
                            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:local="clr-namespace:TOTP.AutoUpdate"
                            xmlns:xaml="clr-namespace:TOTP.Xaml"
                            xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                            ResizeMode="NoResize"
                            ShowInTaskbar="False"
                            WindowStyle="None"
                            TitleBarHeight="0"
                            ShowTitle="False"
                            ShowIcon="False"
                            ShowMinimizeButton="False"
                            ShowMaximizeButton="False"
                            AllowsTransparency="True"
                            SizeToContent="WidthAndHeight"
                            Background="Transparent"
                            WindowStartupLocation="CenterScreen">
    <local:AutoUpdateWindowBase.Resources>
        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource Brush.SurfaceSecondaryButton}" />
            <Setter Property="Foreground"
                    Value="{StaticResource Brush.TextTertiary}" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource Brush.BorderStrong}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="12,6" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>
        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background"
                    Value="{StaticResource Brush.AccentPrimary}" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource Brush.BorderAccentSoft}" />
            <Setter Property="Foreground"
                    Value="{StaticResource Brush.TextPrimary}" />
        </Style>
        <Style x:Key="PackageListItemStyle"
               TargetType="ListBoxItem">
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="10"
                                Background="#0EFFFFFF"
                                CornerRadius="8"
                                BorderBrush="#00000000"
                                BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="{StaticResource Brush.AccentChipBackground}" />
                                <Setter TargetName="ItemBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.BorderAccent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#18FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:AutoUpdateWindowBase.Resources>
    <Border Margin="10"
            Padding="18"
            CornerRadius="14"
            Background="{StaticResource Brush.SurfaceCard}"
            BorderBrush="{StaticResource Brush.BorderAccent}"
            BorderThickness="1.5">
        <Grid Width="396">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="84"
                    Margin="0,0,0,14"
                    CornerRadius="10"
                    ClipToBounds="True">
                <Grid>
                    <Image Source="/Assets/backgrounds/background-main.png"
                           Stretch="UniformToFill"
                           Opacity="0.48" />
                    <Rectangle Fill="{StaticResource Brush.SurfaceOverlay}" />
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,14,0">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="12"
                                Background="#FF162B4F"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1">
                            <Image Source="/Assets/Icons/app.ico"
                                   Width="24"
                                   Height="24"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{xaml:Resx Key=ui_Updater_Available_Title}"
                                       Style="{StaticResource TextStyle.SectionHeader}" />
                            <TextBlock Text="{xaml:Resx Key=ui_Updater_Available_Subtitle}"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource TextStyle.Caption}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="HeaderText"
                               Text="{xaml:Resx Key=ui_Updater_Available_Header}"
                               Style="{StaticResource TextStyle.HeroTitle}" />
                    <TextBlock x:Name="SummaryText"
                               Margin="0,8,0,0"
                               Style="{StaticResource TextStyle.Subheader}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Padding="10,5"
                        CornerRadius="999"
                        Background="{StaticResource Brush.AccentChipBackground}"
                        BorderBrush="{StaticResource Brush.BorderAccent}"
                        BorderThickness="1">
                    <TextBlock x:Name="StatusChipText"
                               Text="{xaml:Resx Key=ui_Updater_Available_State_Ready}"
                               Foreground="{StaticResource Brush.TextTertiary}"
                               FontSize="{StaticResource FontSize.Caption}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,14,0,0"
                    Padding="10"
                    Background="{StaticResource Brush.SurfaceSubtle}"
                    CornerRadius="10"
                    BorderBrush="#334F80"
                    BorderThickness="1">
                <syncfusion:TabControlExt Background="Transparent"
                                          BorderThickness="0"
                                          TabItemHoverBorderBrush="#FF7D7FF4"
                                          TabItemHoverBackground="Transparent"
                                          TabItemHoverForeground="#FFF4F7FF"
                                          CloseButtonType="Hide"
                                          TabStripPlacement="Top"
                                          Foreground="White">
                    <syncfusion:TabItemExt Header="{xaml:Resx Key=ui_Updater_Available_Tab_Overview}">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock x:Name="InstalledVersionText"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="{StaticResource FontSize.Body}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="CurrentVersionText"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource FontSize.Label}" />
                                <TextBlock x:Name="ActionHintText"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="{StaticResource FontSize.Body}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Padding="10"
                                    Background="#10000000"
                                    CornerRadius="8"
                                    BorderBrush="#224B79"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{xaml:Resx Key=ui_Updater_Available_PackageSelection}"
                                               Foreground="{StaticResource Brush.TextTertiary}"
                                               FontWeight="SemiBold"
                                               FontSize="{StaticResource FontSize.Body}" />
                                    <ListBox x:Name="UpdatesList"
                                             Margin="0,8,0,0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             SelectionChanged="UpdatesList_OnSelectionChanged"
                                             ItemContainerStyle="{StaticResource PackageListItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                                   FontWeight="SemiBold" />
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="8,3"
                                                                CornerRadius="999"
                                                                Background="#183C6AD1">
                                                            <TextBlock Text="{Binding ShortVersion}"
                                                                       Foreground="{StaticResource Brush.TextTertiary}"
                                                                       FontSize="{StaticResource FontSize.Caption}"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                    </DockPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </syncfusion:TabItemExt>

                    <syncfusion:TabItemExt Header="{xaml:Resx Key=ui_Updater_Available_Tab_Details}">
                        <StackPanel Margin="8">
                            <TextBlock x:Name="PublishDateText"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="PackageSizeText"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="SourceText"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource Brush.TextInfo}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </syncfusion:TabItemExt>

                    <syncfusion:TabItemExt x:Name="ReleaseNotesTab"
                                           Header="{xaml:Resx Key=ui_Updater_Available_Tab_Notes}">
                        <Grid Margin="8">
                            <WebBrowser x:Name="ReleaseNotesBrowser"
                                        Visibility="Visible" />
                            <ScrollViewer x:Name="ReleaseNotesFallbackPanel"
                                          VerticalScrollBarVisibility="Auto"
                                          Visibility="Collapsed">
                                <TextBlock x:Name="ReleaseNotesFallbackText"
                                           Foreground="{StaticResource Brush.TextTertiary}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </syncfusion:TabItemExt>
                </syncfusion:TabControlExt>
            </Border>

            <WrapPanel Grid.Row="3"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       Margin="0,16,0,0"
                       ItemHeight="30">
                <Button x:Name="SkipButton"
                        
                        MinWidth="84"
                        Height="30"
                        Margin="0,0,8,0"
                        Padding="14,6"
                        Content="{xaml:Resx Key=ui_Updater_Available_Button_Skip}"
                        Click="SkipButton_OnClick" />
                <Button x:Name="LaterButton"
                        
                        MinWidth="144"
                        Height="30"
                        Margin="0,0,8,0"
                        Padding="14,6"
                        Content="{xaml:Resx Key=ui_Updater_Available_Button_Later}"
                        Click="LaterButton_OnClick" />
                <Button x:Name="InstallButton"
                       
                        MinWidth="126"
                        Height="30"
                        Padding="14,6"
                        Content="{xaml:Resx Key=ui_Updater_Available_Button_Download}"
                        Click="InstallButton_OnClick" />
            </WrapPanel>
        </Grid>
    </Border>
</local:AutoUpdateWindowBase>
