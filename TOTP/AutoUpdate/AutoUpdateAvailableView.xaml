<UserControl x:Class="TOTP.AutoUpdate.AutoUpdateAvailableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:xaml="clr-namespace:TOTP.Xaml"
             mc:Ignorable="d">
    <Grid MinWidth="396"
          MaxWidth="360">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Height="84"
                Margin="0,0,0,14"
                CornerRadius="10"
                ClipToBounds="True">
            <Grid>
                <Image Source="/Assets/backgrounds/background-main.png"
                       Stretch="UniformToFill"
                       Opacity="0.48" />
                <Rectangle Fill="{StaticResource Brush.SurfaceOverlay}" />
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,14,0">
                    <Border Width="44"
                            Height="44"
                            CornerRadius="12"
                            Background="#FF162B4F"
                            BorderBrush="#55FFFFFF"
                            BorderThickness="1">
                        <Image Source="/Assets/Icons/app.ico"
                               Width="24"
                               Height="24"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="{xaml:Resx Key=ui_Updater_Available_Title}"
                                   Style="{StaticResource TextStyle.SectionHeader}" />
                        <TextBlock Text="{xaml:Resx Key=ui_Updater_Available_Subtitle}"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource TextStyle.Caption}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding AvailableHeaderText}"
                           Style="{StaticResource TextStyle.HeroTitle}" />
                <TextBlock Text="{Binding AvailableSummaryText}"
                           Margin="0,8,0,0"
                           Style="{StaticResource TextStyle.Subheader}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Padding="10,5"
                    CornerRadius="999"
                    Background="{StaticResource Brush.AccentChipBackground}"
                    BorderBrush="{StaticResource Brush.BorderAccent}"
                    BorderThickness="1">
                <TextBlock Text="{Binding AvailableStatusText}"
                           Foreground="{StaticResource Brush.TextTertiary}"
                           FontSize="{StaticResource FontSize.Caption}"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Padding="10"
                Height="250"
                Background="{StaticResource Brush.SurfaceSubtle}"
                CornerRadius="10"
                BorderBrush="#334F80"
                BorderThickness="1">
            <syncfusion:TabControlExt x:Name="AvailableTabs"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      TabItemHoverBorderBrush="#FF7D7FF4"
                                      TabItemHoverBackground="Transparent"
                                      TabItemHoverForeground="#FFF4F7FF"
                                      CloseButtonType="Hide"
                                      TabStripPlacement="Top"
                                      Foreground="White">

                <syncfusion:TabItemExt Header="{xaml:Resx Key=ui_Updater_Available_Tab_Overview}">
                    <ScrollViewer Margin="8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding InstalledVersionText}"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="{StaticResource FontSize.Body}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CurrentVersionText}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource FontSize.Label}" />
                                <TextBlock Text="{Binding AvailableActionHintText}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="{StaticResource FontSize.Body}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Padding="10"
                                    Background="#10000000"
                                    CornerRadius="8"
                                    BorderBrush="#224B79"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{xaml:Resx Key=ui_Updater_Available_PackageSelection}"
                                               Foreground="{StaticResource Brush.TextTertiary}"
                                               FontWeight="SemiBold"
                                               FontSize="{StaticResource FontSize.Body}" />
                                    <ListBox x:Name="UpdatesList"
                                             Margin="0,8,0,0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemsSource="{Binding Updates}"
                                             SelectionChanged="UpdatesList_OnSelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding"
                                                        Value="0" />
                                                <Setter Property="Margin"
                                                        Value="0,0,0,8" />
                                                <Setter Property="HorizontalContentAlignment"
                                                        Value="Stretch" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder"
                                                                    Padding="10"
                                                                    Background="#0EFFFFFF"
                                                                    CornerRadius="8"
                                                                    BorderBrush="#00000000"
                                                                    BorderThickness="1">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected"
                                                                         Value="True">
                                                                    <Setter TargetName="ItemBorder"
                                                                            Property="Background"
                                                                            Value="{StaticResource Brush.AccentChipBackground}" />
                                                                    <Setter TargetName="ItemBorder"
                                                                            Property="BorderBrush"
                                                                            Value="{StaticResource Brush.BorderAccent}" />
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver"
                                                                         Value="True">
                                                                    <Setter TargetName="ItemBorder"
                                                                            Property="Background"
                                                                            Value="#18FFFFFF" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                                   FontWeight="SemiBold" />
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="8,3"
                                                                CornerRadius="999"
                                                                Background="#183C6AD1">
                                                            <TextBlock Text="{Binding ShortVersion}"
                                                                       Foreground="{StaticResource Brush.TextTertiary}"
                                                                       FontSize="{StaticResource FontSize.Caption}"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                    </DockPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </syncfusion:TabItemExt>

                <syncfusion:TabItemExt Header="{xaml:Resx Key=ui_Updater_Available_Tab_Details}">
                    <ScrollViewer Margin="8"
                                  MaxWidth="700"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding PublishDateText}"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding PackageSizeText}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding SourceText}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource Brush.TextInfo}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </ScrollViewer>
                </syncfusion:TabItemExt>

                <syncfusion:TabItemExt Header="{xaml:Resx Key=ui_Updater_Available_Tab_Notes}"
                                       Visibility="{Binding ReleaseNotesVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="8">
                        <WebBrowser x:Name="ReleaseNotesBrowser"
                                    Visibility="Visible" />
                        <ScrollViewer x:Name="ReleaseNotesFallbackPanel"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed">
                            <TextBlock x:Name="ReleaseNotesFallbackText"
                                       Foreground="{StaticResource Brush.TextTertiary}"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Grid>
                </syncfusion:TabItemExt>
            </syncfusion:TabControlExt>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button MinWidth="84"
                    Height="30"
                    Margin="0,0,8,0"
                    Padding="14,6"
                    Content="{xaml:Resx Key=ui_Updater_Available_Button_Skip}"
                    Command="{Binding SkipCommand}"
                    Visibility="{Binding SkipVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button MinWidth="144"
                    Height="30"
                    Margin="0,0,8,0"
                    Padding="14,6"
                    Content="{xaml:Resx Key=ui_Updater_Available_Button_Later}"
                    Command="{Binding RemindLaterCommand}"
                    Visibility="{Binding LaterVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button MinWidth="126"
                    Height="30"
                    Padding="14,6"
                    Content="{Binding InstallButtonText}"
                    Command="{Binding InstallCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
