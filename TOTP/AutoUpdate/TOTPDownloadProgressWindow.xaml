<Window x:Class="TOTP.AutoUpdate.TOTPDownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="ProgressActionButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#FF7D7FF4" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#FF9899FF" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="12,6" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>
    </Window.Resources>
    <Border Margin="10"
            Padding="18"
            CornerRadius="12"
            Background="#FF10213F"
            BorderBrush="#FF2F5E9E"
            BorderThickness="1.5">
        <Grid Width="332">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="74"
                    Margin="0,0,0,14"
                    CornerRadius="10"
                    ClipToBounds="True">
                <Grid>
                    <Image Source="/Assets/backgrounds/background-main.png"
                           Stretch="UniformToFill"
                           Opacity="0.5" />
                    <Rectangle Fill="#B010213F" />
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,14,0">
                        <Image Source="/Assets/Icons/app.ico"
                               Width="24"
                               Height="24"
                               Stretch="Uniform" />
                        <TextBlock Text="Update Transfer"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TitleText"
                           Text="Downloading update"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold" />

                <Border Grid.Column="1"
                        Padding="10,5"
                        CornerRadius="999"
                        Background="#1B7D7FF4"
                        BorderBrush="#FF7D7FF4"
                        BorderThickness="1">
                    <TextBlock x:Name="ProgressStateText"
                               Text="Downloading"
                               Foreground="#FFF4F7FF"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <TextBlock x:Name="VersionText"
                       Grid.Row="2"
                       Margin="0,8,0,0"
                       Foreground="#FFCBDAF3"
                       FontSize="12"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="DownloadInfoText"
                       Grid.Row="3"
                       Margin="0,8,0,0"
                       Foreground="#FF9CC3FF"
                       FontSize="11"
                       TextWrapping="Wrap" />

            <ProgressBar x:Name="DownloadProgressBar"
                         Grid.Row="4"
                         Height="10"
                         Margin="0,16,0,0"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="True"
                         Foreground="#FF7D7FF4"
                         Background="#FF193257"
                         BorderThickness="0" />

            <TextBlock x:Name="ProgressText"
                       Grid.Row="5"
                       Margin="0,10,0,0"
                       Foreground="#FFF4F7FF"
                       FontSize="12"
                       Text="Waiting for download to start..." />

            <StackPanel Grid.Row="6"
                        Margin="0,16,0,0">
                <TextBlock x:Name="ErrorText"
                           Foreground="#FFFF9C9C"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />

                <Button x:Name="ActionButton"
                        Style="{StaticResource ProgressActionButtonStyle}"
                        Width="120"
                        Height="30"
                        Margin="0,14,0,0"
                        HorizontalAlignment="Right"
                        Content="Close"
                        Click="ActionButton_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
