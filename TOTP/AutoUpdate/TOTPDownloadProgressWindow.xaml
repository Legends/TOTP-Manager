<syncfusion:ChromelessWindow x:Class="TOTP.AutoUpdate.TOTPDownloadProgressWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             WindowStyle="None"
                             TitleBarHeight="0"
                             ShowTitle="False"
                             ShowIcon="False"
                             ShowMinimizeButton="False"
                             ShowMaximizeButton="False"
                             ResizeMode="NoResize"
                             ShowInTaskbar="False"
                             SizeToContent="WidthAndHeight"
                             Background="Transparent"
                             AllowsTransparency="True"
                             WindowStartupLocation="CenterOwner">
    <syncfusion:ChromelessWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TOTP.UI.WPF;component/Styles/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </syncfusion:ChromelessWindow.Resources>
    <Border Margin="10"
            Padding="18"
            CornerRadius="12"
            Background="{StaticResource Brush.SurfaceCard}"
            BorderBrush="{StaticResource Brush.BorderStrong}"
            BorderThickness="1.5">
        <Grid Width="332">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="74"
                    Margin="0,0,0,14"
                    CornerRadius="10"
                    ClipToBounds="True">
                <Grid>
                    <Image Source="/Assets/backgrounds/background-main.png"
                           Stretch="UniformToFill"
                           Opacity="0.5" />
                    <Rectangle Fill="{StaticResource Brush.SurfaceOverlay}" />
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,14,0">
                        <Image Source="/Assets/Icons/app.ico"
                               Width="24"
                               Height="24"
                               Stretch="Uniform" />
                        <TextBlock Text="{xaml:Resx Key=ui_Updater_Download_Title}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource TextStyle.SectionHeader}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TitleText"
                           Text="{xaml:Resx Key=ui_Updater_Download_Header}"
                           Style="{StaticResource TextStyle.SectionHeader}" />

                <Border Grid.Column="1"
                        Padding="10,5"
                        CornerRadius="999"
                        Background="{StaticResource Brush.AccentChipBackground}"
                        BorderBrush="{StaticResource Brush.BorderAccent}"
                        BorderThickness="1">
                    <TextBlock x:Name="ProgressStateText"
                               Text="{xaml:Resx Key=ui_Updater_Download_State_Downloading}"
                               Foreground="{StaticResource Brush.TextTertiary}"
                               FontSize="{StaticResource FontSize.Caption}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <TextBlock x:Name="VersionText"
                       Grid.Row="2"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       FontSize="{StaticResource FontSize.Body}"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="DownloadInfoText"
                       Grid.Row="3"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource Brush.TextInfo}"
                       FontSize="{StaticResource FontSize.Caption}"
                       TextWrapping="Wrap" />

            <ProgressBar x:Name="DownloadProgressBar"
                         Grid.Row="4"
                         Height="10"
                         Margin="0,16,0,0"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="True"
                         Foreground="{StaticResource Brush.AccentPrimary}"
                         Background="{StaticResource Brush.SurfaceProgressTrack}"
                         BorderThickness="0" />

            <TextBlock x:Name="ProgressText"
                       Grid.Row="5"
                       Margin="0,10,0,0"
                       MaxWidth="296"
                       Foreground="{StaticResource Brush.TextTertiary}"
                       FontSize="{StaticResource FontSize.Body}"
                       TextWrapping="Wrap"
                       TextTrimming="None"
                       Text="{xaml:Resx Key=ui_Updater_Download_Waiting}" />

            <StackPanel Grid.Row="6"
                        Margin="0,16,0,0">
                <TextBlock x:Name="ErrorText"
                           MaxWidth="296"
                           Foreground="{StaticResource Brush.TextDanger}"
                           FontSize="{StaticResource FontSize.Body}"
                           TextWrapping="Wrap"
                           TextTrimming="None"
                           Visibility="Collapsed" />

                <Button x:Name="ActionButton"
                        Width="120"
                        Height="30"
                        Margin="0,14,0,0"
                        HorizontalAlignment="Right"
                        Padding="12,6"
                        Content="{xaml:Resx Key=ui_btnClose}"
                        Click="ActionButton_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</syncfusion:ChromelessWindow>
