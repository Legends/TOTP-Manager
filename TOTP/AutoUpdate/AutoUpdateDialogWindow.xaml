<!--WindowStyle="None"
TitleBarHeight="0"
ShowTitle="False"
ShowIcon="False"
ShowMinimizeButton="False"
ShowMaximizeButton="False"
AllowsTransparency="True"-->

<local:AutoUpdateWindowBase x:Class="TOTP.AutoUpdate.AutoUpdateDialogWindow"
                            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:local="clr-namespace:TOTP.AutoUpdate"
                            ResizeMode="NoResize"
                            ShowInTaskbar="False"
                            WindowStyle="None"
                            TitleBarHeight="0"
                            ShowTitle="False"
                            ShowIcon="False"
                            ShowMinimizeButton="False"
                            ShowMaximizeButton="False"
                            AllowsTransparency="True"
                            SizeToContent="WidthAndHeight"
                            Background="Transparent"
                            WindowStartupLocation="CenterOwner">
    <local:AutoUpdateWindowBase.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource Brush.SurfaceSecondaryButton}" />
            <Setter Property="Foreground"
                    Value="{StaticResource Brush.TextTertiary}" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource Brush.BorderStrong}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="12,6" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>
        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background"
                    Value="{StaticResource Brush.AccentPrimary}" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource Brush.BorderAccentSoft}" />
            <Setter Property="Foreground"
                    Value="{StaticResource Brush.TextPrimary}" />
        </Style>
    </local:AutoUpdateWindowBase.Resources>

    <Border x:Name="DialogSurface"
            Margin="10"
            Padding="18"
            CornerRadius="14"
            Background="{StaticResource Brush.SurfaceCard}"
            BorderBrush="{StaticResource Brush.BorderAccent}"
            BorderThickness="1.5">
        <Grid x:Name="DialogRoot">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="UpdateStates">
                    <VisualState x:Name="Checking">
                        <Storyboard>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckingHost"
                                                           Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                        Value="{x:Static Visibility.Visible}" />
                            </ObjectAnimationUsingKeyFrames>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="AvailableHost"
                                                           Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                        Value="{x:Static Visibility.Collapsed}" />
                            </ObjectAnimationUsingKeyFrames>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ProgressHost"
                                                           Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                        Value="{x:Static Visibility.Collapsed}" />
                            </ObjectAnimationUsingKeyFrames>
                            <DoubleAnimation Storyboard.TargetName="CheckingHost"
                                             Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.18">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="CheckingTranslate"
                                             Storyboard.TargetProperty="Y"
                                             To="0"
                                             Duration="0:0:0.18">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="Available">
                        <Storyboard>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckingHost"
                                                           Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                        Value="{x:Static Visibility.Collapsed}" />
                            </ObjectAnimationUsingKeyFrames>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="AvailableHost"
                                                           Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                        Value="{x:Static Visibility.Visible}" />
                            </ObjectAnimationUsingKeyFrames>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ProgressHost"
                                                           Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                        Value="{x:Static Visibility.Collapsed}" />
                            </ObjectAnimationUsingKeyFrames>
                            <DoubleAnimation Storyboard.TargetName="AvailableHost"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="AvailableTranslate"
                                             Storyboard.TargetProperty="Y"
                                             From="8"
                                             To="0"
                                             Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="Progress">
                        <Storyboard>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckingHost"
                                                           Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                        Value="{x:Static Visibility.Collapsed}" />
                            </ObjectAnimationUsingKeyFrames>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="AvailableHost"
                                                           Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                        Value="{x:Static Visibility.Collapsed}" />
                            </ObjectAnimationUsingKeyFrames>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ProgressHost"
                                                           Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                        Value="{x:Static Visibility.Visible}" />
                            </ObjectAnimationUsingKeyFrames>
                            <DoubleAnimation Storyboard.TargetName="ProgressHost"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="ProgressTranslate"
                                             Storyboard.TargetProperty="Y"
                                             From="8"
                                             To="0"
                                             Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid x:Name="CheckingHost"
                  Visibility="Collapsed"
                  Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="CheckingTranslate"
                                        Y="8" />
                </Grid.RenderTransform>
                <local:AutoUpdateCheckingView />
            </Grid>

            <Grid x:Name="AvailableHost"
                  Visibility="Collapsed"
                  Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="AvailableTranslate"
                                        Y="8" />
                </Grid.RenderTransform>
                <local:AutoUpdateAvailableView />
            </Grid>

            <Grid x:Name="ProgressHost"
                  Visibility="Collapsed"
                  Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ProgressTranslate"
                                        Y="8" />
                </Grid.RenderTransform>
                <local:AutoUpdateProgressView />
            </Grid>
        </Grid>
    </Border>
</local:AutoUpdateWindowBase>
