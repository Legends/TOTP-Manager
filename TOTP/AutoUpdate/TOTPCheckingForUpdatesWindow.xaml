<Window x:Class="TOTP.AutoUpdate.TOTPCheckingForUpdatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="20"
            CornerRadius="14"
            Background="#FF10213F"
            BorderBrush="#FF2F5E9E"
            BorderThickness="1.5">
        <StackPanel Width="280">
            <Border Height="74"
                    Margin="0,0,0,14"
                    CornerRadius="12"
                    ClipToBounds="True">
                <Grid>
                    <Image Source="/Assets/backgrounds/background-main.png"
                           Stretch="UniformToFill"
                           Opacity="0.48" />
                    <Rectangle Fill="#B010213F" />
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,14,0">
                        <Image Source="/Assets/Icons/app.ico"
                               Width="24"
                               Height="24"
                               Stretch="Uniform" />
                        <TextBlock Text="TOTP Update Check"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="17"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>
            <TextBlock Text="Checking for updates"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="Contacting the configured appcast feed and validating signatures."
                       Margin="0,8,0,0"
                       Foreground="#FFCBDAF3"
                       FontSize="12"
                       TextWrapping="Wrap" />
            <ProgressBar Height="8"
                         Margin="0,16,0,0"
                         IsIndeterminate="True"
                         Foreground="#FF7D7FF4"
                         Background="#FF193257"
                         BorderThickness="0" />
        </StackPanel>
    </Border>
</Window>
