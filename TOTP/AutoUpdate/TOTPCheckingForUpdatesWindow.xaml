<Window x:Class="TOTP.AutoUpdate.TOTPCheckingForUpdatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="20"
            CornerRadius="14"
            Background="{StaticResource Brush.SurfaceCard}"
            BorderBrush="{StaticResource Brush.BorderStrong}"
            BorderThickness="1.5">
        <StackPanel Width="280">
            <Border Height="74"
                    Margin="0,0,0,14"
                    CornerRadius="12"
                    ClipToBounds="True">
                <Grid>
                    <Image Source="/Assets/backgrounds/background-main.png"
                           Stretch="UniformToFill"
                           Opacity="0.48" />
                    <Rectangle Fill="{StaticResource Brush.SurfaceOverlay}" />
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,14,0">
                        <Image Source="/Assets/Icons/app.ico"
                               Width="24"
                               Height="24"
                               Stretch="Uniform" />
                        <TextBlock Text="TOTP Update Check"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource TextStyle.SectionHeader}" />
                    </StackPanel>
                </Grid>
            </Border>
            <TextBlock Text="Checking for updates"
                       Style="{StaticResource TextStyle.PageTitle}" />
            <TextBlock Text="Contacting the configured appcast feed and validating signatures."
                       Margin="0,8,0,0"
                       Style="{StaticResource TextStyle.Subheader}"
                       TextWrapping="Wrap" />
            <ProgressBar Height="8"
                         Margin="0,16,0,0"
                         IsIndeterminate="True"
                         Foreground="{StaticResource Brush.AccentPrimary}"
                         Background="{StaticResource Brush.SurfaceProgressTrack}"
                         BorderThickness="0" />
        </StackPanel>
    </Border>
</Window>
