<UserControl x:Class="TOTP.Views.PasswordUnlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:TOTP.Behaviors"
             xmlns:attachedProperties="clr-namespace:TOTP.AttachedProperties">
    <StackPanel>
        <PasswordBox attachedProperties:PasswordBoxHelper.BindPassword="True"
                     attachedProperties:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}" />
 
        <Button Content="Unlock"
                Command="{Binding UnlockCommand}"
                Height="32"
                Margin="0,8,0,0" />
    </StackPanel>
</UserControl>
