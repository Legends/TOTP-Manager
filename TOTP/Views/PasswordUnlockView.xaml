<UserControl x:Class="TOTP.Views.PasswordUnlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:TOTP.Behaviors">
    <StackPanel>
        <PasswordBox behaviors:PasswordBoxHelper.BindPassword="True"
                     behaviors:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}" />
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <PasswordBox Password="{Binding Password, Mode=TwoWay}" />
        <Button Content="Unlock"
                Command="{Binding UnlockCommand}"
                Height="32"
                Margin="0,8,0,0" />
    </StackPanel>
</UserControl>
