<Window x:Class="TOTP.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Width="360"
        Height="220"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Storyboard x:Key="LogoSpinStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LogoRotateTransform"
                             Storyboard.TargetProperty="Angle"
                             From="0"
                             To="360"
                             Duration="0:0:2.0" />
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="16"
            Background="#0F1A2D"
            BorderBrush="#2B4A7A"
            BorderThickness="1.2"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Grid Width="64" Height="64">
                    <Ellipse Stroke="#3D5A88"
                             StrokeThickness="4"
                             Opacity="0.35" />
                    <Image Width="42"
                           Height="42"
                           Source="/Assets/Icons/app.ico"
                           RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <RotateTransform x:Name="LogoRotateTransform" />
                        </Image.RenderTransform>
                        <Image.Triggers>
                            <EventTrigger RoutedEvent="Image.Loaded">
                                <BeginStoryboard Storyboard="{StaticResource LogoSpinStoryboard}" />
                            </EventTrigger>
                        </Image.Triggers>
                    </Image>
                </Grid>

                <TextBlock Margin="0,14,0,0"
                           Text="Starting TOTP Manager"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />

                <TextBlock Margin="0,6,0,0"
                           Text="Loading core services..."
                           Foreground="#B8C7DF"
                           FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <ProgressBar Grid.Row="1"
                         Height="6"
                         IsIndeterminate="True"
                         Foreground="#6EA8FE"
                         Background="#1A2E4E"
                         BorderThickness="0"
                         Margin="0,16,0,0" />
        </Grid>
    </Border>
</Window>

