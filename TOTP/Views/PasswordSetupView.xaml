<UserControl x:Class="TOTP.Views.PasswordSetupView"
             x:Name="ucPasswordSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TOTP.Views"
             xmlns:userControls="clr-namespace:TOTP.UserControls"
             xmlns:xaml="clr-namespace:TOTP.Xaml"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <StackPanel Margin="10,10,10,10">
        <Label Margin="0,10,0,10" Content="{xaml:Resx Key=ui_Setup_Password}"></Label>
        <TextBlock Text="{Binding Message}" 
                   TextWrapping="Wrap" 
                   Foreground="Red" 
                   Margin="2"/>

        <!--IsSecretVisible="{Binding IsSetup, Mode=OneWay}"-->
        <userControls:RevealableSecretBox  x:Name="PasswordBox" Margin="0,0,0,10"  AutoFocus="True"
                                           Secret="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           ToggleButtonStyle="{StaticResource IconToggleButtonStyle}"
                                           ToggleToolTip="{xaml:Resx Key=ui_btnShowHideSecret}" />

        <userControls:RevealableSecretBox x:Name="PasswordBoxConfirm" 
                                          Secret="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ToggleButtonStyle="{StaticResource IconToggleButtonStyle}"
                                          ToggleToolTip="{xaml:Resx Key=ui_btnShowHideSecret}" />

        <!-- SavePasswordCommand is defined in PasswordUnlockViewModel, PasswordSetupView automatically inherits its DataContext-->
        <Button Content="{xaml:Resx Key=ui_btnSave}"
                IsDefault="True"
                Command="{Binding SavePasswordCommand}" 
        Height="36"
                Margin="0,10,0,10"/>
    </StackPanel>
</UserControl>
