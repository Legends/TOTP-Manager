<syncfusion:ChromelessWindow x:Class="TOTP.Views.ExportPasswordPromptWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:viewModels="clr-namespace:TOTP.ViewModels"
                             xmlns:userControls="clr-namespace:TOTP.UserControls"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             d:DataContext="{d:DesignInstance Type=viewModels:ExportPasswordPromptViewModel}"
                             mc:Ignorable="d"
                             Title="{Binding Title}"
                             WindowStyle="None"
                             TitleBarHeight="0"
                             ShowTitle="False"
                             ShowIcon="False"
                             ShowMinimizeButton="False"
                             ShowMaximizeButton="False"
                             SizeToContent="WidthAndHeight"
                             WindowStartupLocation="Manual"
                             ResizeMode="NoResize"
                             ShowInTaskbar="False"
                             AllowsTransparency="True"
                             Background="Transparent"
                             Opacity="0">
    <syncfusion:ChromelessWindow.Resources>
        <LinearGradientBrush x:Key="PromptBorderBrush"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#40FFFFFF"
                          Offset="0" />
            <GradientStop Color="#26FFFFFF"
                          Offset="0.45" />
            <GradientStop Color="#14FFFFFF"
                          Offset="1" />
        </LinearGradientBrush>
    </syncfusion:ChromelessWindow.Resources>

    <Border Margin="8"
            Padding="12"
            CornerRadius="8"
            BorderBrush="{StaticResource PromptBorderBrush}"
            BorderThickness="2"
            Background="#FF192B52">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,10">
                <TextBlock Text="{Binding Title}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,4" />
                <TextBlock Text="{xaml:Resx Key=ui_ExportPwd_PromptMessage}"
                           MaxWidth="300"
                           TextWrapping="Wrap"
                           Foreground="#FFD6DEEF"
                           FontSize="12" />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <Border BorderBrush="#404D678F"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <RadioButton Content="{xaml:Resx Key=ui_ExportPwd_UseMasterOption}"
                                     IsChecked="{Binding UseMasterPassword, Mode=TwoWay}"
                                     Foreground="White"
                                     Margin="0,0,0,6" />
                        <TextBlock Text="{xaml:Resx Key=ui_ExportPwd_MasterPasswordLabel}"
                                   Foreground="White"
                                   FontSize="11"
                                   Margin="18,0,0,4"
                                   Visibility="{Binding UseMasterPassword, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <userControls:RevealableSecretBox Margin="18,0,0,0"
                                                          AutoFocus="True"
                                                          FieldHeight="28"
                                                          Secret="{Binding MasterPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          ToggleButtonStyle="{StaticResource IconToggleButtonStyle}"
                                                          ToggleToolTip="{xaml:Resx Key=ui_btnShowHideSecret}"
                                                          Visibility="{Binding UseMasterPassword, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <Border BorderBrush="#404D678F"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <StackPanel>
                        <RadioButton Content="{xaml:Resx Key=ui_ExportPwd_UseCustomOption}"
                                     IsChecked="{Binding UseCustomPassword, Mode=TwoWay}"
                                     Foreground="White"
                                     Margin="0,0,0,6" />
                        <StackPanel Margin="18,0,0,0"
                                    Visibility="{Binding UseCustomPassword, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{xaml:Resx Key=ui_ExportPwd_CustomPasswordLabel}"
                                       Foreground="White"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <userControls:RevealableSecretBox FieldHeight="28"
                                                              Secret="{Binding CustomPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ToggleButtonStyle="{StaticResource IconToggleButtonStyle}"
                                                              ToggleToolTip="{xaml:Resx Key=ui_btnShowHideSecret}" />
                            <TextBlock Text="{xaml:Resx Key=ui_ExportPwd_ConfirmCustomPasswordLabel}"
                                       Foreground="White"
                                       FontSize="11"
                                       Margin="0,8,0,4" />
                            <userControls:RevealableSecretBox FieldHeight="28"
                                                              Secret="{Binding ConfirmCustomPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ToggleButtonStyle="{StaticResource IconToggleButtonStyle}"
                                                              ToggleToolTip="{xaml:Resx Key=ui_btnShowHideSecret}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Text="{Binding ErrorMessage}"
                       Style="{StaticResource InlineErrorTextStyle}"
                       Margin="0,8,0,0"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverterCollapsed}}" />

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="{xaml:Resx Key=ui_btnCancel}"
                        IsCancel="True"
                        Width="86"
                        Margin="0,0,6,0" />
                <Button Content="{xaml:Resx Key=ui_btnOK}"
                        IsDefault="True"
                        Width="86"
                        Command="{Binding ConfirmCommand}" />
            </StackPanel>
        </Grid>
    </Border>
</syncfusion:ChromelessWindow>
