<syncfusion:ChromelessWindow x:Class="TOTP.Views.PasswordPromptWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:viewModels="clr-namespace:TOTP.ViewModels"
                             xmlns:userControls="clr-namespace:TOTP.UserControls"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             d:DataContext="{d:DesignInstance Type=viewModels:PasswordPromptViewModel}"
                             mc:Ignorable="d"
                             Title="{Binding Title}"
                             WindowStyle="None"
                             TitleBarHeight="0"
                             ShowTitle="False"
                             ShowIcon="False"
                             ShowMinimizeButton="False"
                             ShowMaximizeButton="False"
                             SizeToContent="WidthAndHeight"
                             WindowStartupLocation="Manual"
                             ResizeMode="NoResize"
                             ShowInTaskbar="False"
                             AllowsTransparency="True"
                             Background="Transparent"
                             Loaded="OnLoaded"
                             ContentRendered="OnContentRendered">
    <syncfusion:ChromelessWindow.Resources>
        <LinearGradientBrush x:Key="PromptBorderBrush"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#40FFFFFF"
                          Offset="0" />
            <GradientStop Color="#26FFFFFF"
                          Offset="0.45" />
            <GradientStop Color="#14FFFFFF"
                          Offset="1" />
        </LinearGradientBrush>
    </syncfusion:ChromelessWindow.Resources>

    <Border Margin="8"
            Padding="12"
            CornerRadius="8"
            BorderBrush="{StaticResource PromptBorderBrush}"
            BorderThickness="5"
            Background="#FF192B52">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,8">
                <TextBlock Text="{Binding Title}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,4" />
                <TextBlock Text="{Binding Message}"
                           MaxWidth="280"
                           TextWrapping="Wrap"
                           Foreground="#FFD6DEEF"
                           FontSize="12" />
            </StackPanel>

            <userControls:RevealableSecretBox Grid.Row="1"
                                              AutoFocus="True"
                                              FieldHeight="28"
                                              Secret="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ToggleButtonStyle="{StaticResource IconToggleButtonStyle}"
                                              ToggleToolTip="{xaml:Resx Key=ui_btnShowHideSecret}" />

            <TextBlock Grid.Row="2"
                       Text="{Binding ErrorMessage}"
                       Foreground="#FFFF7E7E"
                       FontSize="11"
                       Margin="0,6,0,0"
                       MaxWidth="280"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="{xaml:Resx Key=ui_btnCancel}"
                        IsCancel="True"
                        Width="78"
                        Margin="0,0,6,0" />
                <Button Content="{xaml:Resx Key=ui_btnOK}"
                        IsDefault="True"
                        Width="78"
                        Click="OkButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</syncfusion:ChromelessWindow>
