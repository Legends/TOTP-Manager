<syncfusion:ChromelessWindow x:Class="TOTP.Views.MainWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:sfGrid="clr-namespace:Syncfusion.UI.Xaml.Grid;assembly=Syncfusion.SfGrid.WPF"
                             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                             xmlns:behaviors="clr-namespace:TOTP.Behaviors"
                             xmlns:converters="clr-namespace:TOTP.Converters"
                             xmlns:props="clr-namespace:TOTP.AttachedProperties"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                             xmlns:resx="clr-namespace:TOTP.Resources"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             xmlns:progress="clr-namespace:Syncfusion.UI.Xaml.ProgressBar;assembly=Syncfusion.SfProgressBar.WPF"
                             xmlns:Microsoft_Windows_Themes="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero"
                             xmlns:local="clr-namespace:Syncfusion.Windows.Shared;assembly=Syncfusion.Shared.WPF"
                             xmlns:viewModels="clr-namespace:TOTP.ViewModels"
                             xmlns:views="clr-namespace:TOTP.Views"
                             xmlns:userControls="clr-namespace:TOTP.UserControls"
                             mc:Ignorable="d"
                             Width="300"
                             SizeToContent="Height"
                             Icon="/Assets/Icons/app.ico"
                             Title="TOTP Manager"
                             TitleBarBackground="#7D7FF4"
                             TitleBarForeground="{DynamicResource Brush.Foreground}">

    <syncfusion:ChromelessWindow.Resources>
        <BounceEase x:Key="BounceEase"
                    Bounces="1"
                    Bounciness="100"
                    EasingMode="EaseOut" />
        <converters:SecretMaskConverter x:Key="SecretMaskConverter" />
        <converters:ProgressValueToBrushConverter x:Key="ProgressValueToBrushConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverterCollapsed"
                                                Collapse="True" />

        <DataTemplate DataType="{x:Type viewModels:UnlockViewModel}">
            <views:UnlockView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:HelloUnlockViewModel}">
            <views:HelloUnlockView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PasswordUnlockViewModel}">
            <views:PasswordUnlockView AutoFocus="True"/>
        </DataTemplate>
    </syncfusion:ChromelessWindow.Resources>

    <!-- Root overlay grid -->
    <Grid>

        <!-- ===== DataGrid & Toolbar Container ===== -->
        <StackPanel Orientation="Vertical"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Visibility="{Binding IsUnlocked, Converter={StaticResource BoolToVisibilityConverterCollapsed}}">

            <Grid Height="30"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- left side -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Grid.Column="0">

                    <!-- Scan Button -->
                    <Button ToolTip="{xaml:Resx Key=ui_btnScan}"
                            Margin="5,5,0,0"
                            Padding="5,5"
                            Command="{Binding ScanQrAndAddCommand}">
                        <svgc:SvgViewbox Source="/Assets/Icons/Camera-48x48.svg"
                                         Height="15"
                                         Stretch="Uniform" />
                    </Button>

                    <!-- Add Button -->
                    <Button ToolTip="{xaml:Resx Key=tooltip_AddNew}"
                            Margin="5,5,0,0"
                            Padding="5,5"
                            Command="{Binding OpenFlyoutAddModeCommand}">
                        <svgc:SvgViewbox Source="/Assets/Icons/plus-24x24.svg"
                                         Height="15"
                                         Stretch="Uniform" />
                    </Button>

                    <!-- Search Button -->
                    <Button Command="{Binding ToggleSearchBoxCommand}"
                            ToolTip="{xaml:Resx Key=ui_btnSearch}"
                            Margin="5,5,5,0"
                            Padding="5,5">
                        <svgc:SvgViewbox Source="/Assets/Icons/find-24x24.svg"
                                         Height="15"
                                         Stretch="Uniform" />
                    </Button>

                    <!-- Search Textbox -->
                    <syncfusion:SfTextBoxExt Width="80"
                                             Height="30"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Stretch"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="{xaml:Resx Key=ui_label_Search_Dots}"
                                             props:FocusExtension.IsFocused="{Binding IsSearchFocused}"
                                             Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}"
                                             Padding="0,0,20,0"
                                             Margin="10,0,0,0" >
                        <syncfusion:SfTextBoxExt.InputBindings>
                            <KeyBinding Key="Escape"
                                        Command="{Binding ClearSearchTextCommand}" />
                        </syncfusion:SfTextBoxExt.InputBindings>
                    </syncfusion:SfTextBoxExt>

                    <!-- Search-Clear-Button -->
                    <Button Content="×"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Margin="-20,0,0,0"
                            Command="{Binding ClearSearchCommand}"
                            Visibility="{Binding IsSearchTextNotEmpty, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />
                </StackPanel>

                <!-- right side: language selector + Options Gear Icon-->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Grid.Column="1">

                    <syncfusion:ComboBoxAdv Grid.Column="1"
                                            IsEnabled="{Binding IsGridEditing, Converter={StaticResource InverseBooleanConverter}}"
                                            ItemsSource="{Binding SupportedCultures}"
                                            SelectedItem="{Binding SelectedCulture, Mode=TwoWay}"
                                            Width="50"
                                            VerticalAlignment="Center"
                                            Margin="2"
                                            AllowMultiSelect="False">
                        <syncfusion:ComboBoxAdv.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding IconPath}"
                                           Width="20"
                                           Height="25"
                                           Margin="0,0,5,0" />
                                </StackPanel>
                            </DataTemplate>
                        </syncfusion:ComboBoxAdv.ItemTemplate>
                    </syncfusion:ComboBoxAdv>

                    <!-- Gear-Options -->
                    <syncfusion:MenuAdv Height="25"
                                        Margin="2,5,5,0"
                                        Padding="0"
                                        Width="23"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        ExpandMode="ExpandOnClick">

                        <syncfusion:MenuItemAdv Header="Settings"
                                                Width="32"
                                                Padding="0"
                                                ToolTip="{xaml:Resx Key=ui_Options}"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center">
                            <syncfusion:MenuItemAdv.Icon>
                                <svgc:SvgViewbox Source="/Assets/Icons/Gear--03WF-48x48.svg"
                                                 Height="15"
                                                 Stretch="Uniform" />
                            </syncfusion:MenuItemAdv.Icon>

                            <syncfusion:MenuItemAdv Header="Settings"
                                                    Command="{Binding OpenSettingsCommand}" />

                            <syncfusion:MenuItemAdv Header="Export"
                                                    ToolTip="{Binding ExportToolTip}"
                                                    Command="{Binding ExportSecretsCommand}" />

                            <syncfusion:MenuItemAdv Header="WPF">
                                <syncfusion:MenuItemAdv Header="Tools" ToolTip="{xaml:Resx Key=ui_btnCancel}" />
                                <syncfusion:MenuItemAdv Header="Chart" />
                                <syncfusion:MenuItemAdv Header="Grid" />
                                <syncfusion:MenuItemAdv Header="Edit" />
                            </syncfusion:MenuItemAdv>

                            <syncfusion:MenuItemAdv Header="Reporting" />
                        </syncfusion:MenuItemAdv>
                    </syncfusion:MenuAdv>
                </StackPanel>
            </Grid>

            <!--  === ACCOUNTS SFDATAGRID CONTAINER === -->
            <Grid Margin="10,20,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- =====  ACCOUNTS GRID   ===== -->
                <syncfusion:SfDataGrid x:Name="SecretsGrid"
                                       ItemsSource="{Binding AllSecrets}"
                                       CellStyle="{StaticResource {x:Type sfGrid:GridCell}}"
                                       Grid.Row="0"
                                       AllowSorting="True"
                                       AllowEditing="True"
                                       AllowDeleting="True"
                                       GridValidationMode="InView"
                                       AutoGenerateColumns="False"
                                       CanMaintainScrollPosition="True"
                                       EditTrigger="OnDoubleTap"
                                       SelectionMode="Single"
                                       SelectionUnit="Row"
                                       NavigationMode="Cell"
                                       LiveDataUpdateMode="AllowDataShaping"
                                       MaxHeight="200"
                                       Margin="0,0,0,20"
                                       BorderThickness="0"
                                       RowSelectionBrush="#1D3366"
                                       SelectionForegroundBrush="#87CE3E"
                                       CurrentCellBorderBrush="Transparent"
                                       CurrentCellBorderThickness="0"
                                       HorizontalAlignment="Stretch"
                                       ColumnSizer="Star">

                    <syncfusion:SfDataGrid.SortColumnDescriptions>
                        <syncfusion:SortColumnDescription ColumnName="Platform"
                                                          SortDirection="Ascending" />
                    </syncfusion:SfDataGrid.SortColumnDescriptions>

                    <i:Interaction.Behaviors>
                        <behaviors:ScrollOnNewOrUpdatedItemBehavior />
                        <behaviors:DataGridValidationBehavior />
                        <behaviors:SfDataGridEditingBehavior  IsEditing="{Binding IsGridEditing, Mode=TwoWay}"
                                                              BeginEditCommand="{Binding BeginEditCommand}"
                                                              EndEditCommand="{Binding EndEditCommand}"
                                                              DoubleClickCommand="{Binding DoubleClickCommand}" />
                        <behaviors:SfDataGridContextMenuBehavior />
                        <behaviors:RowClickBehavior SelectionChangedCommand="{Binding RowSelectionChangedCommand}" />
                    </i:Interaction.Behaviors>

                    <syncfusion:SfDataGrid.Resources>
                        <Style TargetType="syncfusion:GridHeaderCellControl">
                            <Setter Property="Background" Value="#269797" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </syncfusion:SfDataGrid.Resources>

                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridTextColumn HeaderText="{xaml:Resx Key=ui_Header_Platform}"
                                                   MappingName="Platform">
                            <syncfusion:GridTextColumn.CellStyle>
                                <Style TargetType="sfGrid:GridCell"
                                       BasedOn="{StaticResource {x:Type sfGrid:GridCell}}">
                                    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                        To="#66FFD54F"
                                                                        Duration="0:0:1" />
                                                        <ColorAnimation Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                                        To="#87CE3E"
                                                                        Duration="0:0:1" />
                                                        <ColorAnimation BeginTime="0:0:1"
                                                                        Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                        To="#00FFFFFF"
                                                                        Duration="0:0:1" />
                                                        <ColorAnimation BeginTime="0:0:1"
                                                                        Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                                        To="#97B0DF"
                                                                        Duration="0:0:1" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </syncfusion:GridTextColumn.CellStyle>
                        </syncfusion:GridTextColumn>
                    </syncfusion:SfDataGrid.Columns>

                    <syncfusion:SfDataGrid.RecordContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{Binding DataGrid.DataContext.EditLabel}"
                                      Foreground="{DynamicResource Brush.Foreground}"
                                      Command="{Binding DataGrid.DataContext.OpenFlyoutEditModeCommand}"
                                      CommandParameter="{Binding Record}">
                                <MenuItem.Icon>
                                    <svgc:SvgViewbox Width="11"
                                                     Height="11"
                                                     Source="/Assets/Icons/Edit-48x48.svg" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator Background="#1D3366" />

                            <MenuItem Header="{Binding DataGrid.DataContext.DeleteLabel}"
                                      Foreground="{DynamicResource Brush.Foreground}"
                                      Command="{Binding DataGrid.DataContext.DeleteSecretCommand}"
                                      CommandParameter="{Binding Record}">
                                <MenuItem.Icon>
                                    <svgc:SvgViewbox Width="11"
                                                     Height="11"
                                                     Source="/Assets/Icons/delete-24x24.svg" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </syncfusion:SfDataGrid.RecordContextMenu>

                </syncfusion:SfDataGrid>

                <!--  TOTP-CODE, PLATFORM-NAME, PROGRESS, GENERATE-QR-CODE-LINK CONTAINER   -->
                <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center">
                    <Label x:Name="lblSelectedPlatformName"
                           Content="{Binding SelectedSecret.Platform }"
                           VerticalContentAlignment="Center"
                           HorizontalContentAlignment="Center"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="15"
                           Height="{Binding CodeLabelHeight}" />

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Center">

                        <Viewbox x:Name="vbCopySymbol" Width="10" Margin="0,0,0,2">
                            <svgc:SvgViewbox Source="/Assets/Icons/Copy-48x48.svg"
                                             Stretch="Uniform"
                                             Style="{StaticResource CopySymbolStyle}"
                                             Visibility="{Binding ShowCopySymbol,
                                                Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Viewbox>

                        <Label x:Name="lblCode"
                               Cursor="Hand"
                               Content="{Binding TotpCode }"
                               HorizontalContentAlignment="Center"
                               Height="{Binding CodeLabelHeight}"
                               FontWeight="Bold"
                               Foreground="#97B0DF"
                               FontSize="24"
                               HorizontalAlignment="Center"
                               Margin="0,0">
                            <Label.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding CopyCodeCommand}" />
                            </Label.InputBindings>
                            <Label.RenderTransform>
                                <TranslateTransform />
                            </Label.RenderTransform>
                            <Label.Style>
                                <Style TargetType="Label">
                                    <Setter Property="Opacity" Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCodeLabelVisible}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                                         From="0"
                                                                         To="-10"
                                                                         Duration="0:0:0.2"
                                                                         AutoReverse="True"
                                                                         EasingFunction="{StaticResource BounceEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Label.Style>
                        </Label>

                        <Viewbox x:Name="vbProgressPieChart" Height="25">
                            <syncfusion:SfCircularProgressBar x:Name="ProgressBar"
                                                              Visibility="{Binding IsProgressPieChartVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                              Minimum="0"
                                                              IndicatorOuterRadius="0.90"
                                                              IndicatorInnerRadius="0.70"
                                                              TrackOuterRadius="0.90"
                                                              TrackInnerRadius="0.70"
                                                              Margin="10,0,0,0"
                                                              Maximum="{Binding PeriodSeconds}"
                                                              Progress="{Binding ElapsedSeconds}"
                                                              IsIndeterminate="False"
                                                              SegmentCount="1"
                                                              ProgressColor="#152549"
                                                              TrackColor="{Binding Progress, ElementName=ProgressBar, Converter={StaticResource ProgressValueToBrushConverter}}">
                                <syncfusion:SfCircularProgressBar.ProgressContent>
                                    <TextBlock Text="{Binding RemainingSeconds}"
                                               FontSize="40"
                                               Padding="0"
                                               Margin="-5,0,0,0"
                                               FontWeight="Bold"
                                               Foreground="{Binding Progress, ElementName=ProgressBar, Converter={StaticResource ProgressValueToBrushConverter}}"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center" />
                                </syncfusion:SfCircularProgressBar.ProgressContent>
                            </syncfusion:SfCircularProgressBar>
                        </Viewbox>
                    </StackPanel>
                </StackPanel>

                <!--QR CODE CONTAINER-->
                <StackPanel Grid.Row="2">
                    <TextBlock HorizontalAlignment="Center"
                               Margin="0,10,0,8"
                               Visibility="{Binding ShowGenerateQrCodeLink, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Hyperlink Command="{Binding GenerateQrCommand}">
                            <TextBlock Text="{xaml:Resx Key=ui_GenerateQR_Code}"/>
                        </Hyperlink>
                    </TextBlock>

                    <Image ToolTip="{xaml:Resx Key=tooltip_AuthenticatorAppScan}"
                           Margin="0,10,0,10"
                           Source="{Binding QrCodeImage}"
                           Width="160"
                           Height="Auto"
                           Visibility="{Binding IsQrVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- ========================================================= -->
        <!-- FLYOUT 1: ADD / EDIT / UPDATE (IsEditOpen)                 -->
        <!-- ========================================================= -->

        <!-- Dim background + click closes -->
        <Border Style="{StaticResource FlyoutOverlayStyle}"
                Panel.ZIndex="100"
                Visibility="{Binding IsEditOpen, Converter={StaticResource BoolToVisibilityConverterCollapsed}}"
                IsHitTestVisible="{Binding IsEditOpen}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CancelFlyoutCommand}" />
            </Border.InputBindings>
        </Border>


        <!-- Flyout container (slides via FlyoutHostStyle) -->
        <Grid Width="300"
              HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              Panel.ZIndex="101"
              Style="{StaticResource FlyoutHostStyle}"
              FocusManager.IsFocusScope="True"
              props:Flyout.IsOpen="{Binding IsEditOpen, Mode=TwoWay}"
              props:Flyout.ClosedX="300"
              props:Flyout.CloseOnEsc="True">

            <!-- Keep your command-based ESC as well (fine) -->
            <Grid.InputBindings>
                <KeyBinding Key="Escape" Command="{Binding CancelFlyoutCommand}" />
            </Grid.InputBindings>

            <Border Background="#152549"
                    Padding="16"
                    BorderBrush="#394B74"
                    BorderThickness="1">
                <StackPanel Margin="0,10,0,10">
                    <!-- Header -->
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="{Binding EditPanelTitle}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="16" />
                        <Button Content="✕"
                                Foreground="White"
                                Width="26"
                                Height="26"
                                Command="{Binding CancelFlyoutCommand}"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right" />
                    </DockPanel>

                    <!-- Platform -->
                    <TextBlock Text="{xaml:Resx Key=ui_Header_Platform}"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,6,0,2" />

                    <TextBox x:Name="PlatformBox"
                             Text="{Binding CurrentSecretBeingEditedOrAdded.Platform, UpdateSourceTrigger=PropertyChanged}"
                             Height="30"
                             props:FocusExtension.IsFocused="{Binding IsEditPlatformFocused}" />

                    <TextBlock Text="{Binding CurrentSecretBeingEditedOrAdded.PlatformError}"
                               Style="{StaticResource InlineErrorTextStyle}"
                               Visibility="{Binding CurrentSecretBeingEditedOrAdded.PlatformError,
                                    Converter={StaticResource StringToVisibilityConverterCollapsed}}" />

                    <!-- Secret -->
                    <TextBlock Text="{xaml:Resx Key=ui_Header_Secret}"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,10,0,-4" />

                    <userControls:RevealableSecretBox AutoFocus="False"
                                                     Secret="{Binding CurrentSecretBeingEditedOrAdded.Secret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsSecretVisible="{Binding IsSecretVisible, Mode=TwoWay}"
                                                     ToggleButtonStyle="{StaticResource IconToggleButtonStyle}"
                                                     ToggleToolTip="{xaml:Resx Key=ui_btnShowHideSecret}" />

                    <TextBlock Text="{Binding CurrentSecretBeingEditedOrAdded.SecretError}"
                               Style="{StaticResource InlineErrorTextStyle}"
                               Visibility="{Binding CurrentSecretBeingEditedOrAdded.SecretError,
                                    Converter={StaticResource StringToVisibilityConverterCollapsed}}" />

                    <!-- Account -->
                    <TextBlock Text="{xaml:Resx Key=ui_Header_Account}"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,10,0,2" />

                    <TextBox Text="{Binding CurrentSecretBeingEditedOrAdded.Account, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />

                    <TextBlock Text="{Binding CurrentSecretBeingEditedOrAdded.AccountError}"
                               Style="{StaticResource InlineErrorTextStyle}"
                               Visibility="{Binding CurrentSecretBeingEditedOrAdded.AccountError,
                                    Converter={StaticResource StringToVisibilityConverterCollapsed}}" />

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Right">
                        <Button Content="{Binding SaveButtonLabel}"
                                IsDefault="{Binding IsEditOpen}"
                                FontWeight="Bold"
                                Foreground="White"
                                Command="{Binding SaveEditFlyoutAsyncCommand}"
                                Margin="0,0,8,0"
                                Padding="14,6" />
                        <Button Content="{Binding CancelButtonLabel}"
                                Foreground="White"
                                FontWeight="Bold"
                                Command="{Binding CancelFlyoutCommand}"
                                Padding="14,6" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ========================================================= -->
        <!-- FLYOUT 2: SETTINGS (IsSettingsOpen)                        -->
        <!-- ========================================================= -->

        <!-- Dim background + click closes -->
        <Border Style="{StaticResource FlyoutOverlayStyle}"
                Panel.ZIndex="200"
                Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibilityConverterCollapsed}}"
                IsHitTestVisible="{Binding IsSettingsOpen}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseSettingsCommand}" />
            </Border.InputBindings>
        </Border>


        <!-- Settings flyout (now ALSO uses FlyoutHostStyle + slide animation) -->
        <Grid Width="320"
              HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              Panel.ZIndex="201"
              Style="{StaticResource FlyoutHostStyle}"
              FocusManager.IsFocusScope="True"
              props:Flyout.IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}"
              props:Flyout.ClosedX="320"
              props:Flyout.CloseOnEsc="True">

            <Grid.InputBindings>
                <KeyBinding Key="Escape" Command="{Binding CloseSettingsCommand}" />
            </Grid.InputBindings>

            <Border Background="#152549"
                    Padding="16"
                    BorderBrush="#394B74"
                    BorderThickness="1">
                <views:SettingsView DataContext="{Binding Settings}" />
            </Border>
        </Grid>

        <!-- ========================================================= -->
        <!-- UnlockView overlay                                         -->
        <!-- ========================================================= -->
        <Grid Background="#CC0C1C33"
              Panel.ZIndex="1000"
              Visibility="{Binding IsUnlocked, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <ContentControl Content="{Binding Unlock}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Grid>

    </Grid>
</syncfusion:ChromelessWindow>
