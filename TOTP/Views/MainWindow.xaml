<syncfusion:ChromelessWindow x:Class="TOTP.Views.MainWindow"
                             x:Name="mainWin"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:sys="clr-namespace:System;assembly=mscorlib"
                             xmlns:sfGrid="clr-namespace:Syncfusion.UI.Xaml.Grid;assembly=Syncfusion.SfGrid.WPF"
                             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                             xmlns:behaviors="clr-namespace:TOTP.Infrastructure.Behaviors"
                             xmlns:converters="clr-namespace:TOTP.Infrastructure.Converters"
                             xmlns:props="clr-namespace:TOTP.Infrastructure.AttachedProperties"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             syncfusionskin:SkinManagerHelper.ScrollBarMode="Default"
                             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                             xmlns:resx="clr-namespace:TOTP.Resources"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             xmlns:progress="clr-namespace:Syncfusion.UI.Xaml.ProgressBar;assembly=Syncfusion.SfProgressBar.WPF"
                             xmlns:Microsoft_Windows_Themes="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero"
                             xmlns:local="clr-namespace:Syncfusion.Windows.Shared;assembly=Syncfusion.Shared.WPF"
                             xmlns:viewModels="clr-namespace:TOTP.ViewModels"
                             xmlns:views="clr-namespace:TOTP.Views"
                             xmlns:userControls="clr-namespace:TOTP.UserControls"
                             d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
                             mc:Ignorable="d"
                             Width="300"
                             SizeToContent="Height"
                             Icon="/Assets/Icons/app.ico"
                             Title="{xaml:Resx Key= ui_Window_Title_TOTP_Manager}"
                             TitleBarBackground="#7D7FF4"
                             TitleBarForeground="{DynamicResource Brush.Foreground}">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseSettingsViewCommand}" />
        <KeyBinding Modifiers="Control" 
                    Key="F" 
                    Command="{Binding ToggleSearchBoxCommand}" />
    </Window.InputBindings>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="StateChanged">
            <i:InvokeCommandAction Command="{Binding SessionController.WindowStateChangedCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Closed">
            <i:InvokeCommandAction Command="{Binding SessionController.DetachWindowCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <syncfusion:ChromelessWindow.Resources>

        <BounceEase x:Key="BounceEase"
                    Bounces="1"
                    Bounciness="100"
                    EasingMode="EaseOut" />


        <DataTemplate DataType="{x:Type viewModels:UnlockViewModel}">
            <views:UnlockView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:HelloUnlockViewModel}">
            <views:HelloUnlockView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PasswordUnlockViewModel}">
            <views:PasswordUnlockView AutoFocus="True"/>
        </DataTemplate>


    </syncfusion:ChromelessWindow.Resources>

    <!-- We wrap the existing content in a Grid so we can overlay the flyout -->
    <Grid>
        <!-- =====  MAIN VIEW  ===== -->
        <StackPanel Orientation="Vertical"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Visibility="{Binding IsUnlocked, Converter={StaticResource BoolToVisibilityConverterCollapsed}}">

            <!--TOOLBAR - SCAN - ADD NEW ACCOUNT - LANGUAGE SELECTOR - OPTIONS MENU-->
            <Grid Height="30"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- left side SCAN / ADD / SEARCH -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Grid.Column="0">

                    <!-- Scan Button -->
                    <Button ToolTip="{xaml:Resx Key=ui_btnScan}"
                            Margin="5,5,0,0"
                            Padding="5,5"
                            Command="{Binding ScanQrAndAddCommand}">
                        <svgc:SvgViewbox Source="/Assets/Icons/Camera-48x48.svg"
                                         Height="15"
                                         Stretch="Uniform" />
                    </Button>

                    <!-- Add Button -->
                    <Button ToolTip="{xaml:Resx Key=tooltip_AddNew}"
                            Margin="5,5,0,0"
                            Padding="5,5"
                            Command="{Binding OpenFlyoutAddModeCommand}">
                        <svgc:SvgViewbox Source="/Assets/Icons/plus-24x24.svg"
                                         Height="15"
                                         Stretch="Uniform" />
                    </Button>

                    <!-- Search Button -->
                    <Button Command="{Binding ToggleSearchBoxCommand}"
                            ToolTip="{xaml:Resx Key=ui_btnSearch}"
                            Margin="5,5,5,0"
                            Padding="5,5">
                        <svgc:SvgViewbox Source="/Assets/Icons/find-24x24.svg"
                                         Height="15"
                                         Stretch="Uniform" />
                    </Button>

                    <!-- Search Textbox -->
                    <syncfusion:SfTextBoxExt Width="80"
                                             Height="30"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Stretch"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="{xaml:Resx Key=ui_label_Search_Dots}"
                                             props:FocusExtension.IsFocused="{Binding IsSearchFocused}"
                                             Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}"
                                             Padding="0,0,20,0"
                                             Margin="10,0,0,0" >
                        <syncfusion:SfTextBoxExt.InputBindings>
                            <KeyBinding
                                Key="Escape"
                                Command="{Binding ClearSearchCommand}" />
                        </syncfusion:SfTextBoxExt.InputBindings>

                    </syncfusion:SfTextBoxExt>

                    <!-- Search-Clear-Button -->
                    <Button Content="×"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Margin="-20,0,0,0"
                            Command="{Binding ClearSearchCommand}"
                            Visibility="{Binding IsSearchTextNotEmpty, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />
                </StackPanel>

                <!-- right side: language selector + Options MENU - Gear Icon-->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Grid.Column="1">
                    <!--LANGUAGE SELECTOR-->
                    <syncfusion:ComboBoxAdv Grid.Column="1"
                                            IsEnabled="{Binding IsGridEditing, Converter={StaticResource InverseBooleanConverter}}"
                                            ItemsSource="{Binding SupportedCultures}"
                                            SelectedItem="{Binding SelectedCulture, Mode=TwoWay}"
                                            Width="50"
                                            VerticalAlignment="Center"
                                            Margin="2"
                                            AllowMultiSelect="False">
                        <syncfusion:ComboBoxAdv.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding IconPath}"
                                           Width="20"
                                           Height="25"
                                           Margin="0,0,5,0" />
                                </StackPanel>
                            </DataTemplate>
                        </syncfusion:ComboBoxAdv.ItemTemplate>
                    </syncfusion:ComboBoxAdv>

                    <!-- MENU Gear-Options -->
                    <syncfusion:MenuAdv Height="25"
                                        Margin="2,5,5,0"
                                        Padding="0"
                                        Width="23"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        ExpandMode="ExpandOnClick">

                        <!-- Main entry point: Gear icon -->
                        <syncfusion:MenuItemAdv Header="xaml:Resx Key=ui_Settings_Title}"
                                                
                                                Command="{Binding OpenSettingsCommand}"
                                                Width="32" 
                                                Padding="0"
                                                ToolTip="{xaml:Resx Key=ui_Settings_Title}"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center">


                            <syncfusion:MenuItemAdv.Icon>
                                <svgc:SvgViewbox Source="/Assets/Icons/Gear--03WF-48x48.svg"
                                                 Height="15"
                                                 Stretch="Uniform" />
                            </syncfusion:MenuItemAdv.Icon>
                            <!--SETTINGS MENU ENTRY-->
                            <!--<syncfusion:MenuItemAdv Header="{xaml:Resx Key=ui_Settings_Title}"
                                                    Command="{Binding OpenSettingsCommand}" />

                            <syncfusion:MenuItemAdv Header="Export"
                                                    ToolTip="{Binding ExportToolTip}"
                                                    Command="{Binding ExportSecretsCommand}" />

                            -->
                            <!-- Your menu opens vertically under the gear -->
                            <!--
                            <syncfusion:MenuItemAdv Header="WPF">
                                <syncfusion:MenuItemAdv Header="Tools" ToolTip="{xaml:Resx Key=ui_btnCancel}" />
                                <syncfusion:MenuItemAdv Header="Chart" />
                                <syncfusion:MenuItemAdv Header="Grid" />
                                <syncfusion:MenuItemAdv Header="Edit" />
                            </syncfusion:MenuItemAdv>


                            <syncfusion:MenuItemAdv Header="Reporting" />-->

                            <!-- Optional: actual settings command as a clickable leaf item -->

                        </syncfusion:MenuItemAdv>

                    </syncfusion:MenuAdv>


                </StackPanel>

            </Grid>

            <!--  === ACCOUNTS SFDATAGRID CONTAINER === -->
            <Grid Margin="10,20,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- =====  ACCOUNTS GRID   ===== -->
                <!--SelectedItem="SelectedSecret"-->
                <!--SelectionChanged="DataGrid_SelectionChanged"
                ItemsSource="{Binding FilteredSecrets}"
                -->
                <syncfusion:SfDataGrid x:Name="AccountsGrid"
                                       ItemsSource="{Binding AllOtps}"
                                       CellStyle="{StaticResource {x:Type sfGrid:GridCell}}"
                                       Grid.Row="0"
                                       AllowSorting="True"
                                       AllowEditing="True"
                                       AllowDeleting="True"
                                       GridValidationMode="InView"
                                       AutoGenerateColumns="False"
                                       CanMaintainScrollPosition="True"
                                       EditTrigger="OnDoubleTap"
                                       SelectionMode="Single"
                                       SelectionUnit="Row"
                                       NavigationMode="Cell"
                                       LiveDataUpdateMode="AllowDataShaping"
                                       MaxHeight="200"
                                       Margin="0,0,0,20"
                                       BorderThickness="0"
                                       RowSelectionBrush="#1D3366"
                                       SelectionForegroundBrush="#87CE3E"
                                       CurrentCellBorderBrush="Transparent"
                                       CurrentCellBorderThickness="0"
                                       HorizontalAlignment="Stretch"
                                       ColumnSizer="Star">


                    <syncfusion:SfDataGrid.SortColumnDescriptions>
                        <syncfusion:SortColumnDescription ColumnName="Issuer"
                                                          SortDirection="Ascending" />
                    </syncfusion:SfDataGrid.SortColumnDescriptions>

                    <i:Interaction.Behaviors>
                        <behaviors:ScrollOnNewOrUpdatedItemBehavior />
                        <behaviors:DataGridValidationBehavior />
                        <behaviors:SfDataGridEditingBehavior  IsEditing="{Binding IsGridEditing, Mode=TwoWay}"
                                                              BeginEditCommand="{Binding BeginEditCommand}"
                                                              EndEditCommand="{Binding EndEditCommand}"
                                                              DoubleClickCommand="{Binding DoubleClickCommand}" />

                        <behaviors:SfDataGridContextMenuBehavior />
                        <behaviors:RowClickBehavior SelectionChangedCommand="{Binding RowSelectionChangedCommand}" />
                    </i:Interaction.Behaviors>

                    <syncfusion:SfDataGrid.Resources>
                        <Style TargetType="syncfusion:GridHeaderCellControl">
                            <Setter Property="Background"
                                    Value="#269797" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.Foreground}" />
                            <Setter Property="FontWeight"
                                    Value="Bold" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Center" />
                        </Style>
                    </syncfusion:SfDataGrid.Resources>

                    <!-- ==== COLUMNS: Platform ==== -->
                    <syncfusion:SfDataGrid.Columns>
                        <!-- Platform -->
                        <syncfusion:GridTextColumn HeaderText="{xaml:Resx Key=ui_Header_Platform}"
                                                   MappingName="Issuer">
                            <syncfusion:GridTextColumn.CellStyle>
                                <Style TargetType="sfGrid:GridCell"
                                       BasedOn="{StaticResource {x:Type sfGrid:GridCell}}">
                                    <Setter Property="FrameworkElement.Cursor"
                                            Value="Hand" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHighlighted}"
                                                     Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <!-- Animate background -->
                                                        <ColorAnimation Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                        To="#66FFD54F"
                                                                        Duration="0:0:1" />
                                                        <!-- Animate foreground -->
                                                        <ColorAnimation Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                                        To="#87CE3E"
                                                                        Duration="0:0:1" />
                                                        <!-- Fade background back -->
                                                        <ColorAnimation BeginTime="0:0:1"
                                                                        Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                        To="#00FFFFFF"
                                                                        Duration="0:0:1" />
                                                        <!-- Fade foreground back -->
                                                        <ColorAnimation BeginTime="0:0:1"
                                                                        Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                                        To="#97B0DF"
                                                                        Duration="0:0:1" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </syncfusion:GridTextColumn.CellStyle>
                        </syncfusion:GridTextColumn>
                    </syncfusion:SfDataGrid.Columns>

                    <!-- DataGridRow Context Menu: Edit + Delete -->
                    <syncfusion:SfDataGrid.RecordContextMenu>
                        <ContextMenu>
                            <!-- Edit -->
                            <MenuItem Header="{Binding DataGrid.DataContext.EditLabel}"
                                      Foreground="{DynamicResource Brush.Foreground}"
                                      Command="{Binding DataGrid.DataContext.OpenFlyoutEditModeCommand}"
                                      CommandParameter="{Binding Record}">
                                <MenuItem.Icon>
                                    <svgc:SvgViewbox Width="11"
                                                     Height="11"
                                                     Source="/Assets/Icons/Edit-48x48.svg" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator Background="#1D3366" />

                            <!-- Delete -->
                            <MenuItem Header="{Binding DataGrid.DataContext.DeleteLabel}"
                                      Foreground="{DynamicResource Brush.Foreground}"
                                      Command="{Binding DataGrid.DataContext.DeleteSecretCommand}"
                                      CommandParameter="{Binding Record}">
                                <MenuItem.Icon>
                                    <svgc:SvgViewbox Width="11"
                                                     Height="11"
                                                     Source="/Assets/Icons/delete-24x24.svg" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </syncfusion:SfDataGrid.RecordContextMenu>

                </syncfusion:SfDataGrid>

                <!--  TOTP-CODE, PLATFORM-NAME, PROGRESS, GENERATE-QR-CODE-LINK     CONTAINER   -->
                <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center">
                    <Label x:Name="lblSelectedPlatformName" Content="{Binding SelectedAccount.Issuer }"
                           VerticalContentAlignment="Center"
                           HorizontalContentAlignment="Center"
                           HorizontalAlignment="Center"
                         FontWeight="Bold" FontSize="15"
Height="{Binding CodeLabelHeight}"
                         />

                    <!-- === TOTP Code and Progress Pie Chart === -->
                    <StackPanel 
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center">

                        <!-- copy symbol -->
                        <Viewbox x:Name="vbCopySymbol" Width="10" Margin="0,0,0,2">
                            <svgc:SvgViewbox Source="/Assets/Icons/Copy-48x48.svg"
                                         Stretch="Uniform"
                                         Style="{StaticResource CopySymbolStyle}"
                                         Visibility="{Binding ShowCopySymbol,
                                         Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Viewbox>


                        <!-- TOTP code value   Grid.Row="2" Content="CurrentCodeLabel"-->
                        <!--Content="{Binding SelectedSecret.TotpCode }"-->
                        <Label x:Name="lblCode"  
                           Cursor="Hand"
                           Content="{Binding TotpCode }"
                           HorizontalContentAlignment="Center"
                           Height="{Binding CodeLabelHeight}"
                           FontWeight="Bold"
                           Foreground="#97B0DF"
                           FontSize="24"
                           HorizontalAlignment="Center"
                           Margin="0,0">
                            <Label.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                          Command="{Binding CopyCodeCommand}" />
                            </Label.InputBindings>
                            <Label.RenderTransform>
                                <TranslateTransform />
                            </Label.RenderTransform>
                            <Label.Style>
                                <Style TargetType="Label">
                                    <Setter Property="Opacity"
                                        Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCodeLabelVisible}"
                                                 Value="True">
                                            <Setter Property="Opacity"
                                                Value="1" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                                     From="0"
                                                                     To="-10"
                                                                     Duration="0:0:0.2"
                                                                     AutoReverse="True"
                                                                     EasingFunction="{StaticResource BounceEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Label.Style>
                        </Label>

                        <!-- Progress Pie Chart -->
                        <Viewbox x:Name="vbProgressPieChart" Height="25">
                            <syncfusion:SfCircularProgressBar x:Name="ProgressBar"
                                                          Visibility="{Binding IsProgressPieChartVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                          Minimum="0"
                                                          IndicatorOuterRadius="0.90"
                                                          IndicatorInnerRadius="0.70"
                                                          TrackOuterRadius="0.90"
                                                          TrackInnerRadius="0.70"
                                                          Margin="10,0,0,0"
                                                          Maximum="{Binding PeriodSeconds}"
                                                          Progress="{Binding ElapsedSeconds}"
                                                          IsIndeterminate="False"
                                                          SegmentCount="1"
                                                          ProgressColor="#152549"
                                                          TrackColor="{Binding Progress,
                                        ElementName=ProgressBar,
                                        Converter={StaticResource ProgressValueToBrushConverter}}">

                                <syncfusion:SfCircularProgressBar.ProgressContent>
                                    <TextBlock Text="{Binding RemainingSeconds}"
                                           FontSize="40"
                                           Padding="0"
                                           Margin="-5,0,0,0"
                                           FontWeight="Bold"
                                           Foreground="{Binding Progress,
ElementName=ProgressBar,
Converter={StaticResource ProgressValueToBrushConverter}}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                                </syncfusion:SfCircularProgressBar.ProgressContent>
                            </syncfusion:SfCircularProgressBar>
                        </Viewbox>
                    </StackPanel>


                </StackPanel>


                <!--QR CODE CONTAINER-->
                <StackPanel Grid.Row="2">
                    <!-- Generate QR code link -->
                    <TextBlock HorizontalAlignment="Center"
                               Margin="0,10,0,8"
                               Visibility="{Binding ShowGenerateQrCodeLink, 
                                Converter={StaticResource BooleanToVisibilityConverter}}">
                         <Hyperlink Command="{Binding GenerateQrCommand}">
                             <TextBlock Text="{xaml:Resx Key=ui_GenerateQR_Code}"/>
                         </Hyperlink>
                    </TextBlock>

                    <!-- === QR Code Placeholder === -->
                    <Image ToolTip="{xaml:Resx Key=tooltip_AuthenticatorAppScan}"
                           Margin="0,10,0,10"
                           Source="{Binding QrCodeImage}"
                           Width="160"
                           Height="Auto"
                           Visibility="{Binding IsQrVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />
                </StackPanel>

            </Grid>
        </StackPanel>

        <Grid>
            <!-- Edit/Add flyout -->
            <userControls:FlyoutHost   WarmUpOnLoad="True" IsOpen="{Binding IsEditAddFlyoutOpen}"
                                       CloseCommand="{Binding CancelFlyoutCommand}"
                                       PanelWidth="300">
                <userControls:FlyoutHost.FlyoutContent>
                    <views:EditAddAccountFlyoutView />
                </userControls:FlyoutHost.FlyoutContent>
            </userControls:FlyoutHost>

            <!-- Settings flyout -->
            <!--
                If you want to bind properties of the MainViewModel you have to use DataContext.YourProperty, 
                because this uc is bound to SettingsViewModel in MainViewModel constructor
            -->
            <userControls:FlyoutHost  IsOpen="{Binding DataContext.IsSettingsViewOpen, ElementName=mainWin}"
                                      DataContext="{Binding SettingsVm}"
                                      WarmUpOnLoad="True"
                                      PanelWidth="300"
                                      OverlayZIndex="20"
                                    >
                <userControls:FlyoutHost.FlyoutContent>
                    <views:SettingsFlyoutView  />
                </userControls:FlyoutHost.FlyoutContent>
            </userControls:FlyoutHost>

        </Grid>

        <!--   UnlockView.xaml   -->
        <Grid Background="#CC0C1C33" VerticalAlignment="Center"
              Visibility="{Binding IsUnlocked, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <ContentControl Content="{Binding UnlockViewModel}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Grid>


        <!-- IsBusy overlay -->
        <Border
            Background="Black"
            Opacity="1"
            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
            Panel.ZIndex="9999">

            <!-- blocks mouse/keyboard -->
            <Border IsHitTestVisible="True">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="280">
                    <TextBlock Text="LOADING..."
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- If you have Syncfusion spinner use it; otherwise a ProgressBar works -->
                    <ProgressBar IsIndeterminate="True" Height="6"/>
                </StackPanel>

            </Border>
        </Border>
    </Grid>
</syncfusion:ChromelessWindow>
