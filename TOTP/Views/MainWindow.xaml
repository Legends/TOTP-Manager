<syncfusion:ChromelessWindow x:Class="TOTP.MainWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:sys="clr-namespace:System;assembly=mscorlib"
                             xmlns:sfGrid="clr-namespace:Syncfusion.UI.Xaml.Grid;assembly=Syncfusion.SfGrid.WPF"
                             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                             xmlns:behaviors="clr-namespace:TOTP.Behaviors"
                             xmlns:converters="clr-namespace:TOTP.Converters"
                             xmlns:props="clr-namespace:TOTP.AttachedProperties"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                             xmlns:resx="clr-namespace:TOTP.Resources"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             xmlns:progress="clr-namespace:Syncfusion.UI.Xaml.ProgressBar;assembly=Syncfusion.SfProgressBar.WPF"
                             mc:Ignorable="d"
                             Width="300"
                             SizeToContent="Height"
                             Icon="/Assets/Icons/app.ico"
                             Title="TOTP Manager"
                             TitleBarBackground="#7D7FF4"
                             TitleBarForeground="{DynamicResource Brush.Foreground}"
                             xmlns:Microsoft_Windows_Themes="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero"
                             xmlns:local="clr-namespace:Syncfusion.Windows.Shared;assembly=Syncfusion.Shared.WPF">

    <syncfusion:ChromelessWindow.Resources>
        <BounceEase x:Key="BounceEase"
                    Bounces="1"
                    Bounciness="100"
                    EasingMode="EaseOut" />
        <converters:SecretMaskConverter x:Key="SecretMaskConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverterCollapsed"
                                                Collapse="True" />

        <Style x:Key="IconToggleButtonStyle"
               TargetType="{x:Type ToggleButton}">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Focusable"
                    Value="False" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="Cursor"
                    Value="Hand" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <!-- Always transparent; no trigger-driven box -->
                        <Border Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <!-- Optional: if you still want subtle feedback, uncomment:
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.85"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.75"/>
                    </Trigger>
                </ControlTemplate.Triggers>
                -->
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="InlineErrorTextStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#FFEF5350" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Margin"
                    Value="0,2,0,0" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>

        <!-- Slide-in animation for flyout -->
        <Style x:Key="FlyoutHostStyle"
               TargetType="Grid">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="300" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditOpen}"
                             Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                 To="0"
                                                 Duration="0:0:0.18" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                 To="300"
                                                 Duration="0:0:0.18" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <SolidColorBrush x:Key="MenuItemHoverBackgroundBrushKey"
                         Color="Transparent" />
        <LinearGradientBrush x:Key="MenuItemSelectedBackgroundBrushKey"
                             EndPoint="0.5,1"
                             StartPoint="0.5,0">
            <GradientStop Color="Gainsboro"
                          Offset="0.127" />
            <GradientStop Color="#FFD4D3D3"
                          Offset="0.133" />
            <GradientStop Color="#FFBDBBBB"
                          Offset="0.8" />
            <GradientStop Color="#FFB1AFAF"
                          Offset="0.873" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="MenuItemSelectedBorderBrushKey"
                         Color="#FF807F7F" />
        <SolidColorBrush x:Key="MenuItemSelectedInnerBorderBrushKey"
                         Color="#FF9B9A9A" />
        <SolidColorBrush x:Key="ExtendButtonFillKey"
                         Color="Black" />
        <SolidColorBrush x:Key="MenuItemForegroundBrushKey"
                         Color="Black" />
        <SolidColorBrush x:Key="MenuItemDisabledForegroundBrush"
                         Color="Gray" />
        <LinearGradientBrush x:Key="MenuItemMouseHoverBackgroundBrushKey"
                             EndPoint="0.5,1"
                             StartPoint="0.5,0">
            <GradientStop Color="#FF4381C2"
                          Offset="0" />
            <GradientStop Color="#FF3399FF"
                          Offset="0.028" />
            <GradientStop Color="#FF3399FF"
                          Offset="0.972" />
            <GradientStop Color="#FF6D98C3"
                          Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="MenuItemMouseHoverBorderBrushKey"
                         Color="#FFABAAAA" />
        <LinearGradientBrush x:Key="SubItemMouseHoverBackgroundBrushKey"
                             EndPoint="0,1"
                             StartPoint="0,0">
            <GradientStop Color="#34C5EBFF"
                          Offset="0" />
            <GradientStop Color="#3481D8FF"
                          Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SubItemMouseHoverBorderBrushKey"
                         Color="#FFAEDFF4" />
        <SolidColorBrush x:Key="PopUpBackgroundBrush"
                         Color="#FFF5F5F5" />
        <SolidColorBrush x:Key="PopUpBorderBrush"
                         Color="#FF959595" />
        <SolidColorBrush x:Key="PopUpLeftBackgroundBrush"
                         Color="#FFF1F1F1" />
        <SolidColorBrush x:Key="ScrollerBackgroundBrush"
                         Color="#FFC8CBD1" />
        <SolidColorBrush x:Key="ScrollBtnPathFillKey"
                         Color="Black" />
        <SolidColorBrush x:Key="ChkBoxBackgroundBrushKey"
                         Color="#EDF2F7" />
        <SolidColorBrush x:Key="ChkBoxBorderBrushKey"
                         Color="#AECFF7" />
        <SolidColorBrush x:Key="ChkBoxPathFillKey"
                         Color="#FF0C12A1" />
        <SolidColorBrush x:Key="RadioBtnBackgroundBrushKey"
                         Color="#EDF2F7" />
        <SolidColorBrush x:Key="RadioBtnBorderBrushKey"
                         Color="#AECFF7" />
        <Style x:Key="TopScrollButtonStyleKey"
               TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Border x:Name="TopButtonScroll"
                                    Background="{StaticResource ScrollerBackgroundBrush}"
                                    BorderBrush="{StaticResource ScrollerBackgroundBrush}"
                                    BorderThickness="1">
                                <Path Data="F0 M 0,0 L 4,4 8,0 Z"
                                      Fill="{StaticResource ScrollBtnPathFillKey}"
                                      HorizontalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5"
                                      VerticalAlignment="Center">
                                    <Path.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform />
                                            <SkewTransform />
                                            <RotateTransform Angle="180" />
                                            <TranslateTransform />
                                        </TransformGroup>
                                    </Path.RenderTransform>
                                </Path>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BottomScrollButtonStyleKey"
               TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Border x:Name="BottomButtonScroll"
                                    Background="{StaticResource ScrollerBackgroundBrush}"
                                    BorderBrush="{StaticResource ScrollerBackgroundBrush}"
                                    BorderThickness="1">
                                <Path Data="F0 M 0,0 L 4,4 8,0 Z"
                                      Fill="{StaticResource ScrollBtnPathFillKey}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CheckBoxStyleKey"
               TargetType="{x:Type CheckBox}">
            <Setter Property="Margin"
                    Value="3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid>
                            <Border x:Name="ChkBoxBorder"
                                    Background="{StaticResource ChkBoxBackgroundBrushKey}"
                                    BorderBrush="{StaticResource ChkBoxBorderBrushKey}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Height="22"
                                    Width="22">
                                <Path x:Name="Glyph"
                                      Data="M 2,10 L 8,16 L 18,4"
                                      Stroke="{StaticResource ChkBoxPathFillKey}"
                                      StrokeThickness="2"
                                      Fill="Transparent"
                                      Height="11"
                                      Width="16" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RadioButtonStyleKey"
               TargetType="{x:Type RadioButton}">
            <Setter Property="Margin"
                    Value="3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Grid>
                            <Border x:Name="RadioBtnBorder"
                                    Background="{StaticResource RadioBtnBackgroundBrushKey}"
                                    BorderBrush="{StaticResource RadioBtnBorderBrushKey}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Height="22"
                                    Width="22">
                                <Ellipse x:Name="EllipsePath"
                                         Height="8"
                                         Margin="1"
                                         StrokeThickness="1"
                                         Width="8">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush Center="0.65625,0.218746"
                                                             GradientOrigin="0.65625,0.218746">
                                            <RadialGradientBrush.RelativeTransform>
                                                <TransformGroup>
                                                    <RotateTransform Angle="120.379"
                                                                     CenterY="0.218746"
                                                                     CenterX="0.65625" />
                                                </TransformGroup>
                                            </RadialGradientBrush.RelativeTransform>
                                            <GradientStop Color="#FFCCCCED"
                                                          Offset="0" />
                                            <GradientStop Color="#FF16186D"
                                                          Offset="1" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </syncfusion:ChromelessWindow.Resources>

    <!-- Wrap existing content in a Grid so we can overlay the flyout -->
    <Grid>
        <!-- ===== DataGrid & Toolbar ===== -->
        <StackPanel Orientation="Vertical"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

            <Grid Height="30"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- left side -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Grid.Column="0">

                    <!-- Scan Button -->
                    <Button ToolTip="{xaml:Resx Key=ui_btnScan}"
                            Margin="5,5,0,0"
                            Padding="5,5"
                            Command="{Binding ScanQrAndAddCommand}">
                        <svgc:SvgViewbox Source="/Assets/Icons/Camera-48x48.svg"
                                         Height="15"
                                         Stretch="Uniform" />
                    </Button>

                    <!-- Add Button -->
                    <Button ToolTip="{xaml:Resx Key=tooltip_AddNew}"
                            Margin="5,5,0,0"
                            Padding="5,5"
                            Command="{Binding OpenFlyoutAddModeCommand}">
                        <svgc:SvgViewbox Source="/Assets/Icons/plus-24x24.svg"
                                         Height="15"
                                         Stretch="Uniform" />
                    </Button>

                    <!-- Search Button -->
                    <Button Command="{Binding ToggleSearchBoxCommand}"
                            ToolTip="{xaml:Resx Key=ui_btnSearch}"
                            Margin="5,5,5,0"
                            Padding="5,5">
                        <svgc:SvgViewbox Source="/Assets/Icons/find-24x24.svg"
                                         Height="15"
                                         Stretch="Uniform" />
                    </Button>

                    <!-- Search Textbox -->
                    <syncfusion:SfTextBoxExt Width="80"
                                             Height="30"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Stretch"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="{xaml:Resx Key=ui_label_Search_Dots}"
                                             props:FocusExtension.IsFocused="{Binding IsSearchFocused}"
                                             Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}"
                                             Padding="0,0,20,0"
                                             Margin="10,0,0,0" />

                    <!-- Search-Clear-Button -->
                    <Button Content="×"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Margin="-20,0,0,0"
                            Command="{Binding ClearSearchCommand}"
                            Visibility="{Binding IsSearchTextNotEmpty, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />
                </StackPanel>

                <!-- right side: language selector + Options Gear Icon-->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Grid.Column="1">
                    <syncfusion:ComboBoxAdv Grid.Column="1"
                                            IsEnabled="{Binding IsGridEditing, Converter={StaticResource InverseBooleanConverter}}"
                                            ItemsSource="{Binding SupportedCultures}"
                                            SelectedItem="{Binding SelectedCulture, Mode=TwoWay}"
                                            Width="50"
                                            VerticalAlignment="Center"
                                            Margin="2"
                                            AllowMultiSelect="False">
                        <syncfusion:ComboBoxAdv.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding IconPath}"
                                           Width="20"
                                           Height="25"
                                           Margin="0,0,5,0" />
                                </StackPanel>
                            </DataTemplate>
                        </syncfusion:ComboBoxAdv.ItemTemplate>
                    </syncfusion:ComboBoxAdv>

                    <!-- Gear-Options -->
                    <syncfusion:MenuAdv Height="25"
                                        Margin="2,5,5,0"
                                        Padding="0"
                                        Width="23"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        ExpandMode="ExpandOnClick">

                        <!-- Main entry point: Gear icon -->
                        <syncfusion:MenuItemAdv Header=" "
                                                Width="32"
                                                Padding="0"
                                                ToolTip="{xaml:Resx Key=ui_Options}"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center">


                            <syncfusion:MenuItemAdv.Icon>
                                <svgc:SvgViewbox Source="/Assets/Icons/Gear--03WF-48x48.svg"
                                                 Height="15"
                                                 Stretch="Uniform" />
                            </syncfusion:MenuItemAdv.Icon>

                            <syncfusion:MenuItemAdv Header="Export"
                                                    ToolTip="{Binding ExportToolTip}"
                                                    Command="{Binding ExportSecretsCommand}" />

                            <!-- Your menu opens vertically under the gear -->
                            <syncfusion:MenuItemAdv Header="WPF">
                                <syncfusion:MenuItemAdv Header="Tools"
                                                        ToolTip="{xaml:Resx Key=ui_btnCancel}" />
                                <syncfusion:MenuItemAdv Header="Chart" />
                                <syncfusion:MenuItemAdv Header="Grid" />
                                <syncfusion:MenuItemAdv Header="Diagram" />
                                <syncfusion:MenuItemAdv Header="Gauge" />
                                <syncfusion:MenuItemAdv Header="Schedule" />
                                <syncfusion:MenuItemAdv Header="Edit" />
                            </syncfusion:MenuItemAdv>


                            <syncfusion:MenuItemAdv Header="Reporting" />

                            <!-- Optional: actual settings command as a clickable leaf item -->
                            <syncfusion:MenuItemAdv Header="Settings"
                                                    Command="{Binding OpenSettingsCommand}" />
                        </syncfusion:MenuItemAdv>

                    </syncfusion:MenuAdv>


                </StackPanel>

            </Grid>

            <!--  === SECRETS DATAGRID CONTAINER === -->
            <Grid Margin="10,20,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- =====  SECRETS GRID   ===== -->
                <!--SelectedItem="SelectedSecret"-->
                <syncfusion:SfDataGrid x:Name="SecretsGrid"
                                       ItemsSource="{Binding AllSecrets}"
                                       CellStyle="{StaticResource {x:Type sfGrid:GridCell}}"
                                       Grid.Row="0"
                                       AllowSorting="True"
                                       AllowEditing="True"
                                       AllowDeleting="True"
                                       GridValidationMode="InView"
                                       AutoGenerateColumns="False"
                                       CanMaintainScrollPosition="True"
                                       EditTrigger="OnDoubleTap"
                                       SelectionMode="Single"
                                       SelectionUnit="Row"
                                       SelectionChanged="DataGrid_SelectionChanged"
                                       NavigationMode="Cell"
                                       LiveDataUpdateMode="AllowDataShaping"
                                       MaxHeight="200"
                                       Margin="0,0,0,20"
                                       BorderThickness="0"
                                       RowSelectionBrush="#1D3366"
                                       SelectionForegroundBrush="#87CE3E"
                                       CurrentCellBorderBrush="Transparent"
                                       CurrentCellBorderThickness="0"
                                       HorizontalAlignment="Stretch"
                                       ColumnSizer="Star">

                    <syncfusion:SfDataGrid.SortColumnDescriptions>
                        <syncfusion:SortColumnDescription ColumnName="Platform"
                                                          SortDirection="Ascending" />
                    </syncfusion:SfDataGrid.SortColumnDescriptions>

                    <i:Interaction.Behaviors>
                        <behaviors:ScrollOnNewOrUpdatedItemBehavior />
                        <behaviors:DataGridEditingStateBehavior IsEditing="{Binding IsGridEditing, Mode=TwoWay}" />
                        <behaviors:DataGridValidationBehavior />
                        <behaviors:SfDataGridEditingBehavior BeginEditCommand="{Binding BeginEditCommand}"
                                                             EndEditCommand="{Binding EndEditCommand}"
                                                             DoubleClickCommand="{Binding DoubleClickCommand}" />

                        <behaviors:SfDataGridContextMenuBehavior />
                        <behaviors:RowClickBehavior SelectionChangedCommand="{Binding RowSelectionChangedCommand}" />
                    </i:Interaction.Behaviors>

                    <syncfusion:SfDataGrid.Resources>
                        <Style TargetType="syncfusion:GridHeaderCellControl">
                            <Setter Property="Background"
                                    Value="#269797" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Brush.Foreground}" />
                            <Setter Property="FontWeight"
                                    Value="Bold" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Center" />
                        </Style>
                    </syncfusion:SfDataGrid.Resources>

                    <!-- ==== COLUMNS: Platform ==== -->
                    <syncfusion:SfDataGrid.Columns>
                        <!-- Platform -->
                        <syncfusion:GridTextColumn HeaderText="{xaml:Resx Key=ui_Header_Platform}"
                                                   MappingName="Platform">
                            <syncfusion:GridTextColumn.CellStyle>
                                <Style TargetType="sfGrid:GridCell"
                                       BasedOn="{StaticResource {x:Type sfGrid:GridCell}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHighlighted}"
                                                     Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <!-- Animate background -->
                                                        <ColorAnimation Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                        To="#66FFD54F"
                                                                        Duration="0:0:1" />
                                                        <!-- Animate foreground -->
                                                        <ColorAnimation Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                                        To="#87CE3E"
                                                                        Duration="0:0:1" />
                                                        <!-- Fade background back -->
                                                        <ColorAnimation BeginTime="0:0:1"
                                                                        Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                        To="#00FFFFFF"
                                                                        Duration="0:0:1" />
                                                        <!-- Fade foreground back -->
                                                        <ColorAnimation BeginTime="0:0:1"
                                                                        Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                                        To="#97B0DF"
                                                                        Duration="0:0:1" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </syncfusion:GridTextColumn.CellStyle>
                        </syncfusion:GridTextColumn>
                    </syncfusion:SfDataGrid.Columns>

                    <!-- Context menu: Edit + Delete -->
                    <syncfusion:SfDataGrid.RecordContextMenu>
                        <ContextMenu>
                            <!-- Edit -->
                            <MenuItem Header="{Binding DataGrid.DataContext.EditLabel}"
                                      Foreground="{DynamicResource Brush.Foreground}"
                                      Command="{Binding DataGrid.DataContext.OpenFlyoutEditModeCommand}"
                                      CommandParameter="{Binding Record}">
                                <MenuItem.Icon>
                                    <svgc:SvgViewbox Width="11"
                                                     Height="11"
                                                     Source="/Assets/Icons/Edit-48x48.svg" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator Background="#1D3366" />

                            <!-- Delete -->
                            <MenuItem Header="{Binding DataGrid.DataContext.DeleteLabel}"
                                      Foreground="{DynamicResource Brush.Foreground}"
                                      Command="{Binding DataGrid.DataContext.DeleteSecretCommand}"
                                      CommandParameter="{Binding Record}">
                                <MenuItem.Icon>
                                    <svgc:SvgViewbox Width="11"
                                                     Height="11"
                                                     Source="/Assets/Icons/delete-24x24.svg" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </syncfusion:SfDataGrid.RecordContextMenu>


                </syncfusion:SfDataGrid>

                <!-- QR Code image -->
                <Image Grid.Row="1"
                       ToolTip="{xaml:Resx Key=tooltip_AuthenticatorAppScan}"
                       Margin="0,0,0,20"
                       Source="{Binding QrCodeImage}"
                       Width="160"
                       Height="160"
                       Visibility="{Binding IsQrVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}" />

                <!--Generated TOTP code label-->
                <Label x:Name="lblCode"
                       Grid.Row="2"
                       Content="{Binding CurrentCodeLabel}"
                       HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center"
                       Height="{Binding CodeLabelHeight}"
                       FontWeight="Bold"
                       Foreground="#97B0DF"
                       FontSize="24"
                       HorizontalAlignment="Center"
                       Margin="0,0">
                    <Label.RenderTransform>
                        <TranslateTransform />
                    </Label.RenderTransform>
                    <Label.Style>
                        <Style TargetType="Label">
                            <Setter Property="Opacity"
                                    Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCodeLabelVisible}"
                                             Value="True">
                                    <Setter Property="Opacity"
                                            Value="1" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                                 From="0"
                                                                 To="-10"
                                                                 Duration="0:0:0.2"
                                                                 AutoReverse="True"
                                                                 EasingFunction="{StaticResource BounceEase}" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Label.Style>
                </Label>

                <!--Copied! label-->
                <TextBlock x:Name="lblCopiedToClipboard"
                           Grid.Row="3"
                           Margin="0,10"
                           Text="{xaml:Resx Key=ui_Code_Copied_Clipboard}"
                           TextAlignment="Center"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#FF22ED20"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsCodeCopiedVisible, Converter={StaticResource BoolToVisibilityConverterCollapsed}}">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10"
                                          Color="Aqua" />
                    </TextBlock.Effect>
                </TextBlock>

            </Grid>
        </StackPanel>

        <!-- ===== Flyout Border overlay (edit) ===== -->
        <!-- Dim background -->
        <Border Background="#66000000"
                Visibility="{Binding IsEditOpen, Converter={StaticResource BoolToVisibilityConverterCollapsed}}"
                Panel.ZIndex="10" />

        <!-- === FLYOUT CONTAINER === -->
        <Grid Width="300"
              HorizontalAlignment="Right"
              Panel.ZIndex="11"
              Visibility="{Binding IsEditOpen, Converter={StaticResource BoolToVisibilityConverterCollapsed}}"
              Style="{StaticResource FlyoutHostStyle}"
              FocusManager.IsFocusScope="True">

            <Border Background="#152549"
                    Padding="16"
                    BorderBrush="#394B74"
                    BorderThickness="1">
                <StackPanel Margin="0,10,0,10">
                    <!-- === FLYOUT HEADER  === -->
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="{Binding EditPanelTitle}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="16" />
                        <Button Content="✕"
                                Foreground="White"
                                Width="26"
                                Height="26"
                                Command="{Binding CancelFlyoutCommand}"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right" />
                    </DockPanel>

                    <!--  ===  FLYOUT FORM FIELDS  ===  -->

                    <!-- PLATFORM -->
                    <TextBlock Text="{xaml:Resx Key=ui_Header_Platform}"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,6,0,2" />
                    <TextBox x:Name="PlatformBox"
                             Text="{Binding CurrentSecretBeingEditedOrAdded.Platform,
                        UpdateSourceTrigger=PropertyChanged}"
                             Height="30"
                             props:FocusExtension.IsFocused="{Binding IsEditPlatformFocused}" />

                    <!--Error Field Platform-->
                    <TextBlock Text="{Binding CurrentSecretBeingEditedOrAdded.PlatformError}"
                               Style="{StaticResource InlineErrorTextStyle}"
                               Visibility="{Binding CurrentSecretBeingEditedOrAdded.PlatformError,
                                Converter={StaticResource StringToVisibilityConverterCollapsed}}" />

                    <!-- SECRET -->
                    <TextBlock Text="{xaml:Resx Key=ui_Header_Secret}"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,10,0,-4" />


                    <!-- VISIBLE (TextBox) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <!--<ColumnDefinition Width="Auto"></ColumnDefinition>-->
                        </Grid.ColumnDefinitions>
                        <PasswordBox Height="30"
                                     props:PasswordBoxHelper.BindPassword="True"
                                     props:PasswordBoxHelper.BoundPassword="{Binding CurrentSecretBeingEditedOrAdded.Secret,
              Mode=TwoWay,
              UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding IsSecretVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                        <TextBox Grid.Column="0"
                                 Height="30"
                                 Padding="0,0,6,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding CurrentSecretBeingEditedOrAdded.Secret,
                            Mode=TwoWay,
                            UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsSecretVisible,
                                  Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!-- Eye button -->
                        <ToggleButton Grid.Column="0" HorizontalAlignment="Right"
                                      Style="{StaticResource IconToggleButtonStyle}"
                                      Width="32"
                                      Height="30"
                                      Margin="4,0,0,0"
                                      IsChecked="{Binding IsSecretVisible, Mode=TwoWay}"
                                      ToolTip="{xaml:Resx Key=ui_btnShowHideSecret}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False">

                            <ToggleButton.Content>
                                <Grid Width="16"
                                      Height="16">
                                    <!-- eye-open icon when visible -->
                                    <svgc:SvgViewbox Source="/Assets/Icons/Eye-Closed-48x48.svg"
                                                     Stretch="Uniform"
                                                     Visibility="{Binding IsSecretVisible,
                                                      Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <!-- eye-closed icon when hidden -->
                                    <svgc:SvgViewbox Source="/Assets/Icons/Eye-Open-48x48.svg"
                                                     Stretch="Uniform"
                                                     Visibility="{Binding IsSecretVisible,
                                                      Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                </Grid>
                            </ToggleButton.Content>
                        </ToggleButton>
                    </Grid>

                    <!--Error Field Secret-->
                    <TextBlock Text="{Binding CurrentSecretBeingEditedOrAdded.SecretError}"
                               Style="{StaticResource InlineErrorTextStyle}"
                               Visibility="{Binding CurrentSecretBeingEditedOrAdded.SecretError,
                                Converter={StaticResource StringToVisibilityConverterCollapsed}}" />

                    <!-- ACCOUNT -->
                    <TextBlock Text="{xaml:Resx Key=ui_Header_Account}"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,10,0,2" />
                    <TextBox Text="{Binding CurrentSecretBeingEditedOrAdded.Account,
                        UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                    <TextBlock Text="{Binding CurrentSecretBeingEditedOrAdded.AccountError}"
                               Style="{StaticResource InlineErrorTextStyle}"
                               Visibility="{Binding CurrentSecretBeingEditedOrAdded.AccountError,
                                Converter={StaticResource StringToVisibilityConverterCollapsed}}" />

                    <!-- Save, Cancel BUTTONS -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Right">
                        <Button Content="{Binding SaveButtonLabel}"
                                FontWeight="Bold"
                                Foreground="White"
                                Command="{Binding SaveEditFlyoutAsyncCommand}"
                                Margin="0,0,8,0"
                                Padding="14,6" />
                        <Button Content="{Binding CancelButtonLabel}"
                                Foreground="White"
                                FontWeight="Bold"
                                Command="{Binding CancelFlyoutCommand}"
                                Padding="14,6" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</syncfusion:ChromelessWindow>
