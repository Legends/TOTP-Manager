<syncfusion:ChromelessWindow x:Class="TOTP.Views.QrScannerWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             mc:Ignorable="d"
                             Title="{xaml:Resx Key=ui_ScanQR}"
                             Height="420"
                             Width="560"
                             WindowStartupLocation="CenterOwner"
                             >

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCameraWindowCommand}" />
    </Window.InputBindings>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{xaml:Resx Key=ui_Header_QR_Window}"
                   FontSize="16"
                   Margin="0,0,0,8" />

        <Image Grid.Row="1"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Width="520"
               Height="320"
               Source="{Binding PreviewImage}" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="{xaml:Resx Key=ui_btnCancel}"
                    Width="100"
                    Command="{Binding CancelCommand}" />
        </StackPanel>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="3"
                Background="#80000000"
                CornerRadius="6"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="16"
                Panel.ZIndex="9999"
                Visibility="{Binding IsInitializing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="120"
                             Height="12"
                             Margin="0,0,12,0" />
                <TextBlock Text="{xaml:Resx Key=ui_CameraInit}"
                           Foreground="White"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</syncfusion:ChromelessWindow>
