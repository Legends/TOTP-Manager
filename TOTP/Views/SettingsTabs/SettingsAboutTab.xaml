<UserControl x:Class="TOTP.Views.SettingsTabs.SettingsAboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xaml="clr-namespace:TOTP.Xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="10"
                  MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.5}">
        <StackPanel Margin="0,10,0,0">
            <Border CornerRadius="14"
                    Padding="18"
                    Margin="0,0,0,12"
                    Background="#172A49"
                    BorderBrush="#365B91"
                    BorderThickness="1.2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{xaml:Resx Key=ui_Settings_About_AppName}"
                                   Style="{StaticResource TextStyle.SectionHeader}" />
                        <TextBlock Text="{xaml:Resx Key=ui_Settings_About_Description}"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource TextStyle.Subheader}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,16,0,0">
                        <Border Margin="0,0,0,8"
                                Padding="12"
                                CornerRadius="10"
                                Background="#10213C"
                                BorderBrush="#294A79"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_About_RunningVersion}"
                                           Foreground="{StaticResource Brush.TextInfo}"
                                           FontSize="{StaticResource FontSize.Caption}" />
                                <TextBlock Text="{Binding RunningVersion}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontSize="{StaticResource FontSize.DialogTitle}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,0,8"
                                Padding="12"
                                CornerRadius="10"
                                Background="#10213C"
                                BorderBrush="#294A79"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_About_AssemblyVersion}"
                                           Foreground="{StaticResource Brush.TextInfo}"
                                           FontSize="{StaticResource FontSize.Caption}" />
                                <TextBlock Text="{Binding AssemblyVersion}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontSize="{StaticResource FontSize.DialogTitle}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Padding="12"
                                CornerRadius="10"
                                Background="#10213C"
                                BorderBrush="#294A79"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_About_InstallationPath}"
                                           Foreground="{StaticResource Brush.TextInfo}"
                                           FontSize="{StaticResource FontSize.Caption}" />
                                <TextBlock Text="{Binding InstallationPath}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontSize="{StaticResource FontSize.Label}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="14"
                            CornerRadius="12"
                            Background="#0F1D35"
                            BorderBrush="#2C4F82"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding AboutSoftwareUpdatesText}"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       FontSize="{StaticResource FontSize.DialogTitle}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding AboutSoftwareUpdatesDescriptionText}"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource TextStyle.Subheader}"
                                       TextWrapping="Wrap" />

                            <Button Margin="0,14,0,0"
                                    MinWidth="190"
                                    Height="34"
                                    HorizontalAlignment="Left"
                                    Command="{Binding CheckForUpdatesCommand}">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Grid Width="16"
                                          Height="16"
                                          Margin="0,0,10,0"
                                          Visibility="{Binding IsCheckingForUpdates, Converter={StaticResource BoolToVisibilityConverterCollapsed}}">
                                        <Path Data="M 8,1 A 7,7 0 1 1 7.99,1"
                                              Stroke="#FFF4F7FF"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Stretch="Fill"
                                              SnapsToDevicePixels="True">
                                            <Path.RenderTransform>
                                                <RotateTransform CenterX="8" CenterY="8" />
                                            </Path.RenderTransform>
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCheckingForUpdates}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="SpinnerStoryboard">
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                         From="0"
                                                                                         To="360"
                                                                                         Duration="0:0:0.85" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="SpinnerStoryboard" />
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                    <TextBlock Text="{Binding CheckForUpdatesButtonText}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
