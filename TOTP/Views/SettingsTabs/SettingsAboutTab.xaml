<UserControl x:Class="TOTP.Views.SettingsTabs.SettingsAboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
             xmlns:xaml="clr-namespace:TOTP.Xaml"
             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="10"
                  MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.5}">
        <StackPanel Margin="0,10,0,0">
            <Border CornerRadius="14"
                    Padding="18"
                    Margin="0,0,0,12"
                    Background="#172A49"
                    BorderBrush="#365B91"
                    BorderThickness="1.2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{xaml:Resx Key=ui_Settings_About_AppName}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="18" />
                        <TextBlock Text="{xaml:Resx Key=ui_Settings_About_Description}"
                                   Margin="0,6,0,0"
                                   Foreground="#B8D2F2"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,16,0,0">
                        <Border Margin="0,0,0,8"
                                Padding="12"
                                CornerRadius="10"
                                Background="#10213C"
                                BorderBrush="#294A79"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_About_RunningVersion}"
                                           Foreground="#8EB6E8"
                                           FontSize="11" />
                                <TextBlock Text="{Binding RunningVersion}"
                                           Margin="0,4,0,0"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,0,8"
                                Padding="12"
                                CornerRadius="10"
                                Background="#10213C"
                                BorderBrush="#294A79"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_About_AssemblyVersion}"
                                           Foreground="#8EB6E8"
                                           FontSize="11" />
                                <TextBlock Text="{Binding AssemblyVersion}"
                                           Margin="0,4,0,0"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Padding="12"
                                CornerRadius="10"
                                Background="#10213C"
                                BorderBrush="#294A79"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_About_InstallationPath}"
                                           Foreground="#8EB6E8"
                                           FontSize="11" />
                                <TextBlock Text="{Binding InstallationPath}"
                                           Margin="0,4,0,0"
                                           Foreground="White"
                                           FontSize="13"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="14"
                            CornerRadius="12"
                            Background="#0F1D35"
                            BorderBrush="#2C4F82"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,16,0">
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_About_SoftwareUpdates}"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_About_SoftwareUpdatesDescription}"
                                           Margin="0,6,0,0"
                                           Foreground="#B8D2F2"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    MinWidth="190"
                                    Height="38"
                                    Padding="14,0"
                                    Command="{Binding CheckForUpdatesCommand}">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Grid Width="16"
                                          Height="16"
                                          Margin="0,0,10,0"
                                          Visibility="{Binding IsCheckingForUpdates, Converter={StaticResource BoolToVisibilityConverterCollapsed}}">
                                        <Path Data="M 8,1 A 7,7 0 1 1 7.99,1"
                                              Stroke="#FFF4F7FF"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Stretch="Fill"
                                              SnapsToDevicePixels="True">
                                            <Path.RenderTransform>
                                                <RotateTransform CenterX="8" CenterY="8" />
                                            </Path.RenderTransform>
                                            <Path.Triggers>
                                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0"
                                                                             To="360"
                                                                             Duration="0:0:0.85" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Path.Triggers>
                                        </Path>
                                    </Grid>
                                    <TextBlock Text="{Binding CheckForUpdatesButtonText}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
