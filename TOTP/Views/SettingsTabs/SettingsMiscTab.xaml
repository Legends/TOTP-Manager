<UserControl x:Class="TOTP.Views.SettingsTabs.SettingsMiscTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
             xmlns:xaml="clr-namespace:TOTP.Xaml"
             xmlns:local="clr-namespace:Syncfusion.Windows.Shared;assembly=Syncfusion.Shared.WPF"
             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="10"
                  MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.5}">
        <StackPanel Margin="0,10,0,0">
            <GroupBox Margin="0,0,0,12"
                      BorderBrush="#394B74"
                      BorderThickness="1">
                <GroupBox.Header>
                    <TextBlock Text="{xaml:Resx Key=ui_Settings_Section_Logging}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                </GroupBox.Header>
                <StackPanel Margin="10">
                    <Border Background="#443300"
                            BorderBrush="Orange"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Margin="0,0,0,10"
                            Visibility="{Binding IsCliOverrideActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️"
                                       Margin="0,0,8,2"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ClrOverrideText}"
                                       Foreground="Orange"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{xaml:Resx Key=ui_Settings_Logging_Level}"
                               Foreground="White"
                               Margin="0,0,0,6"/>

                    <ComboBox ItemsSource="{Binding AvailableLogLevels}"
                              SelectedItem="{Binding SelectedLogLevel, Mode=TwoWay}"
                              Height="30"
                              Margin="0,0,0,10"/>

                    <Button Content="{xaml:Resx Key=ui_Settings_Logging_OpenFolder}"
                            Command="{Binding OpenLogFolderCommand}"
                            Height="34"/>
                </StackPanel>
            </GroupBox>

            <GroupBox BorderBrush="#394B74"
                      BorderThickness="1">
                <GroupBox.Header>
                    <TextBlock Text="{xaml:Resx Key=ui_Settings_Section_Misc}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                </GroupBox.Header>
                <StackPanel Margin="10">
                    <TextBlock Text="{xaml:Resx Key=ui_Settings_QrPreviewScale}"
                               Foreground="White"
                               Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal">
                        <local:DoubleTextBox Width="70"
                                             Height="26"
                                             MinValue="1"
                                             MaxValue="6"
                                             NumberDecimalDigits="1"
                                             Step="0.5"
                                             Value="{Binding QrPreviewScaleFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{xaml:Resx Key=ui_Settings_QrPreviewScale_Hint}"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
