<syncfusion:ChromelessWindow x:Class="TOTP.Views.SettingsWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:views="clr-namespace:TOTP.Views"
                             xmlns:xaml="clr-namespace:TOTP.Xaml"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             Title="{xaml:Resx Key=ui_Settings_Title}"
                             Width="460"
                             MinWidth="460"
                             SizeToContent="Height"
                             ResizeMode="NoResize"
                             ShowInTaskbar="False"
                             WindowStartupLocation="CenterOwner"
                             WindowStyle="None"
                             TitleBarHeight="0"
                             ShowTitle="False"
                             ShowIcon="False"
                             ShowMinimizeButton="False"
                             ShowMaximizeButton="False"
                             Background="{DynamicResource Brush.SurfaceCard}">
    <syncfusion:ChromelessWindow.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}" />
    </syncfusion:ChromelessWindow.InputBindings>

    <Border Padding="16"
            Background="{DynamicResource Brush.SurfaceCard}">
        <views:SettingsFlyoutView />
    </Border>
</syncfusion:ChromelessWindow>
