<UserControl x:Class="TOTP.Views.SettingsFlyoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TOTP.Views"
             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
             xmlns:xaml="clr-namespace:TOTP.Xaml"
             xmlns:diag="clr-namespace:System.Diagnostics;assembly=WindowsBase"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:attached="clr-namespace:TOTP.Infrastructure.AttachedProperties"
             xmlns:behaviors="clr-namespace:TOTP.Infrastructure.Behaviors"
             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}">

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,10" Grid.Row="0">
            <TextBlock Text="{xaml:Resx Key=ui_Settings_Title}"
                      Foreground="White"
                      FontWeight="Bold"
                      FontSize="16"
                      VerticalAlignment="Center"/>

            <Button Content="✕"
                   Foreground="White"
                   Width="26"
                   Height="26"
                   Command="{Binding CloseCommand}"
                   HorizontalAlignment="Right"
                   DockPanel.Dock="Right" />
        </DockPanel>


        <!-- TABS CONTAINER -->
        <syncfusion:TabControlExt x:Name="ContTabControlExt" TabItemHoverBorderBrush="AliceBlue"  
                                  Focusable="True"
                                  attached:FocusTriggerExtension.FocusTrigger="{Binding RequestFocusTick}"
                                      EnableLabelEdit="False"
                                      TabItemHoverBackground="Transparent" 
                                      TabItemHoverForeground="AliceBlue"  
                                      Grid.Row="1"   CloseButtonType="Hide"
                                      Margin="0,0,0,12"
                                      TabStripPlacement="Top">
            <!-- AUTHORIZATION -->
            <syncfusion:TabItemExt Header="{xaml:Resx Key=ui_Settings_Tab_Authorization}"
                                   >

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="0,10,0,0">

                        <!--<TextBlock Text="{xaml:Resx Key=ui_Settings_Section_Auth}"
                                  Foreground="White"
                                  FontWeight="Bold"
                                  Margin="0,0,0,10"/>-->

                        <TextBlock Text="{xaml:Resx Key=ui_Settings_Auth_Method}"
                                  Foreground="White"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,6"/>

                        <!-- Simple choice (can be ComboBoxAdv later if you want) -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton Content="{xaml:Resx Key=ui_Settings_Auth_WindowsHello}"
                                            Foreground="White"
                                            IsChecked="{Binding IsHelloSelected, Mode=TwoWay}"
                                            IsEnabled="{Binding IsHelloAvailable}"
                                            VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding HelloUnavailableText}"
                                           Foreground="#5D729C"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsHelloUnavailable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>

                            <RadioButton Content="{xaml:Resx Key=ui_Settings_Auth_Password}"
                                        Foreground="White"
                                        IsChecked="{Binding IsPasswordSelected, Mode=TwoWay}"/>
                        </StackPanel>

                        <Border Height="1" Background="Transparent" Margin="0,0,0,14"/>

                        <!-- Password management block (only show when Password is selected) -->
                        <StackPanel Visibility="{Binding IsPasswordSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{xaml:Resx Key=ui_Settings_Auth_Password_SetChange}"
                                      Foreground="White"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,6"/>

                            <PasswordBox Height="30" Margin="0,0,0,10"
                                         behaviors:PasswordBoxHelper.BindPassword="True"
                                         behaviors:PasswordBoxHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <PasswordBox Height="30" Margin="0,0,0,10"
                                         behaviors:PasswordBoxHelper.BindPassword="True"
                                         behaviors:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>


                        <TextBlock Margin="0,0,0,10" Text="{Binding AuthError}"
                                   Foreground="#FFEF5350"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding HasAuthError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Border Visibility="{Binding IsPasswordSelected, Converter={StaticResource InverseBoolToVisibilityConverter}}" Height="1" Background="#394B74" Margin="0,0,0,14"/>
                        <TextBlock Text="{xaml:Resx Key=ui_Settings_Auth_Lock_Session}"
                                  Foreground="White"
                                  FontWeight="SemiBold"
                                  Margin="0,5,0,6"/>
                        <!-- Lock policy -->
                        <CheckBox Content="{xaml:Resx Key=ui_Settings_LockOnWindowsLock}"
                                 Foreground="White"
                                 IsChecked="{Binding LockOnSessionLock, Mode=TwoWay}"
                                 Margin="0,0,0,8"/>

                        <CheckBox Content="{xaml:Resx Key=ui_Settings_ClearClipboard}"
                                 Foreground="White"
                                 IsChecked="{Binding ClearClipboardEnabled, Mode=TwoWay}"
                                 Margin="0,0,0,6"/>

                        <StackPanel Orientation="Horizontal"
                                   Visibility="{Binding ClearClipboardEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{xaml:Resx Key=ui_Settings_ClearClipboard_After}"
                                      Foreground="White"
                                      VerticalAlignment="Center"/>
                            <TextBox Width="60" Height="26" Margin="10,0,0,0"
                                    Text="{Binding ClearClipboardSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{xaml:Resx Key=ui_Settings_ClearClipboard_Seconds}"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="{xaml:Resx Key=ui_Settings_QrPreviewScale}"
                                  Foreground="White"
                                  FontWeight="SemiBold"
                                  Margin="0,12,0,6"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBox Width="60"
                                     Height="26"
                                     Text="{Binding QrPreviewScaleFactor, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock Text="{xaml:Resx Key=ui_Settings_QrPreviewScale_Hint}"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </syncfusion:TabItemExt>

            <!-- BACKUP & RESTORE -->
            <syncfusion:TabItemExt Header="{xaml:Resx Key=ui_Settings_Tab_Export}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="{xaml:Resx Key=ui_Settings_Export}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <CheckBox Content="{xaml:Resx Key=ui_Settings_Export_Encrypt}"
                             Foreground="White"
                             IsChecked="{Binding ExportEncrypt, Mode=TwoWay}"
                             Margin="0,0,0,8"/>

                        <TextBlock Text="{xaml:Resx Key=ui_Settings_Export_Format}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,6"/>

                        <ComboBox ItemsSource="{Binding AvailableExportFormats}"
                                  SelectedItem="{Binding SelectedExportFormat, Mode=TwoWay}"
                                  IsEnabled="{Binding IsExportFormatSelectionEnabled}"
                                  Height="30"
                                  Margin="0,0,0,8"/>

                        <CheckBox Content="{xaml:Resx Key=ui_Settings_Export_OpenAfterExport}"
                                  Foreground="White"
                                  IsChecked="{Binding OpenExportFileAfterExport, Mode=TwoWay}"
                                  Margin="0,0,0,8"
                                  Visibility="{Binding IsOpenExportFileAfterExportOptionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <Button Content="{xaml:Resx Key=ui_Settings_Export}"
                           Command="{Binding ExportCommand}"
                           Height="34"
                           Margin="0,10,0,0"/>

                        <Border Height="1" Background="#394B74" Margin="0,16,0,16"/>

                        <TextBlock Text="{xaml:Resx Key=ui_Settings_Import}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="{xaml:Resx Key=ui_Settings_Import_ConflictStrategy}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,6"/>

                        <ComboBox ItemsSource="{Binding AvailableImportConflictOptions}"
                                  SelectedItem="{Binding SelectedImportConflictOption, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Height="30"
                                  Margin="0,0,0,8"/>

                        <Button Content="{xaml:Resx Key=ui_Settings_Import}"
                                Command="{Binding ImportCommand}"
                                Height="34"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </syncfusion:TabItemExt>

            <syncfusion:TabItemExt Header="{xaml:Resx Key=ui_Settings_Tab_Diagnostics}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="0,10,0,0">
                        <!--<TextBlock Text="{xaml:Resx Key=ui_Settings_Section_Logging}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>-->

                        <Border Background="#443300" 
                                BorderBrush="Orange" 
                                BorderThickness="1" 
                                CornerRadius="4" 
                                Padding="8" 
                                Margin="0,0,0,15"
                                Visibility="{Binding IsCliOverrideActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️" Margin="0,0,8,2" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ClrOverrideText}" 
                                           Foreground="Orange" 
                                           TextWrapping="Wrap"
                                        
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{xaml:Resx Key=ui_Settings_Logging_Level}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <ComboBox ItemsSource="{Binding AvailableLogLevels}"
                                  SelectedItem="{Binding SelectedLogLevel, Mode=TwoWay}"
                                  Height="30"
                                  Margin="0,0,0,15"/>

                        <Border Height="1" Background="#394B74" Margin="0,0,0,15"/>

                        <Button Content="{xaml:Resx Key=ui_Settings_Logging_OpenFolder}"
                                Command="{Binding OpenLogFolderCommand}"
                                Height="34"/>
                    </StackPanel>
                </ScrollViewer>
            </syncfusion:TabItemExt>
        </syncfusion:TabControlExt>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right">
            <Button Content="{xaml:Resx Key=ui_btnSave}"
                   Command="{Binding SaveCommand}"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,8,0"
                   Padding="14,6"/>
            <Button Content="{xaml:Resx Key=ui_btnCancel}"
                   Command="{Binding CloseCommand}"
                   Foreground="White"
                   FontWeight="Bold"
                   Padding="14,6"/>
        </StackPanel>
    </Grid>
</UserControl>
