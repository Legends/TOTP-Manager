<UserControl x:Class="TOTP.Views.SettingsFlyoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TOTP.Views"
             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
             xmlns:xaml="clr-namespace:TOTP.Xaml"
             xmlns:diag="clr-namespace:System.Diagnostics;assembly=WindowsBase"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:local="clr-namespace:Syncfusion.Windows.Shared;assembly=Syncfusion.Shared.WPF"
             xmlns:userControls="clr-namespace:TOTP.UserControls"
             xmlns:attached="clr-namespace:TOTP.Infrastructure.AttachedProperties"
             xmlns:behaviors="clr-namespace:TOTP.Infrastructure.Behaviors"
             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}">

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,10" Grid.Row="0">
            <TextBlock Text="{xaml:Resx Key=ui_Settings_Title}"
                      Foreground="White"
                      FontWeight="Bold"
                      FontSize="16"
                      VerticalAlignment="Center"/>

            <Button Content="✕"
                   Foreground="White"
                   Width="26"
                   Height="26"
                   Command="{Binding CloseCommand}"
                   HorizontalAlignment="Right"
                   DockPanel.Dock="Right" />
        </DockPanel>


        <!-- TABS CONTAINER -->
        <syncfusion:TabControlExt x:Name="ContTabControlExt" TabItemHoverBorderBrush="AliceBlue"  
                                  Focusable="True"
                                  attached:FocusTriggerExtension.FocusTrigger="{Binding RequestFocusTick}"
                                      EnableLabelEdit="False"
                                      TabItemHoverBackground="Transparent" 
                                      TabItemHoverForeground="AliceBlue"  
                                      Grid.Row="1"   CloseButtonType="Hide"
                                      Margin="0,0,0,12"
                                      TabStripPlacement="Top">
            <!-- SECURITY -->
            <syncfusion:TabItemExt Header="Security">

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="10"
                              MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.5}">
                    <StackPanel Margin="0,10,0,0">
                        <GroupBox Margin="0,0,0,12"
                                  BorderBrush="#394B74"
                                  BorderThickness="1">
                            <GroupBox.Header>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_Auth_Method}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <RadioButton Content="{xaml:Resx Key=ui_Settings_Auth_WindowsHello}"
                                                 Foreground="White"
                                                 IsChecked="{Binding IsHelloSelected, Mode=TwoWay}"
                                                 IsEnabled="{Binding IsHelloAvailable}"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding HelloUnavailableText}"
                                               Foreground="#5D729C"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IsHelloUnavailable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>

                                <RadioButton Content="{xaml:Resx Key=ui_Settings_Auth_Password}"
                                             Foreground="White"
                                             IsChecked="{Binding IsPasswordSelected, Mode=TwoWay}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Margin="0,0,0,12"
                                  BorderBrush="#394B74"
                                  BorderThickness="1"
                                  Visibility="{Binding IsPasswordSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <GroupBox.Header>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_Auth_Password_SetChange}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <userControls:RevealableSecretBox Margin="0,0,0,10"
                                                                  Secret="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  ToggleButtonStyle="{StaticResource IconToggleButtonStyle}"
                                                                  ToggleToolTip="{xaml:Resx Key=ui_btnShowHideSecret}" />
                                <TextBlock Text="{Binding NewPasswordError}"
                                           Style="{StaticResource InlineErrorTextStyle}"
                                           Visibility="{Binding NewPasswordError, Converter={StaticResource StringToVisibilityConverterCollapsed}}"
                                           Margin="0,0,0,8" />

                                <userControls:RevealableSecretBox Secret="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  ToggleButtonStyle="{StaticResource IconToggleButtonStyle}"
                                                                  ToggleToolTip="{xaml:Resx Key=ui_btnShowHideSecret}" />
                                <TextBlock Text="{Binding ConfirmPasswordError}"
                                           Style="{StaticResource InlineErrorTextStyle}"
                                           Visibility="{Binding ConfirmPasswordError, Converter={StaticResource StringToVisibilityConverterCollapsed}}"
                                           Margin="0,0,0,8" />

                                <Button Content="{xaml:Resx Key=ui_Settings_Auth_Password_SetChange}"
                                        Command="{Binding ChangePasswordCommand}"
                                        Height="32"
                                        Margin="0,10,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <TextBlock Margin="0,0,0,10"
                                   Text="{Binding AuthError}"
                                   Foreground="#FFEF5350"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding HasAuthError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <GroupBox Margin="0,0,0,12"
                                  BorderBrush="#394B74"
                                  BorderThickness="1">
                            <GroupBox.Header>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_Auth_Lock_Session}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <CheckBox Content="{xaml:Resx Key=ui_Settings_LockOnWindowsLock}"
                                          Foreground="White"
                                          IsChecked="{Binding LockOnSessionLock, Mode=TwoWay}"
                                          Margin="0,0,0,8"/>

                                <CheckBox Content="Lock when app is minimized"
                                          Foreground="White"
                                          IsChecked="{Binding LockOnMinimize, Mode=TwoWay}"
                                          Margin="0,0,0,8"/>

                                <CheckBox Content="Lock after inactivity"
                                          Foreground="White"
                                          IsChecked="{Binding LockOnIdleTimeout, Mode=TwoWay}"
                                          Margin="0,0,0,6"/>

                                <StackPanel Orientation="Horizontal"
                                            Margin="18,0,0,0">
                                    <TextBox Width="60"
                                             Height="26"
                                             IsEnabled="{Binding IsIdleTimeoutMinutesEnabled}"
                                             Text="{Binding IdleTimeoutMinutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <TextBlock Text="minutes"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox BorderBrush="#394B74"
                                  BorderThickness="1">
                            <GroupBox.Header>
                                <TextBlock Text="Common"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <CheckBox Content="{xaml:Resx Key=ui_Settings_ClearClipboard}"
                                          Foreground="White"
                                          IsChecked="{Binding ClearClipboardEnabled, Mode=TwoWay}"
                                          Margin="0,0,0,6"/>

                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding ClearClipboardEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{xaml:Resx Key=ui_Settings_ClearClipboard_After}"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                    <TextBox Width="60"
                                             Height="26"
                                             Margin="10,0,0,0"
                                             Text="{Binding ClearClipboardSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="{xaml:Resx Key=ui_Settings_ClearClipboard_Seconds}"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </syncfusion:TabItemExt>

            <!-- BACKUP & RESTORE -->
            <syncfusion:TabItemExt Header="{xaml:Resx Key=ui_Settings_Tab_Export}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="10"
                              MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.5}">
                    <StackPanel Margin="0,10,0,0">
                        <GroupBox Margin="0,0,0,12"
                                  BorderBrush="#394B74"
                                  BorderThickness="1">
                            <GroupBox.Header>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_Export}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <CheckBox Content="{xaml:Resx Key=ui_Settings_Export_Encrypt}"
                                          Foreground="White"
                                          IsChecked="{Binding ExportEncrypt, Mode=TwoWay}"
                                          Margin="0,0,0,8"/>

                                <TextBlock Text="{xaml:Resx Key=ui_Settings_Export_Format}"
                                           Foreground="White"
                                           Margin="0,4,0,6"/>

                                <ComboBox ItemsSource="{Binding AvailableExportFormats}"
                                          SelectedItem="{Binding SelectedExportFormat, Mode=TwoWay}"
                                          IsEnabled="{Binding IsExportFormatSelectionEnabled}"
                                          Height="30"
                                          Margin="0,0,0,8"/>

                                <CheckBox Content="{xaml:Resx Key=ui_Settings_Export_OpenAfterExport}"
                                          Foreground="White"
                                          IsChecked="{Binding OpenExportFileAfterExport, Mode=TwoWay}"
                                          Margin="0,0,0,8"
                                          IsEnabled="{Binding IsOpenExportFileAfterExportOptionEnabled}" />

                                <Button Content="{xaml:Resx Key=ui_Settings_Export}"
                                        Command="{Binding ExportCommand}"
                                        Height="34"
                                        Margin="0,10,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox BorderBrush="#394B74"
                                  BorderThickness="1">
                            <GroupBox.Header>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_Import}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_Import_ConflictStrategy}"
                                           Foreground="White"
                                           Margin="0,4,0,6"/>

                                <ComboBox ItemsSource="{Binding AvailableImportConflictOptions}"
                                          SelectedItem="{Binding SelectedImportConflictOption, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          Height="30"
                                          Margin="0,0,0,8"/>

                                <Button Content="{xaml:Resx Key=ui_Settings_Import}"
                                        Command="{Binding ImportCommand}"
                                        Height="34"
                                        Margin="0,10,0,0"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </syncfusion:TabItemExt>

            <!-- MISC TAB -->
            <syncfusion:TabItemExt Header="MISC">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="10"
                              MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.5}">
                    <StackPanel Margin="0,10,0,0">
                        <GroupBox Margin="0,0,0,12"
                                  BorderBrush="#394B74"
                                  BorderThickness="1">
                            <GroupBox.Header>
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_Section_Logging}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <Border Background="#443300"
                                        BorderBrush="Orange"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8"
                                        Margin="0,0,0,10"
                                        Visibility="{Binding IsCliOverrideActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠️" Margin="0,0,8,2" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ClrOverrideText}"
                                                   Foreground="Orange"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{xaml:Resx Key=ui_Settings_Logging_Level}"
                                           Foreground="White"
                                           Margin="0,0,0,6"/>

                                <ComboBox ItemsSource="{Binding AvailableLogLevels}"
                                          SelectedItem="{Binding SelectedLogLevel, Mode=TwoWay}"
                                          Height="30"
                                          Margin="0,0,0,10"/>

                                <Button Content="{xaml:Resx Key=ui_Settings_Logging_OpenFolder}"
                                        Command="{Binding OpenLogFolderCommand}"
                                        Height="34"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox BorderBrush="#394B74"
                                  BorderThickness="1">
                            <GroupBox.Header>
                                <TextBlock Text="Misc"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <TextBlock Text="{xaml:Resx Key=ui_Settings_QrPreviewScale}"
                                           Foreground="White"
                                           Margin="0,0,0,6"/>

                                <StackPanel Orientation="Horizontal">
                                    <local:DoubleTextBox Width="70"
                                                         Height="26"
                                                         MinValue="1"
                                                         MaxValue="6"
                                                         NumberDecimalDigits="1"
                                                         Step="0.5"
                                                         Value="{Binding QrPreviewScaleFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{xaml:Resx Key=ui_Settings_QrPreviewScale_Hint}"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Margin="0,12,0,0"
                                  BorderBrush="#394B74"
                                  BorderThickness="1">
                            <GroupBox.Header>
                                <TextBlock Text="About"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </GroupBox.Header>
                            <StackPanel Margin="10">
                                <TextBlock Text="TOTP Manager"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                                <TextBlock Text="{Binding RunningVersion, StringFormat=Running version: {0}}"
                                           Margin="0,8,0,0"
                                           Foreground="#D7E6FF"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding AssemblyVersion, StringFormat=Assembly version: {0}}"
                                           Margin="0,6,0,0"
                                           Foreground="#AFC7E8"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding InstallationPath, StringFormat=Path: {0}}"
                                           Margin="0,6,0,0"
                                           Foreground="#8EB6E8"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </syncfusion:TabItemExt>
        </syncfusion:TabControlExt>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right">
            <Button Content="Reset to defaults"
                   Command="{Binding ResetToDefaultsCommand}"
                   IsEnabled="{Binding CanResetToDefaults}"
                   Foreground="White"
                   FontWeight="Bold"
                   Padding="14,6"/>
        </StackPanel>
    </Grid>
</UserControl>
