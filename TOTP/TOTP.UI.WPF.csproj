<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
		<Nullable>enable</Nullable>
		<UseWPF>true</UseWPF>
		<InterceptorsNamespaces>$(InterceptorsNamespaces);Microsoft.Extensions.Configuration.Binder.SourceGeneration</InterceptorsNamespaces>
		<!--<PublishAot>true</PublishAot>-->
		<!--<UseWindowsForms>true</UseWindowsForms>-->
		<UserSecretsId>6f888768-43da-4da8-9820-96b854382d72</UserSecretsId>
		<ApplicationIcon>totp.ico</ApplicationIcon>
		<PackageIcon>totp.ico</PackageIcon>
		<SignAssembly>True</SignAssembly>
		<AssemblyOriginatorKeyFile>totp-sign-key.snk</AssemblyOriginatorKeyFile>
		<PublicSign>true</PublicSign>
		<GenerateDocumentationFile>False</GenerateDocumentationFile>
		<RootNamespace>TOTP</RootNamespace>
		<GenerateApplicationDefinition>false</GenerateApplicationDefinition>
	</PropertyGroup>

	<ItemGroup>
