	<Target Name="PublishSplashProject"
	        AfterTargets="Publish"
	        Condition="'$(PublishDir)' != ''">
		<MSBuild Projects="..\TOTP.Splash\TOTP.Splash.csproj"
		         Targets="Publish"
		         Properties="Configuration=$(Configuration);RuntimeIdentifier=$(RuntimeIdentifier);SelfContained=$(SelfContained);PublishSingleFile=true;IncludeAllContentForSelfExtract=true;IncludeNativeLibrariesForSelfExtract=true;PublishTrimmed=false;NoRestore=true;Restore=false;PublishDir=$(PublishDir);PublishProfile=" />
