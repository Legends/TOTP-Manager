		<None Remove=".github\**" />
		<Page Remove=".github\**" />
	</ItemGroup>

	<PropertyGroup>
		<IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
		<_SuppressWpfTrimError>true</_SuppressWpfTrimError>
	</PropertyGroup>

	<ItemGroup>
	  <ApplicationDefinition Remove="App.xaml" />
	</ItemGroup>



