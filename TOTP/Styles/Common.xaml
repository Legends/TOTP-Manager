<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    
                    xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                    xmlns:props="clr-namespace:TOTP.AttachedProperties"
                    xmlns:converters="clr-namespace:TOTP.Converters">

    <!--xmlns:sys="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"-->

    <!-- Converter -->
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <converters:BoolToVisibilityConverterCollapsed x:Key="BoolToVisibilityConverterCollapsed" />

    <BounceEase x:Key="BounceEase"
                Bounces="1"
                Bounciness="100"
                EasingMode="EaseOut" />
    <converters:SecretMaskConverter x:Key="SecretMaskConverter" />
    <converters:ProgressValueToBrushConverter x:Key="ProgressValueToBrushConverter" />
    <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverterCollapsed"
                                            Collapse="True" />

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Foreground"
                     Color="White" />
    <SolidColorBrush x:Key="WatermarkBrush"
                     Color="White"
                     Opacity="0.2" />

    <Style x:Key="CopySymbolStyle"
           TargetType="svgc:SvgViewbox">
        <Style.Triggers>
            <DataTrigger Binding="{Binding ShowCopySymbol}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1"
                                             To="0"
                                             Duration="0:0:0.3"
                                             AutoReverse="True" />
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>


    <DataTemplate x:Key="CustomWatermarkTemplate">
        <TextBlock Text="{Binding}"
                   FontStyle="Italic"
                   FontSize="11"
                   Opacity="0.5" />
    </DataTemplate>

    <Style x:Key="IconToggleButtonStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background"
			  Value="Transparent" />
        <Setter Property="BorderBrush"
			  Value="Transparent" />
        <Setter Property="BorderThickness"
			  Value="0" />
        <Setter Property="Padding"
			  Value="0" />
        <Setter Property="Focusable"
			  Value="False" />
        <Setter Property="FocusVisualStyle"
			  Value="{x:Null}" />
        <Setter Property="Cursor"
			  Value="Hand" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <!--Always transparent; no trigger-driven box-->
                    <Border Background="Transparent"
						  BorderBrush="Transparent"
						  BorderThickness="0"
						  SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
										VerticalAlignment="Center" />
                    </Border>

                    <!--Optional: if you still want subtle feedback, uncomment:-->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.75"/>
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="InlineErrorTextStyle"
           TargetType="TextBlock">
        <Setter Property="Foreground"
                Value="#FFEF5350" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="Margin"
                Value="0,2,0,0" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
    </Style>


    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrushKey"
					 Color="Transparent" />
    <LinearGradientBrush x:Key="MenuItemSelectedBackgroundBrushKey"
						 EndPoint="0.5,1"
						 StartPoint="0.5,0">
        <GradientStop Color="Gainsboro"
					  Offset="0.127" />
        <GradientStop Color="#FFD4D3D3"
					  Offset="0.133" />
        <GradientStop Color="#FFBDBBBB"
					  Offset="0.8" />
        <GradientStop Color="#FFB1AFAF"
					  Offset="0.873" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="MenuItemSelectedBorderBrushKey"
					 Color="#FF807F7F" />
    <SolidColorBrush x:Key="MenuItemSelectedInnerBorderBrushKey"
					 Color="#FF9B9A9A" />
    <SolidColorBrush x:Key="ExtendButtonFillKey"
					 Color="Black" />
    <SolidColorBrush x:Key="MenuItemForegroundBrushKey"
					 Color="Black" />
    <SolidColorBrush x:Key="MenuItemDisabledForegroundBrush"
					 Color="Gray" />
    <LinearGradientBrush x:Key="MenuItemMouseHoverBackgroundBrushKey"
						 EndPoint="0.5,1"
						 StartPoint="0.5,0">
        <GradientStop Color="#FF4381C2"
					  Offset="0" />
        <GradientStop Color="#FF3399FF"
					  Offset="0.028" />
        <GradientStop Color="#FF3399FF"
					  Offset="0.972" />
        <GradientStop Color="#FF6D98C3"
					  Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="MenuItemMouseHoverBorderBrushKey"
					 Color="#FFABAAAA" />
    <LinearGradientBrush x:Key="SubItemMouseHoverBackgroundBrushKey"
						 EndPoint="0,1"
						 StartPoint="0,0">
        <GradientStop Color="#34C5EBFF"
					  Offset="0" />
        <GradientStop Color="#3481D8FF"
					  Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="SubItemMouseHoverBorderBrushKey"
					 Color="#FFAEDFF4" />
    <SolidColorBrush x:Key="PopUpBackgroundBrush"
					 Color="#FFF5F5F5" />
    <SolidColorBrush x:Key="PopUpBorderBrush"
					 Color="#FF959595" />
    <SolidColorBrush x:Key="PopUpLeftBackgroundBrush"
					 Color="#FFF1F1F1" />
    <SolidColorBrush x:Key="ScrollerBackgroundBrush"
					 Color="#FFC8CBD1" />
    <SolidColorBrush x:Key="ScrollBtnPathFillKey"
					 Color="Black" />
    <SolidColorBrush x:Key="ChkBoxBackgroundBrushKey"
					 Color="#EDF2F7" />
    <SolidColorBrush x:Key="ChkBoxBorderBrushKey"
					 Color="#AECFF7" />
    <SolidColorBrush x:Key="ChkBoxPathFillKey"
					 Color="#FF0C12A1" />
    <SolidColorBrush x:Key="RadioBtnBackgroundBrushKey"
					 Color="#EDF2F7" />
    <SolidColorBrush x:Key="RadioBtnBorderBrushKey"
					 Color="#AECFF7" />
    <Style x:Key="TopScrollButtonStyleKey"
		   TargetType="{x:Type Button}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border x:Name="TopButtonScroll"
								Background="{StaticResource ScrollerBackgroundBrush}"
								BorderBrush="{StaticResource ScrollerBackgroundBrush}"
								BorderThickness="1">
                            <Path Data="F0 M 0,0 L 4,4 8,0 Z"
								  Fill="{StaticResource ScrollBtnPathFillKey}"
								  HorizontalAlignment="Center"
								  RenderTransformOrigin="0.5,0.5"
								  VerticalAlignment="Center">
                                <Path.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform />
                                        <SkewTransform />
                                        <RotateTransform Angle="180" />
                                        <TranslateTransform />
                                    </TransformGroup>
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="BottomScrollButtonStyleKey"
		   TargetType="{x:Type Button}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border x:Name="BottomButtonScroll"
								Background="{StaticResource ScrollerBackgroundBrush}"
								BorderBrush="{StaticResource ScrollerBackgroundBrush}"
								BorderThickness="1">
                            <Path Data="F0 M 0,0 L 4,4 8,0 Z"
								  Fill="{StaticResource ScrollBtnPathFillKey}"
								  HorizontalAlignment="Center"
								  VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="CheckBoxStyleKey"
		   TargetType="{x:Type CheckBox}">
        <Setter Property="Margin"
				Value="3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid>
                        <Border x:Name="ChkBoxBorder"
								Background="{StaticResource ChkBoxBackgroundBrushKey}"
								BorderBrush="{StaticResource ChkBoxBorderBrushKey}"
								BorderThickness="1"
								CornerRadius="3"
								Height="22"
								Width="22">
                            <Path x:Name="Glyph"
								  Data="M 2,10 L 8,16 L 18,4"
								  Stroke="{StaticResource ChkBoxPathFillKey}"
								  StrokeThickness="2"
								  Fill="Transparent"
								  Height="11"
								  Width="16" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="RadioButtonStyleKey"
		   TargetType="{x:Type RadioButton}">
        <Setter Property="Margin"
				Value="3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Grid>
                        <Border x:Name="RadioBtnBorder"
								Background="{StaticResource RadioBtnBackgroundBrushKey}"
								BorderBrush="{StaticResource RadioBtnBorderBrushKey}"
								BorderThickness="1"
								CornerRadius="3"
								Height="22"
								Width="22">
                            <Ellipse x:Name="EllipsePath"
									 Height="8"
									 Margin="1"
									 StrokeThickness="1"
									 Width="8">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.65625,0.218746"
														 GradientOrigin="0.65625,0.218746">
                                        <RadialGradientBrush.RelativeTransform>
                                            <TransformGroup>
                                                <RotateTransform Angle="120.379"
																 CenterY="0.218746"
																 CenterX="0.65625" />
                                            </TransformGroup>
                                        </RadialGradientBrush.RelativeTransform>
                                        <GradientStop Color="#FFCCCCED"
													  Offset="0" />
                                        <GradientStop Color="#FF16186D"
													  Offset="1" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

     <!--Overlay that appears when flyout is open--> 
    <Style x:Key="FlyoutOverlayStyle" TargetType="Border">
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="Background" Value="#80000000"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="IsHitTestVisible" Value="False"/>

        <Style.Triggers>
             <!--If overlay's DataContext has IsXxxFlyoutOpen, you can bind in the instance--> 
        </Style.Triggers>
    </Style>

    <!-- Host grid that slides -->
    <Style x:Key="FlyoutHostStyle" TargetType="Grid">
        <!-- default: closed -->
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Focusable" Value="True"/>

        <!-- transform uses binding (this is OK; it's not part of the Storyboard tree) -->
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="{Binding RelativeSource={RelativeSource Self}, Path=(props:Flyout.ClosedX)}"/>
            </Setter.Value>
        </Setter>

        <!-- ESC support (attached property) -->
        <Setter Property="props:Flyout.CloseOnEsc" Value="True"/>

        <Style.Triggers>
            <Trigger Property="props:Flyout.IsOpen" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
                <Setter Property="IsHitTestVisible" Value="True"/>
                
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- IMPORTANT: no Binding / DynamicResource anywhere in the Timeline -->
                            <DoubleAnimation
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                            To="0"
                            Duration="0:0:0.18"
                            FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>

                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- IMPORTANT: no Binding / DynamicResource anywhere in the Timeline -->
                            <!-- So we do NOT bind the 'To' value; we use a constant.
                             Therefore ClosedX must match this constant. -->
                            <DoubleAnimation
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                            To="300"
                            Duration="0:0:0.18"
                            FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>