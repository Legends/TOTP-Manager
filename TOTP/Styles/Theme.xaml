<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Color x:Key="Color.TextPrimary">#FFFFFFFF</Color>
    <Color x:Key="Color.TextSecondary">#FFCBDAF3</Color>
    <Color x:Key="Color.TextTertiary">#FFD7E6FF</Color>
    <Color x:Key="Color.TextInfo">#FF9CC3FF</Color>
    <Color x:Key="Color.TextDanger">#FFFF9C9C</Color>
    <Color x:Key="Color.TextValidationError">#FFEF5350</Color>
    <Color x:Key="Color.TextSelection">#FF97B0DF</Color>
    <Color x:Key="Color.TextHighlight">#FF87CE3E</Color>
    <Color x:Key="Color.TextBrand">#AA3ADA</Color>

    <Color x:Key="Color.SurfaceCard">#FF10213F</Color>
    <Color x:Key="Color.SurfaceDialog">#FF192B52</Color>
    <Color x:Key="Color.SurfaceSplash">#FF0F1A2D</Color>
    <Color x:Key="Color.SurfaceSubtle">#141F3559</Color>
    <Color x:Key="Color.SurfaceSecondaryButton">#FF1A2E4E</Color>
    <Color x:Key="Color.SurfaceSecondaryButtonHover">#FF243C63</Color>
    <Color x:Key="Color.SurfaceSecondaryButtonPressed">#FF152744</Color>
    <Color x:Key="Color.SurfaceProgressTrack">#FF193257</Color>
    <Color x:Key="Color.SurfaceOverlay">#B010213F</Color>
    <Color x:Key="Color.SurfaceBusyOverlay">#CC000000</Color>
    <Color x:Key="Color.SurfaceGridAccent">#FF1D3366</Color>

    <Color x:Key="Color.BorderAccent">#FF7D7FF4</Color>
    <Color x:Key="Color.BorderAccentSoft">#FF9899FF</Color>
    <Color x:Key="Color.BorderStrong">#FF2F5E9E</Color>
    <Color x:Key="Color.BorderStrongHover">#FF4C78B8</Color>
    <Color x:Key="Color.BorderSplash">#FF2B4A7A</Color>

    <Color x:Key="Color.AccentPrimary">#FF7D7FF4</Color>
    <Color x:Key="Color.AccentPrimaryHover">#FF9193FF</Color>
    <Color x:Key="Color.AccentPrimaryPressed">#FF6A6CDF</Color>
    <Color x:Key="Color.AccentProgress">#FF6EA8FE</Color>
    <Color x:Key="Color.AccentChipBackground">#1B7D7FF4</Color>

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextTertiary" Color="{StaticResource Color.TextTertiary}" />
    <SolidColorBrush x:Key="Brush.TextInfo" Color="{StaticResource Color.TextInfo}" />
    <SolidColorBrush x:Key="Brush.TextDanger" Color="{StaticResource Color.TextDanger}" />
    <SolidColorBrush x:Key="Brush.ValidationError" Color="{StaticResource Color.TextValidationError}" />
    <SolidColorBrush x:Key="Brush.TextSelection" Color="{StaticResource Color.TextSelection}" />
    <SolidColorBrush x:Key="Brush.TextHighlight" Color="{StaticResource Color.TextHighlight}" />
    <SolidColorBrush x:Key="Brush.TextBrand" Color="{StaticResource Color.TextBrand}" />

    <SolidColorBrush x:Key="Brush.SurfaceCard" Color="{StaticResource Color.SurfaceCard}" />
    <SolidColorBrush x:Key="Brush.SurfaceDialog" Color="{StaticResource Color.SurfaceDialog}" />
    <SolidColorBrush x:Key="Brush.SurfaceSplash" Color="{StaticResource Color.SurfaceSplash}" />
    <SolidColorBrush x:Key="Brush.SurfaceSubtle" Color="{StaticResource Color.SurfaceSubtle}" />
    <SolidColorBrush x:Key="Brush.SurfaceSecondaryButton" Color="{StaticResource Color.SurfaceSecondaryButton}" />
    <SolidColorBrush x:Key="Brush.SurfaceSecondaryButtonHover" Color="{StaticResource Color.SurfaceSecondaryButtonHover}" />
    <SolidColorBrush x:Key="Brush.SurfaceSecondaryButtonPressed" Color="{StaticResource Color.SurfaceSecondaryButtonPressed}" />
    <SolidColorBrush x:Key="Brush.SurfaceProgressTrack" Color="{StaticResource Color.SurfaceProgressTrack}" />
    <SolidColorBrush x:Key="Brush.SurfaceOverlay" Color="{StaticResource Color.SurfaceOverlay}" />
    <SolidColorBrush x:Key="Brush.SurfaceBusyOverlay" Color="{StaticResource Color.SurfaceBusyOverlay}" />
    <SolidColorBrush x:Key="Brush.SurfaceGridAccent" Color="{StaticResource Color.SurfaceGridAccent}" />

    <SolidColorBrush x:Key="Brush.BorderAccent" Color="{StaticResource Color.BorderAccent}" />
    <SolidColorBrush x:Key="Brush.BorderAccentSoft" Color="{StaticResource Color.BorderAccentSoft}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}" />
    <SolidColorBrush x:Key="Brush.BorderStrongHover" Color="{StaticResource Color.BorderStrongHover}" />
    <SolidColorBrush x:Key="Brush.BorderSplash" Color="{StaticResource Color.BorderSplash}" />

    <SolidColorBrush x:Key="Brush.AccentPrimary" Color="{StaticResource Color.AccentPrimary}" />
    <SolidColorBrush x:Key="Brush.AccentPrimaryHover" Color="{StaticResource Color.AccentPrimaryHover}" />
    <SolidColorBrush x:Key="Brush.AccentPrimaryPressed" Color="{StaticResource Color.AccentPrimaryPressed}" />
    <SolidColorBrush x:Key="Brush.AccentProgress" Color="{StaticResource Color.AccentProgress}" />
    <SolidColorBrush x:Key="Brush.AccentChipBackground" Color="{StaticResource Color.AccentChipBackground}" />

    <sys:Double x:Key="FontSize.Caption">11</sys:Double>
    <sys:Double x:Key="FontSize.Body">12</sys:Double>
    <sys:Double x:Key="FontSize.Label">13</sys:Double>
    <sys:Double x:Key="FontSize.DialogTitle">14</sys:Double>
    <sys:Double x:Key="FontSize.SectionHeader">16</sys:Double>
    <sys:Double x:Key="FontSize.PageTitle">18</sys:Double>
    <sys:Double x:Key="FontSize.HeroTitle">19</sys:Double>
    <sys:Double x:Key="FontSize.CodeLabel">24</sys:Double>

    <Style x:Key="TextStyle.SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.SectionHeader}" />
    </Style>

    <Style x:Key="TextStyle.PageTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.PageTitle}" />
    </Style>

    <Style x:Key="TextStyle.HeroTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.HeroTitle}" />
    </Style>

    <Style x:Key="TextStyle.Subheader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
    </Style>

    <Style x:Key="TextStyle.Caption" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
    </Style>

    <Style x:Key="TextStyle.FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Label}" />
    </Style>

    <Style x:Key="TextStyle.DialogTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.DialogTitle}" />
    </Style>

    <Style x:Key="ButtonStyle.SecondaryAction" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceSecondaryButton}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.SurfaceSecondaryButtonHover}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrongHover}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.SurfaceSecondaryButtonPressed}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrongHover}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.65" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ButtonStyle.PrimaryAction" TargetType="Button" BasedOn="{StaticResource ButtonStyle.SecondaryAction}">
        <Setter Property="Background" Value="{StaticResource Brush.AccentPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderAccentSoft}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.AccentPrimaryHover}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderAccentSoft}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.AccentPrimaryPressed}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderAccentSoft}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.65" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
