<UserControl x:Class="TOTP.UserControls.RevealableSecretBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:props="clr-namespace:TOTP.AttachedProperties"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:converters="http://sharpvectors.codeplex.com/svgc/"
             x:Name="ucRevealableSecretBox"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <!-- One-column overlay layout (like your original) -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Hidden secret (PasswordBox) -->
        <PasswordBox x:Name="PartPasswordBox" Height="{Binding FieldHeight, ElementName=ucRevealableSecretBox}"
                     Padding="{Binding TextPadding, ElementName=ucRevealableSecretBox}"
                     VerticalContentAlignment="Center"
                     props:PasswordBoxHelper.BindPassword="True"
                     props:PasswordBoxHelper.BoundPassword="{Binding Secret, ElementName=ucRevealableSecretBox,
                             Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding IsSecretVisible,
                                          ElementName=ucRevealableSecretBox,
                                          Converter={StaticResource InverseBoolToVisibilityConverter}}" />

        <!-- Visible secret (TextBox) -->
        <TextBox x:Name="PartPasswordBoxVisible" Height="{Binding FieldHeight, ElementName=ucRevealableSecretBox}"
                 Padding="{Binding TextPadding, ElementName=ucRevealableSecretBox}"
                 VerticalContentAlignment="Center"
                 Text="{Binding Secret, ElementName=ucRevealableSecretBox,
                                Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Visibility="{Binding IsSecretVisible,
                                      ElementName=ucRevealableSecretBox,
                                      Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- Eye button (overlay right) -->
        <ToggleButton HorizontalAlignment="Right"
                      Width="{Binding ToggleButtonWidth, ElementName=ucRevealableSecretBox}"
                      Height="{Binding FieldHeight, ElementName=ucRevealableSecretBox}"
                      Margin="{Binding ToggleButtonMargin, ElementName=ucRevealableSecretBox}"
                      IsChecked="{Binding IsSecretVisible, ElementName=ucRevealableSecretBox, Mode=TwoWay}"
                      ToolTip="{Binding ToggleToolTip, ElementName=ucRevealableSecretBox}"
                      Focusable="False"
                      Style="{Binding ToggleButtonStyle, ElementName=ucRevealableSecretBox}">

            <Grid Width="{Binding IconSize, ElementName=ucRevealableSecretBox}"
                  Height="{Binding IconSize, ElementName=ucRevealableSecretBox}">

                <!-- visible -> closed icon (your original behavior) -->
                <svgc:SvgViewbox Source="{Binding EyeClosedIconSource, ElementName=ucRevealableSecretBox}"
                                 Stretch="Uniform"
                                 Visibility="{Binding IsSecretVisible,
                                                      ElementName=ucRevealableSecretBox,
                                                      Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- hidden -> open icon -->
                <converters:SvgViewbox Source="{Binding EyeOpenIconSource, ElementName=ucRevealableSecretBox}"
                                       Stretch="Uniform"
                                       Visibility="{Binding IsSecretVisible,
                                                            ElementName=ucRevealableSecretBox,
                                                            Converter={StaticResource InverseBoolToVisibilityConverter}}" />
            </Grid>
        </ToggleButton>
    </Grid>
</UserControl>
