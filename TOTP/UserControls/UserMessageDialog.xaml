<Window x:Class="TOTP.UserControls.UserMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True">

        <Window.Resources>

                <!-- =========================================================
             PALETTE (warning dialog compatible with your app)
             ========================================================= -->

                <!-- Surfaces -->
                <Color x:Key="Dlg.Bg1">#FF0C1C33</Color>
                <Color x:Key="Dlg.Bg2">#FF122A4B</Color>
                <Color x:Key="Dlg.Panel">#FF102440</Color>
                <Color x:Key="Dlg.Border">#FF2C4B70</Color>

                <!-- Text -->
                <Color x:Key="Dlg.TextPrimary">#FFF3F7FF</Color>
                <Color x:Key="Dlg.TextSecondary">#FFC8D6EA</Color>

                <!-- Warning accent -->
                <Color x:Key="Dlg.Warning1">#FFFFD24A</Color>
                <Color x:Key="Dlg.Warning2">#FFFFB400</Color>

                <!-- Buttons (neutral) -->
                <Color x:Key="Dlg.BtnNeutralBg">#FF3A4A63</Color>
                <Color x:Key="Dlg.BtnNeutralBgHover">#FF465A78</Color>
                <Color x:Key="Dlg.BtnNeutralBgPressed">#FF2F3C52</Color>
                <Color x:Key="Dlg.BtnNeutralBorder">#FF566A86</Color>

                <!-- Buttons (danger) -->
                <Color x:Key="Dlg.BtnDangerBg">#FFB1151D</Color>
                <Color x:Key="Dlg.BtnDangerBgHover">#FFC61C26</Color>
                <Color x:Key="Dlg.BtnDangerBgPressed">#FF8F1016</Color>
                <Color x:Key="Dlg.BtnDangerBorder">#FFD25B61</Color>

                <!-- =========================================================
             BRUSHES (WPF setters need brushes, not colors)
             ========================================================= -->

                <SolidColorBrush x:Key="Dlg.TextPrimaryBrush"
                                 Color="{StaticResource Dlg.TextPrimary}" />
                <SolidColorBrush x:Key="Dlg.TextSecondaryBrush"
                                 Color="{StaticResource Dlg.TextSecondary}" />
                <SolidColorBrush x:Key="Dlg.PanelBrush"
                                 Color="{StaticResource Dlg.Panel}" />
                <SolidColorBrush x:Key="Dlg.BorderBrush"
                                 Color="{StaticResource Dlg.Border}" />

                <LinearGradientBrush x:Key="Dlg.BackgroundBrush"
                                     StartPoint="0,0"
                                     EndPoint="0,1">
                        <GradientStop Color="{StaticResource Dlg.Bg2}"
                                      Offset="0" />
                        <GradientStop Color="{StaticResource Dlg.Bg1}"
                                      Offset="1" />
                </LinearGradientBrush>

                <LinearGradientBrush x:Key="Dlg.WarningBrush"
                                     StartPoint="0,0"
                                     EndPoint="1,1">
                        <GradientStop Color="{StaticResource Dlg.Warning1}"
                                      Offset="0" />
                        <GradientStop Color="{StaticResource Dlg.Warning2}"
                                      Offset="1" />
                </LinearGradientBrush>

                <!-- Brushes (NEUTRAL) -->
                <SolidColorBrush x:Key="Dlg.BtnNeutralBgBrush"
                                 Color="{StaticResource Dlg.BtnNeutralBg}" />
                <SolidColorBrush x:Key="Dlg.BtnNeutralBgHoverBrush"
                                 Color="{StaticResource Dlg.BtnNeutralBgHover}" />
                <SolidColorBrush x:Key="Dlg.BtnNeutralBgPressedBrush"
                                 Color="{StaticResource Dlg.BtnNeutralBgPressed}" />
                <SolidColorBrush x:Key="Dlg.BtnNeutralBorderBrush"
                                 Color="{StaticResource Dlg.BtnNeutralBorder}" />

                <!-- Brushes (DANGER) -->
                <SolidColorBrush x:Key="Dlg.BtnDangerBgBrush"
                                 Color="{StaticResource Dlg.BtnDangerBg}" />
                <SolidColorBrush x:Key="Dlg.BtnDangerBgHoverBrush"
                                 Color="{StaticResource Dlg.BtnDangerBgHover}" />
                <SolidColorBrush x:Key="Dlg.BtnDangerBgPressedBrush"
                                 Color="{StaticResource Dlg.BtnDangerBgPressed}" />
                <SolidColorBrush x:Key="Dlg.BtnDangerBorderBrush"
                                 Color="{StaticResource Dlg.BtnDangerBorder}" />

                <!-- =========================================================
             TYPOGRAPHY (your requirement: 12 normal, 16 headers)
             ========================================================= -->
                <sys:Double x:Key="Dlg.Font.Normal">12</sys:Double>
                <sys:Double x:Key="Dlg.Font.Header">16</sys:Double>

                <!-- =========================================================
             BUTTONS
             ========================================================= -->

                <Style x:Key="DialogButtonBaseStyle"
                       TargetType="Button">
                        <Setter Property="Padding"
                                Value="11,6" />
                        <Setter Property="FontSize"
                                Value="{StaticResource Dlg.Font.Normal}" />
                        <Setter Property="FontWeight"
                                Value="SemiBold" />
                        <Setter Property="Cursor"
                                Value="Hand" />
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />
                        <Setter Property="BorderThickness"
                                Value="1" />
                        <Setter Property="Foreground"
                                Value="{StaticResource Dlg.TextPrimaryBrush}" />
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        CornerRadius="6"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                        <Border.Effect>
                                                                <DropShadowEffect Color="#000000"
                                                                                  Opacity="0.35"
                                                                                  BlurRadius="10"
                                                                                  ShadowDepth="2" />
                                                        </Border.Effect>
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Margin="{TemplateBinding Padding}" />
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter TargetName="Bd"
                                                                        Property="Opacity"
                                                                        Value="0.92" />
                                                                <Setter TargetName="Bd"
                                                                        Property="RenderTransform">
                                                                        <Setter.Value>
                                                                                <TranslateTransform Y="1" />
                                                                        </Setter.Value>
                                                                </Setter>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled"
                                                                 Value="False">
                                                                <Setter Property="Opacity"
                                                                        Value="0.55" />
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- Cancel / secondary -->
                <Style x:Key="DialogCancelButtonStyle"
                       TargetType="Button"
                       BasedOn="{StaticResource DialogButtonBaseStyle}">
                        <Setter Property="Background"
                                Value="{StaticResource Dlg.BtnNeutralBgBrush}" />
                        <Setter Property="BorderBrush"
                                Value="{StaticResource Dlg.BtnNeutralBorderBrush}" />
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{StaticResource Dlg.BtnNeutralBgHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{StaticResource Dlg.BtnNeutralBgPressedBrush}" />
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- Destructive -->
                <Style x:Key="DialogDangerButtonStyle"
                       TargetType="Button"
                       BasedOn="{StaticResource DialogButtonBaseStyle}">
                        <Setter Property="Background"
                                Value="{StaticResource Dlg.BtnDangerBgBrush}" />
                        <Setter Property="BorderBrush"
                                Value="{StaticResource Dlg.BtnDangerBorderBrush}" />
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{StaticResource Dlg.BtnDangerBgHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{StaticResource Dlg.BtnDangerBgPressedBrush}" />
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- Close button (X) -->
                <Style x:Key="DialogCloseButtonStyle"
                       TargetType="Button">
                        <Setter Property="Width"
                                Value="26" />
                        <Setter Property="Height"
                                Value="26" />
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Setter Property="Foreground"
                                Value="{StaticResource Dlg.TextSecondaryBrush}" />
                        <Setter Property="Cursor"
                                Value="Hand" />
                        <Setter Property="Focusable"
                                Value="False" />
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />
                        <Setter Property="FontSize"
                                Value="{StaticResource Dlg.Font.Normal}" />
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        CornerRadius="8"
                                                        Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="Bd"
                                                                        Property="Background"
                                                                        Value="#22FFFFFF" />
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource Dlg.TextPrimaryBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter TargetName="Bd"
                                                                        Property="Background"
                                                                        Value="#33FFFFFF" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled"
                                                                 Value="False">
                                                                <Setter Property="Opacity"
                                                                        Value="0.55" />
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

        </Window.Resources>

        <!-- Card only (NO overlay here) -->
        <Border CornerRadius="10"
                Background="{StaticResource Dlg.BackgroundBrush}"
                BorderThickness="1"
                BorderBrush="{StaticResource Dlg.BorderBrush}"
                Padding="18"
                SnapsToDevicePixels="True">

                <Border.Effect>
                        <DropShadowEffect BlurRadius="24"
                                          ShadowDepth="8"
                                          Opacity="0.55" />
                </Border.Effect>

                <Grid>
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Icon - Header - Close X -->
                        <Grid Grid.Row="0"
                              Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Attention Icon -->
                                <Border Grid.Column="0"
                                        Width="38"
                                        Height="38"
                                        CornerRadius="19"
                                        Background="{StaticResource Dlg.PanelBrush}"
                                        BorderBrush="{StaticResource Dlg.BorderBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Top"
                                        Visibility="{Binding IconVisibility}">
                                        <Image Source="{Binding IconPath}"
                                               Width="22"
                                               Height="22"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Header -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CaptionString}"
                                           Margin="10,7,0,0"
                                           FontSize="{StaticResource Dlg.Font.Header}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Dlg.WarningBrush}"
                                           VerticalAlignment="Top" />

                                <!-- Close -->
                                <Button Grid.Column="2"
                                        Margin="6,-2,-2,0"
                                        Content="✕"
                                        Style="{StaticResource DialogCloseButtonStyle}"
                                        IsCancel="True"
                                        Command="{Binding CancelCommand}"
                                        Visibility="{Binding CancelButtonVisibility}" />
                        </Grid>

                        <!-- Message -->
                        <Border Grid.Row="1"
                                Background="{StaticResource Dlg.PanelBrush}"
                                BorderBrush="{StaticResource Dlg.BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,14">
                                <TextBlock Text="{Binding Message}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource Dlg.TextPrimaryBrush}"
                                           FontSize="{StaticResource Dlg.Font.Normal}"
                                           LineHeight="20" />
                        </Border>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                                <Button Style="{StaticResource DialogCancelButtonStyle}"
                                        Margin="0,0,10,0"
                                        Content="{Binding CancelButtonText}"
                                        Visibility="{Binding CancelButtonVisibility}"
                                        IsCancel="True"
                                        Command="{Binding CancelCommand}" />

                                <Button Style="{StaticResource DialogDangerButtonStyle}"
                                        Content="{Binding OkButtonText}"
                                        IsDefault="True"
                                        Command="{Binding OkCommand}" />
                        </StackPanel>
                </Grid>
        </Border>
</Window>
