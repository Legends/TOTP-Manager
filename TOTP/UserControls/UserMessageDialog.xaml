<Window x:Class="TOTP.UserControls.UserMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True">

        <Window.Resources>

                <!-- Base dialog button: modern, no default WPF chrome -->
                <Style x:Key="DialogButtonStyle"
                       TargetType="Button">
                        <!--<Setter Property="MinWidth"
                    Value="110" />
            <Setter Property="Height"
                    Value="34" />-->
                        <Setter Property="Padding"
                                Value="5,3" />
                        <Setter Property="FontSize"
                                Value="10" />
                        <Setter Property="FontWeight"
                                Value="SemiBold" />
                        <Setter Property="Cursor"
                                Value="Hand" />

                        <!-- Remove dotted/blue focus visuals -->
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />

                        <!-- Secondary look -->
                        <Setter Property="Background"
                                Value="#223A73" />
                        <Setter Property="BorderBrush"
                                Value="#2A3C6A" />
                        <Setter Property="Foreground"
                                Value="White" />
                        <Setter Property="BorderThickness"
                                Value="1" />

                        <!--Buttons Template-->
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        CornerRadius="2"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Margin="{TemplateBinding Padding}" />
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="Bd"
                                                                        Property="Background"
                                                                        Value="#2B4B8C" />
                                                                <Setter TargetName="Bd"
                                                                        Property="BorderBrush"
                                                                        Value="#36579E" />
                                                        </Trigger>

                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter TargetName="Bd"
                                                                        Property="Background"
                                                                        Value="#1C3363" />
                                                                <Setter TargetName="Bd"
                                                                        Property="BorderBrush"
                                                                        Value="#1C3363" />
                                                        </Trigger>

                                                        <Trigger Property="IsEnabled"
                                                                 Value="False">
                                                                <Setter Property="Opacity"
                                                                        Value="0.55" />
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- OK button -->
                <Style x:Key="DialogOkButtonStyle"
                       TargetType="Button"
                       BasedOn="{StaticResource DialogButtonStyle}">
                        <Setter Property="Background"
                                Value="#2F6FED" />
                        <Setter Property="BorderBrush"
                                Value="#2F6FED" />
                        <Setter Property="Foreground"
                                Value="White" />

                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#3A7BFF" />
                                        <Setter Property="BorderBrush"
                                                Value="#3A7BFF" />
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#245DCC" />
                                        <Setter Property="BorderBrush"
                                                Value="#245DCC" />
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- Close button (X) - no old-school button chrome -->
                <Style x:Key="DialogCloseButtonStyle"
                       TargetType="Button">
                        <Setter Property="Width"
                                Value="12" />

                        <Setter Property="Height"
                                Value="12" />
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Setter Property="Foreground"
                                Value="#B8C6F2" />
                        <Setter Property="Cursor"
                                Value="Hand" />
                        <Setter Property="Focusable"
                                Value="False" />
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        CornerRadius="8"
                                                        Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <!-- subtle hover only (optional) -->
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="Bd"
                                                                        Property="Background"
                                                                        Value="#1AFFFFFF" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter TargetName="Bd"
                                                                        Property="Background"
                                                                        Value="#2AFFFFFF" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled"
                                                                 Value="False">
                                                                <Setter Property="Opacity"
                                                                        Value="0.55" />
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

        </Window.Resources>

        <!-- Card only (NO overlay here) -->
        <Border CornerRadius="14"
                Background="#14264F"
                BorderThickness="1"
                BorderBrush="#2A3C6A"
                Padding="18"
                SnapsToDevicePixels="True">

                <Border.Effect>
                        <DropShadowEffect BlurRadius="22"
                                          ShadowDepth="0"
                                          Opacity="0.45" />
                </Border.Effect>


                <!--MinWidth="300"
                MaxWidth="460"-->
                <Grid>
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Icon - Header - CLose X -->
                        <Grid Grid.Row="0"
                              Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--Attention Icon-->
                                <Border Grid.Column="0"
                                        Width="30"
                                        Height="30"
                                        CornerRadius="19"
                                        Background="#223A73"
                                        VerticalAlignment="Top"
                                        Visibility="{Binding IconVisibility}">
                                        <Image Source="{Binding IconPath}"
                                               Width="22"
                                               Height="22"
                                               Margin="0,2,0,0"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!--Header - Achtung -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CaptionString}"
                                           Margin="12,5,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#E8EEFF"
                                           VerticalAlignment="Top" />

                                <!-- Close -->
                                <Button Grid.Column="2"
                                        Margin="8,-40,-10,0"
                                        Content="✕"
                                        Style="{StaticResource DialogCloseButtonStyle}"
                                        IsCancel="True"
                                        Command="{Binding CancelCommand}"
                                        Visibility="{Binding CancelButtonVisibility}" />
                        </Grid>

                        <!-- Message -->
                        <TextBlock Grid.Row="1"
                                   Text="{Binding Message}"
                                   TextWrapping="Wrap"
                                   Foreground="#B8C6F2"
                                   FontSize="13"
                                   LineHeight="20"
                                   Margin="0,0,0,18" />

                        <!-- Buttons -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                                <Button Style="{StaticResource DialogButtonStyle}"
                                        Margin="0,0,10,0"
                                        Content="{Binding CancelButtonText}"
                                        Visibility="{Binding CancelButtonVisibility}"
                                        IsCancel="True"
                                        Command="{Binding CancelCommand}" />

                                <Button Style="{StaticResource DialogOkButtonStyle}"
                                        Content="{Binding OkButtonText}"
                                        IsDefault="True"
                                        Command="{Binding OkCommand}" />
                        </StackPanel>
                </Grid>
        </Border>
</Window>
