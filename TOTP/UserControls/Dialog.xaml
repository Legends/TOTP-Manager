<syncfusion:ChromelessWindow x:Class="TOTP.UserControls.Dialog"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=MaterialDarkBlue}"
                             WindowStartupLocation="CenterScreen"
                             ResizeMode="NoResize"
                             SizeToContent="WidthAndHeight"
                             MinWidth="300"
                             MinHeight="150"
                             MaxWidth="600"
                             MaxHeight="400"
                             TitleBarBackground="{Binding TitleBarBackground}"
                             TitleBarForeground="{Binding TitleBarForeground}"
                             Title="{Binding Caption}"
                             UseNativeChrome="False">

    <Border Padding="10"
            Background="{DynamicResource Brush.Background}">
        <StackPanel HorizontalAlignment="Center">

            <!-- Icon with rounded background -->
            <Border Width="45"
                    Height="45"
                    
                    Background="{DynamicResource Brush.AlternateBackground}"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    Visibility="{Binding IconVisibility}">
                <Image Source="{Binding IconPath}" Width="30"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />
            </Border>

            <!-- Message Text -->
            <TextBlock Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.Foreground}"
                       MaxWidth="500"
                       Margin="0,0,0,10"
                       TextAlignment="Center" />

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0">
                <Button Width="100"
                        Margin="5,0"
                        Content="{Binding OkButtonText}"
                        IsDefault="True"
                        Click="Ok_Click" />

                <Button Width="100"
                        Margin="5,0"
                        Content="{Binding CancelButtonText}"
                        Visibility="{Binding CancelButtonVisibility}"
                        IsCancel="True"
                        Click="Cancel_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</syncfusion:ChromelessWindow>
