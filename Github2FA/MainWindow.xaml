<Window x:Class="Github2FA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:local="clr-namespace:Github2FA.ViewModels"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:Github2FA.Behaviors"
        mc:Ignorable="d"
        Width="300"
        Height="350"
        Title="TOTP code generator"
        WindowStartupLocation="CenterScreen">
    <!--Loaded="Window_Loaded">-->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <ResourceDictionary x:Key="gridStyle"
                            Source="/StylesDictionary.xaml" />       
    </Window.Resources>

    <StackPanel Orientation="Vertical"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
        <syncfusion:MenuAdv Orientation="Horizontal"
                            ExpandMode="ExpandOnClick"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="10">

            <syncfusion:MenuItemAdv Header="Add new (T)OTP Provider"
                                    VerticalContentAlignment="Center"
                                    Command="{Binding AddNewTotpCommand}" />

            <!--<syncfusion:MenuItemAdv Header="Command 2"                                  
                                    Command="{Binding Cmd2Command}" Foreground="#FF0A0B0C" />

            <syncfusion:MenuItemAdv Header="Command 3"
                                    Command="{Binding Cmd3Command}" />-->

            <!--<syncfusion:MenuItemAdv Style="{DynamicResource FancyAnimatedMenuItemAdvStyle}"
                                    Header="Command 4"
                                    Command="{Binding Cmd3Command}" />-->

        </syncfusion:MenuAdv>
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!-- Row 0: DataGrid -->
                <RowDefinition Height="Auto" />
                <!-- Row 1: Code Label -->
                <RowDefinition Height="Auto" />
                <!-- Row 2: Copied Label -->
            </Grid.RowDefinitions>

            <syncfusion:SfDataGrid x:Name="SecretsGrid"
                                   AllowEditing="True"
                                   AllowDeleting="True"
                                   AutoGenerateColumns="False"
                                   ItemsSource="{Binding Secrets}"
                                   SelectedItem="{Binding SelectedSecret, Mode=TwoWay}"                                   
                                   SelectionMode="Single"
                                   SelectionUnit="Row"
                                   MaxHeight="140"
                                   BorderThickness="0"
                                   RowSelectionBrush="LightYellow"
                                   SelectionForegroundBrush="DarkBlue"
                                   CurrentCellBorderBrush="Transparent"
                                   CurrentCellBorderThickness="0"
                                   Grid.Row="0"
                                   HorizontalAlignment="Stretch"
                                   ColumnSizer="Star">
                <i:Interaction.Behaviors>
                    <behaviors:SfDataGridEditingBehavior BeginEditCommand="{Binding BeginEditCommand}"
                                                         EndEditCommand="{Binding EndEditCommand}"
                                                         DoubleClickCommand="{Binding DoubleClickCommand}" />
                    <behaviors:ToggleColumnVisibilityBehavior ShowActionsColumn="{Binding ShowActionsColumn}" />
                </i:Interaction.Behaviors>


                <syncfusion:SfDataGrid.Resources>
                    <Style TargetType="syncfusion:GridHeaderCellControl">
                        <Setter Property="Background"
                                Value="#FF005577" />
                        <!-- Deep blue -->
                        <Setter Property="Foreground"
                                Value="White" />
                        <Setter Property="FontWeight"
                                Value="Bold" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Center" />
                    </Style>

                </syncfusion:SfDataGrid.Resources>

                <syncfusion:SfDataGrid.Columns>

                    <syncfusion:GridTextColumn HeaderText="TOTP"
                                               MappingName="Key" />

                    <syncfusion:GridTextColumn HeaderText="Secret"
                                               MappingName="Value" />

                    <syncfusion:GridTemplateColumn x:Name="ActionsColumn"
                                                   HeaderText="Actions">

                        <syncfusion:GridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBeingEdited}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Delete Button -->

                                    <Button  FontFamily="Segoe MDL2 Assets"
                                             Content="&#xE74D;"
                                             ToolTip="Delete"
                                             Command="{Binding DataContext.DeleteSecretCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                             CommandParameter="{Binding}"
                                             Focusable="False" />


                                    <!-- Edit Button -->
                                    <!--<Button FontFamily="Segoe MDL2 Assets"
                                            Content="&#xE74E;"
                                            ToolTip="Save"
                                            Command="{Binding DataContext.UpdateSecretCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Focusable="False"
                                            Margin="4,0,0,0" />-->
                                </StackPanel>
                            </DataTemplate>
                        </syncfusion:GridTemplateColumn.CellTemplate>
                    </syncfusion:GridTemplateColumn>

                </syncfusion:SfDataGrid.Columns>
            </syncfusion:SfDataGrid>

            <Label x:Name="lblCode"
                   Content="{Binding CurrentCodeLabel}"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Height="80"
                   FontWeight="Bold"
                   FontSize="24"
                   Grid.Row="1"
                   HorizontalAlignment="Center"
                   Margin="0,0" />

            <Label x:Name="lblCopiedToClipboard"
                   Content="Code was copied to clipboard!"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Top"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#FF22ED20"
                   Visibility="{Binding IsCodeCopiedVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                   Grid.Row="2"
                   Margin="0,0">
                <Label.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      Color="Aqua" />
                </Label.Effect>
            </Label>
        </Grid>
    </StackPanel>
</Window>
