<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <UserSecretsId>6f888768-43da-4da8-9820-96b854382d72</UserSecretsId>
    <ApplicationIcon>github.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="github.ico" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\readme.md" Link="readme.md" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="7.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.UserSecrets" Version="6.0.1" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.5" />
    <PackageReference Include="Otp.NET" Version="1.3.0" />
    <PackageReference Include="Syncfusion.Licensing" Version="29.2.9" />
    <PackageReference Include="syncfusion.ui.wpf.net" Version="29.1.33" />
  </ItemGroup>

</Project>
